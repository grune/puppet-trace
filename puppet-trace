            m2 = re.search(r'connect\(.*sin_addr=inet_addr\("([^"]+)"\).*sin_port=htons\((\d+)\)', line)
            if m2:
                net_connects.append({'addr': m2.group(1), 'port': m2.group(2)})
            m3 = re.search(r'^\d+\s+(\S+)\s+(\S+)', line)
            if m3 and not m:
                op, path = m3.group(1), m3.group(2)
                file_counter[path] += 1
                op_types[path].add(op)

top_files = file_counter.most_common(20)
total_files = sum(file_counter.values())

ss_conns = []
if os.path.isfile(net_log):
    with open(net_log) as f:
        for line in f:
            if line.startswith('#'):
                continue
            parts = line.split()
            if len(parts) >= 5 and parts[0] in ('ESTAB', 'CLOSE_WAIT', 'SYN_SENT', 'TIME_WAIT'):
                ss_conns.append({'state': parts[0], 'local': parts[3], 'remote': parts[4]})

seen = set()
unique_conns = []
for c in ss_conns:
    key = (c['state'], c['remote'])
    if key not in seen:
        seen.add(key)
        unique_conns.append(c)
unique_conns.extend(net_connects)

def make_line_chart(points, title, ylabel, color, width=700, height=200):
    if not points:
        return f'<div class="chart-empty">No data for {html.escape(title)}</div>'
    xs = [p[0] for p in points]
    ys = [p[1] for p in points]
    minx, maxx = min(xs), max(xs)
    miny, maxy = min(ys), max(ys)
    if maxy == miny: maxy = miny + 1
    if maxx == minx: maxx = minx + 1
    pad = 40
    pw = width - 2 * pad
    ph = height - 2 * pad
    def tx(v): return pad + (v - minx) / (maxx - minx) * pw
    def ty(v): return height - pad - (v - miny) / (maxy - miny) * ph
    pts = ' '.join(f'{tx(p[0]):.1f},{ty(p[1]):.1f}' for p in points)
    ticks_y = [miny, (miny + maxy) / 2, maxy]
    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" style="background:#fff;border:1px solid #e0e0e0;border-radius:4px">']
    svg.append(f'<text x="{width//2}" y="14" text-anchor="middle" font-family="monospace" font-size="12" font-weight="bold">{html.escape(title)}</text>')
    svg.append(f'<line x1="{pad}" y1="{pad}" x2="{pad}" y2="{height-pad}" stroke="#888" stroke-width="1"/>')
    svg.append(f'<line x1="{pad}" y1="{height-pad}" x2="{width-pad}" y2="{height-pad}" stroke="#888" stroke-width="1"/>')
    for v in ticks_y:
        yy = ty(v)
        svg.append(f'<line x1="{pad-4}" y1="{yy:.1f}" x2="{pad}" y2="{yy:.1f}" stroke="#888"/>')
        svg.append(f'<text x="{pad-6}" y="{yy+4:.1f}" text-anchor="end" font-family="monospace" font-size="10">{v:.0f}</text>')
    svg.append(f'<polyline points="{pts}" fill="none" stroke="{color}" stroke-width="2"/>')
    svg.append(f'<text x="10" y="{height//2}" text-anchor="middle" font-family="monospace" font-size="10" transform="rotate(-90,10,{height//2})">{html.escape(ylabel)}</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

def make_memory_chart(mem_points_ts, io_resources, width=900, height=300):
    """Enhanced memory chart: RSS over time with per-resource eval bands and min/max/peak lines.
    mem_points_ts: [(unix_ts, rss_kb)]; io_resources: correlated list with t_start/t_end."""
    if not mem_points_ts:
        return '<div class="chart-empty">No memory samples collected.</div>'
    xs = [p[0] for p in mem_points_ts]
    ys = [p[1] for p in mem_points_ts]
    minx, maxx = min(xs), max(xs)
    miny, maxy = min(ys), max(ys)
    if maxy == miny: maxy = miny + 1
    if maxx == minx: maxx = minx + 1
    pad_l, pad_r, pad_t, pad_b = 65, 20, 36, 36
    pw = width - pad_l - pad_r
    ph = height - pad_t - pad_b
    def tx(v):
        v = max(minx, min(maxx, v))
        return pad_l + (v - minx) / (maxx - minx) * pw
    def ty(v):
        return height - pad_b - (v - miny) / (maxy - miny) * ph
    avg_y = sum(ys) / len(ys)
    peak_y = maxy
    min_y  = miny
    status_colors = {
        'changed':    'rgba(39,174,96,0.18)',
        'failed':     'rgba(232,64,64,0.22)',
        'skipped':    'rgba(243,156,18,0.18)',
        'out_of_sync':'rgba(74,144,217,0.15)',
