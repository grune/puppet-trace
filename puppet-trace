def make_line_chart(points, title, ylabel, color, width=700, height=200):
    if not points:
        return f'<div class="chart-empty">No data for {html.escape(title)}</div>'
    xs = [p[0] for p in points]
    ys = [p[1] for p in points]
    minx, maxx = min(xs), max(xs)
    miny, maxy = min(ys), max(ys)
    if maxy == miny: maxy = miny + 1
    if maxx == minx: maxx = minx + 1
    pad = 40
    pw = width - 2 * pad
    ph = height - 2 * pad
    def tx(v): return pad + (v - minx) / (maxx - minx) * pw
    def ty(v): return height - pad - (v - miny) / (maxy - miny) * ph
    pts = ' '.join(f'{tx(p[0]):.1f},{ty(p[1]):.1f}' for p in points)
    ticks_y = [miny, (miny + maxy) / 2, maxy]
    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" style="background:#fff;border:1px solid #e0e0e0;border-radius:4px">']
    svg.append(f'<text x="{width//2}" y="14" text-anchor="middle" font-family="monospace" font-size="12" font-weight="bold">{html.escape(title)}</text>')
    svg.append(f'<line x1="{pad}" y1="{pad}" x2="{pad}" y2="{height-pad}" stroke="#888" stroke-width="1"/>')
    svg.append(f'<line x1="{pad}" y1="{height-pad}" x2="{width-pad}" y2="{height-pad}" stroke="#888" stroke-width="1"/>')
    for v in ticks_y:
        yy = ty(v)
        svg.append(f'<line x1="{pad-4}" y1="{yy:.1f}" x2="{pad}" y2="{yy:.1f}" stroke="#888"/>')
        svg.append(f'<text x="{pad-6}" y="{yy+4:.1f}" text-anchor="end" font-family="monospace" font-size="10">{v:.0f}</text>')
    svg.append(f'<polyline points="{pts}" fill="none" stroke="{color}" stroke-width="2"/>')
    svg.append(f'<text x="10" y="{height//2}" text-anchor="middle" font-family="monospace" font-size="10" transform="rotate(-90,10,{height//2})">{html.escape(ylabel)}</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

def make_resource_timeline(io_resources, width=1000):
    """Gantt chart: one row per resource sorted by t_start. Bar color = log-scale disk I/O."""
    import math as _math
    if not io_resources:
        return '<div class="chart-empty">No I/O resource data for timeline.</div>'
    resources = sorted(io_resources, key=lambda r: r.get('t_start', 0))
    if not resources:
        return '<div class="chart-empty">No resources with timing data.</div>'
    t_min = min(r.get('t_start', 0) for r in resources)
    t_max = max(r.get('t_end', r.get('t_start', 0)) for r in resources)
    if t_max <= t_min:
        t_max = t_min + 1
    row_h = 20
    pad_l = 220
    pad_r = 20
    pad_t = 36
    pad_b = 60
    n = len(resources)
    height = pad_t + n * row_h + pad_b
    pw = width - pad_l - pad_r

    def tx(t):
        return pad_l + (t - t_min) / (t_max - t_min) * pw

    def io_color(dw, dr):
        total = dw + dr
        if total == 0:
            return '#aaa'
        # log scale: 1KB=blue, 1MB=between, 10MB=orange, 100MB=red
        log_val = _math.log10(max(total, 1))
        # range: 3 (1KB) to 8 (100MB)
        frac = max(0.0, min(1.0, (log_val - 3) / 5))
        if frac < 0.33:
            # blue to cyan
            r = int(74 + (0 - 74) * frac / 0.33)
            g = int(144 + (200 - 144) * frac / 0.33)
            b = int(217 + (255 - 217) * frac / 0.33)
        elif frac < 0.66:
            # cyan to orange
            ff = (frac - 0.33) / 0.33
            r = int(0 + (255 - 0) * ff)
            g = int(200 + (140 - 200) * ff)
            b = int(255 + (0 - 255) * ff)
        else:
            # orange to red
            ff = (frac - 0.66) / 0.34
            r = 255
            g = int(140 + (0 - 140) * ff)
            b = 0
        return f'rgb({r},{g},{b})'

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" '
           f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">']
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="16" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">Resource I/O Timeline</text>')
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="30" text-anchor="middle" '
               f'font-family="monospace" font-size="10" fill="#666">'
               f'color = total disk I/O (gray=none, blue=small, red=large)</text>')
    # axes
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{height-pad_b}" x2="{width-pad_r}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    # x-axis ticks
    elapsed_total = t_max - t_min
    for frac in [0, 0.25, 0.5, 0.75, 1.0]:
        xv = t_min + frac * elapsed_total
        xx = tx(xv)
        svg.append(f'<line x1="{xx:.1f}" y1="{height-pad_b}" x2="{xx:.1f}" y2="{height-pad_b+4}" stroke="#888"/>')
        svg.append(f'<text x="{xx:.1f}" y="{height-pad_b+14}" text-anchor="middle" '
                   f'font-family="monospace" font-size="10">{frac*elapsed_total:.0f}s</text>')
    # rows
    for i, r in enumerate(resources):
        y = pad_t + i * row_h
        label = r.get('title', '')[:30]
        x1 = tx(r.get('t_start', t_min))
        x2 = tx(r.get('t_end', r.get('t_start', t_min)))
        bw = max(x2 - x1, 2.0)
        dw = r.get('disk_bytes_written', 0)
        dr = r.get('disk_bytes_read', 0)
        col = io_color(dw, dr)
        dur = r.get('duration_s', 0)
        tooltip = (f"{r.get('title','')} | dur:{dur:.3f}s | "
                   f"written:{fmt_bytes(dw)} | read:{fmt_bytes(dr)} | "
                   f"strace:{r.get('strace_events',0)}")
        svg.append(f'<text x="{pad_l-4}" y="{y+row_h-6}" text-anchor="end" '
                   f'font-family="monospace" font-size="9" fill="#333">{html.escape(label)}</text>')
        svg.append(f'<rect x="{x1:.1f}" y="{y+2}" width="{bw:.1f}" height="{row_h-4}" '
                   f'fill="{col}" rx="2" opacity="0.85">'
                   f'<title>{html.escape(tooltip)}</title></rect>')
    # legend
    legend_y = height - 40
    legend_items = [
        ('#aaa', 'none'),
        ('rgb(74,144,217)', 'small (<1MB)'),
        ('rgb(255,140,0)', 'medium (~10MB)'),
        ('rgb(255,0,0)', 'large (>100MB)'),
    ]
    lx = pad_l
    svg.append(f'<text x="{pad_l}" y="{legend_y-4}" font-family="monospace" font-size="10" fill="#555">I/O scale:</text>')
    lx += 58
    for col, label in legend_items:
        svg.append(f'<rect x="{lx}" y="{legend_y-10}" width="14" height="10" fill="{col}" rx="2"/>')
        svg.append(f'<text x="{lx+18}" y="{legend_y}" font-family="monospace" font-size="10" fill="#333">{html.escape(label)}</text>')
        lx += len(label) * 7 + 30
    svg.append('</svg>')
    return '\n'.join(svg)

def make_disk_io_chart(io_poll_points, io_resources, width=900, height=220):
    """Plot read/write KB/s over time from proc-io-poll cumulative bytes."""
    if len(io_poll_points) < 2:
        return '<div class="chart-empty">No disk I/O poll data collected (proc-io-poll.log).</div>'
    # compute deltas -> KB/s
    rate_points = []  # [(elapsed_s, read_kbs, write_kbs)]
    for i in range(1, len(io_poll_points)):
        ts0, rb0, wb0 = io_poll_points[i-1]
        ts1, rb1, wb1 = io_poll_points[i]
        dt_s = (ts1 - ts0) / 1000.0
        if dt_s <= 0:
            continue
        r_kbs = (rb1 - rb0) / dt_s / 1024.0
        w_kbs = (wb1 - wb0) / dt_s / 1024.0
        elapsed = (ts1 - io_poll_points[0][0]) / 1000.0
        rate_points.append((elapsed, max(r_kbs, 0), max(w_kbs, 0)))
    if not rate_points:
        return '<div class="chart-empty">No disk I/O rate data.</div>'

    pad_l, pad_r, pad_t, pad_b = 65, 20, 36, 36
    pw = width - pad_l - pad_r
    ph = height - pad_t - pad_b

    ts_start_ms = io_poll_points[0][0]
    ts_end_ms   = io_poll_points[-1][0]
    elapsed_max = max((ts_end_ms - ts_start_ms) / 1000.0, 1.0)

    all_kbs = [p[1] for p in rate_points] + [p[2] for p in rate_points]
    max_kbs = max(all_kbs) if all_kbs else 1
    if max_kbs == 0: max_kbs = 1

    def tx(t):
        return pad_l + t / elapsed_max * pw
    def ty(v):
        return height - pad_b - v / max_kbs * ph

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" '
           f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">']
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="20" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">Disk I/O Rate (KB/s)</text>')
    # axes
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{height-pad_b}" x2="{width-pad_r}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    # y ticks
    for frac in [0, 0.5, 1.0]:
        v = frac * max_kbs
        yy = ty(v)
        svg.append(f'<line x1="{pad_l-4}" y1="{yy:.1f}" x2="{pad_l}" y2="{yy:.1f}" stroke="#888"/>')
        svg.append(f'<text x="{pad_l-6}" y="{yy+4:.1f}" text-anchor="end" font-family="monospace" font-size="10">{v:.0f}</text>')
    # x ticks
    for frac in [0, 0.25, 0.5, 0.75, 1.0]:
        xv = frac * elapsed_max
        xx = tx(xv)
        svg.append(f'<line x1="{xx:.1f}" y1="{height-pad_b}" x2="{xx:.1f}" y2="{height-pad_b+4}" stroke="#888"/>')
        svg.append(f'<text x="{xx:.1f}" y="{height-pad_b+14}" text-anchor="middle" font-family="monospace" font-size="10">{xv:.0f}s</text>')
    # resource eval bands (top 20 by duration)
    band_res = sorted(
        [r for r in io_resources if r.get('t_start') and r.get('t_end')],
        key=lambda r: -r.get('duration_s', 0))[:20]
    if band_res:
        ref_t0 = band_res[0]['t_start'] if band_res else 0
        # use first io_poll ts as reference
        ref_ts0 = io_poll_points[0][0] / 1000.0
        for r in band_res:
            rx1 = tx(r['t_start'] - ref_ts0)
            rx2 = tx(r['t_end'] - ref_ts0)
            bw = max(rx2 - rx1, 1.5)
            svg.append(f'<rect x="{rx1:.1f}" y="{pad_t}" width="{bw:.1f}" height="{ph}" '
                       f'fill="rgba(74,144,217,0.08)" stroke="none">'
                       f'<title>{html.escape(r.get("title",""))}</title></rect>')
    # polylines
    r_pts = ' '.join(f'{tx(p[0]):.1f},{ty(p[1]):.1f}' for p in rate_points)
    w_pts = ' '.join(f'{tx(p[0]):.1f},{ty(p[2]):.1f}' for p in rate_points)
    svg.append(f'<polyline points="{r_pts}" fill="none" stroke="#4a90d9" stroke-width="2" stroke-linejoin="round"/>')
    svg.append(f'<polyline points="{w_pts}" fill="none" stroke="#e87b2a" stroke-width="2" stroke-linejoin="round"/>')
    # y-axis label
    mid_y = (pad_t + height - pad_b) // 2
    svg.append(f'<text x="12" y="{mid_y}" text-anchor="middle" font-family="monospace" font-size="10" '
               f'transform="rotate(-90,12,{mid_y})">KB/s</text>')
    # legend
    svg.append(f'<rect x="{width-pad_r-130}" y="{pad_t+4}" width="10" height="10" fill="#4a90d9"/>')
    svg.append(f'<text x="{width-pad_r-116}" y="{pad_t+13}" font-family="monospace" font-size="10">read rate</text>')
    svg.append(f'<rect x="{width-pad_r-130}" y="{pad_t+20}" width="10" height="10" fill="#e87b2a"/>')
    svg.append(f'<text x="{width-pad_r-116}" y="{pad_t+29}" font-family="monospace" font-size="10">write rate</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

def make_net_connections_chart(net_blocks, io_resources, width=900, height=180):
    """Step-line chart of TCP connection count over time."""
    if not net_blocks:
        return '<div class="chart-empty">No net-poll data captured.</div>'
    if len(net_blocks) < 2:
        return '<div class="chart-empty">Not enough net-poll samples.</div>'

    pad_l, pad_r, pad_t, pad_b = 50, 20, 36, 36
    pw = width - pad_l - pad_r
    ph = height - pad_t - pad_b

    ts_min = net_blocks[0][0]
    ts_max = net_blocks[-1][0]
    if ts_max == ts_min:
        ts_max = ts_min + 1
    max_cnt = max(b[1] for b in net_blocks)
    if max_cnt == 0:
        max_cnt = 1

    def tx(t):
        return pad_l + (t - ts_min) / (ts_max - ts_min) * pw
    def ty(v):
        return height - pad_b - v / max_cnt * ph

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" '
           f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">']
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="20" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">'
               f'Network Connections Over Time</text>')
    # axes
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{height-pad_b}" x2="{width-pad_r}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    # y ticks
    for v in range(0, max_cnt + 1):
        yy = ty(v)
        svg.append(f'<line x1="{pad_l-4}" y1="{yy:.1f}" x2="{pad_l}" y2="{yy:.1f}" stroke="#888"/>')
        svg.append(f'<text x="{pad_l-6}" y="{yy+4:.1f}" text-anchor="end" font-family="monospace" font-size="10">{v}</text>')
    # x ticks
    elapsed_total = ts_max - ts_min
    for frac in [0, 0.25, 0.5, 0.75, 1.0]:
        xv = ts_min + frac * elapsed_total
        xx = tx(xv)
        svg.append(f'<line x1="{xx:.1f}" y1="{height-pad_b}" x2="{xx:.1f}" y2="{height-pad_b+4}" stroke="#888"/>')
        svg.append(f'<text x="{xx:.1f}" y="{height-pad_b+14}" text-anchor="middle" font-family="monospace" font-size="10">{frac*elapsed_total:.0f}s</text>')
    # resource eval bands
    band_res = sorted(
        [r for r in io_resources if r.get('t_start') and r.get('t_end')],
        key=lambda r: -r.get('duration_s', 0))[:20]
    for r in band_res:
        rx1 = tx(r['t_start'])
        rx2 = tx(r['t_end'])
        bw = max(rx2 - rx1, 1.5)
        svg.append(f'<rect x="{rx1:.1f}" y="{pad_t}" width="{bw:.1f}" height="{ph}" '
                   f'fill="rgba(74,144,217,0.08)" stroke="none"/>')
    # step-line
    step_pts = []
    for i, (ts, cnt) in enumerate(net_blocks):
        x = tx(ts)
        y = ty(cnt)
        step_pts.append(f'{x:.1f},{y:.1f}')
        if i + 1 < len(net_blocks):
            x_next = tx(net_blocks[i+1][0])
            step_pts.append(f'{x_next:.1f},{y:.1f}')
    svg.append(f'<polyline points="{" ".join(step_pts)}" fill="none" stroke="#27ae60" stroke-width="2.5"/>')
    # dots
    for ts, cnt in net_blocks:
        svg.append(f'<circle cx="{tx(ts):.1f}" cy="{ty(cnt):.1f}" r="3" fill="#27ae60" opacity="0.8">'
                   f'<title>{cnt} connections @ t={ts-ts_min}s</title></circle>')
    svg.append(f'<text x="12" y="{(pad_t+height-pad_b)//2}" text-anchor="middle" font-family="monospace" font-size="10" '
               f'transform="rotate(-90,12,{(pad_t+height-pad_b)//2})">connections</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

def make_memory_segments_chart(pmap_texts, width=700, height=260):
    """Grouped bar chart of RSS by memory category from pmap -x output at 3 time points."""
    import re as _re2
    if not any(pmap_texts):
        return '<div class="chart-empty">No pmap data available (pmap-start/mid/end.txt not found).</div>'

    CATEGORIES = ['Heap', 'Stack', 'Shared libs', 'Files', 'Kernel', 'Other']
    CAT_COLORS  = {'Heap':'#4a90d9','Stack':'#e87b2a','Shared libs':'#27ae60',
                   'Files':'#9b59b6','Kernel':'#888','Other':'#aaa'}
    LABELS = ['Start', 'Mid', 'End']

    def categorize(mapping, addr):
        m = mapping.strip()
        if '[heap]' in m or (not m and addr):
            return 'Heap'
        if '[stack]' in m:
            return 'Stack'
        if '.so' in m or 'lib' in m.lower():
            return 'Shared libs'
        if m in ('[vvar]', '[vdso]', '[vsyscall]'):
            return 'Kernel'
        if m and m[0] == '/':
            return 'Files'
        if not m:
            return 'Heap'  # anonymous mappings treated as heap
        return 'Other'

    snapshots = []
    for txt in pmap_texts:
        cats = {c: 0 for c in CATEGORIES}
        for line in txt.splitlines():
            line = line.strip()
            # skip header/total lines
            if not line or line.startswith('Address') or line.startswith('----') or line.startswith('total'):
                continue
            parts = line.split(None, 5)
            if len(parts) < 3:
                continue
            try:
                rss = int(parts[2])
            except ValueError:
                continue
            mapping = parts[5] if len(parts) > 5 else ''
            addr = parts[0]
            cat = categorize(mapping, addr)
            cats[cat] += rss
        snapshots.append(cats)

    if not snapshots:
        return '<div class="chart-empty">Could not parse pmap data.</div>'

    max_rss = max((sum(s.values()) for s in snapshots), default=1)
    if max_rss == 0:
        max_rss = 1

    n_snaps = len(snapshots)
    n_cats  = len(CATEGORIES)
    pad_l, pad_r, pad_t, pad_b = 70, 20, 40, 80
    pw = width - pad_l - pad_r
    ph = height - pad_t - pad_b

    group_w = pw / n_snaps
    bar_w   = group_w / (n_cats + 1)

    def ty(v):
        return height - pad_b - (v / max_rss) * ph

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" '
           f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">']
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="20" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">Memory Segments by Category (pmap)</text>')
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="33" text-anchor="middle" '
               f'font-family="monospace" font-size="10" fill="#666">RSS KB by segment type at start / mid / end</text>')
    # axes
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{height-pad_b}" x2="{width-pad_r}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    # y ticks
    for frac in [0, 0.5, 1.0]:
        v = int(frac * max_rss)
        yy = ty(v)
        svg.append(f'<line x1="{pad_l-4}" y1="{yy:.1f}" x2="{pad_l}" y2="{yy:.1f}" stroke="#888"/>')
        svg.append(f'<text x="{pad_l-6}" y="{yy+4:.1f}" text-anchor="end" font-family="monospace" font-size="10">{v//1024}MB</text>')
    # bars
    for si, snap in enumerate(snapshots):
        gx = pad_l + si * group_w + bar_w * 0.5
        for ci, cat in enumerate(CATEGORIES):
            v = snap.get(cat, 0)
            if v == 0:
                continue
            bx = gx + ci * bar_w
            bh = (v / max_rss) * ph
            by = height - pad_b - bh
            svg.append(f'<rect x="{bx:.1f}" y="{by:.1f}" width="{bar_w-1:.1f}" height="{bh:.1f}" '
                       f'fill="{CAT_COLORS[cat]}" rx="2" opacity="0.85">'
                       f'<title>{cat}: {v//1024}MB ({LABELS[si]})</title></rect>')
        # group label
        lx = gx + group_w / 2 - bar_w * 0.5
        svg.append(f'<text x="{lx:.1f}" y="{height-pad_b+14}" text-anchor="middle" '
                   f'font-family="monospace" font-size="11" font-weight="bold">{LABELS[si]}</text>')
    # legend
    legend_y = height - 24
    lx = pad_l
    for cat in CATEGORIES:
        svg.append(f'<rect x="{lx}" y="{legend_y-10}" width="10" height="10" fill="{CAT_COLORS[cat]}" rx="2"/>')
        svg.append(f'<text x="{lx+13}" y="{legend_y}" font-family="monospace" font-size="9" fill="#333">{cat}</text>')
        lx += len(cat) * 6.5 + 18
    svg.append(f'<text x="12" y="{(pad_t+height-pad_b)//2}" text-anchor="middle" font-family="monospace" font-size="10" '
               f'transform="rotate(-90,12,{(pad_t+height-pad_b)//2})">RSS KB</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

def make_memory_chart(mem_points_ts, io_resources, width=900, height=300):
    """Enhanced memory chart: RSS over time with per-resource eval bands and min/max/peak lines.
    mem_points_ts: [(unix_ts, rss_kb)]; io_resources: correlated list with t_start/t_end."""
    if not mem_points_ts:
        return '<div class="chart-empty">No memory samples collected.</div>'
    xs = [p[0] for p in mem_points_ts]
    ys = [p[1] for p in mem_points_ts]
    minx, maxx = min(xs), max(xs)
    miny, maxy = min(ys), max(ys)
    if maxy == miny: maxy = miny + 1
    if maxx == minx: maxx = minx + 1
    pad_l, pad_r, pad_t, pad_b = 65, 20, 36, 36
    pw = width - pad_l - pad_r
    ph = height - pad_t - pad_b
    def tx(v):
        v = max(minx, min(maxx, v))
        return pad_l + (v - minx) / (maxx - minx) * pw
    def ty(v):
        return height - pad_b - (v - miny) / (maxy - miny) * ph
    avg_y = sum(ys) / len(ys)
    peak_y = maxy
    min_y  = miny
    status_colors = {
        'changed':    'rgba(39,174,96,0.18)',
        'failed':     'rgba(232,64,64,0.22)',
        'skipped':    'rgba(243,156,18,0.18)',
        'out_of_sync':'rgba(74,144,217,0.15)',
        'unchanged':  'rgba(180,180,180,0.08)',
    }
    svg = [
        f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" '
        f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">'
    ]
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="20" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">'
               f'Memory RSS over time (per-resource eval bands)</text>')
    # axes
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{height-pad_b}" x2="{width-pad_r}" y2="{height-pad_b}" stroke="#bbb" stroke-width="1"/>')
    # y-axis ticks
    for v in [miny, (miny+maxy)//2, maxy]:
        yy = ty(v)
        svg.append(f'<line x1="{pad_l-4}" y1="{yy:.1f}" x2="{pad_l}" y2="{yy:.1f}" stroke="#888" stroke-width="1"/>')
        svg.append(f'<text x="{pad_l-6}" y="{yy+4:.1f}" text-anchor="end" '
                   f'font-family="monospace" font-size="10">{v//1024}MB</text>')
    # x-axis ticks (elapsed seconds)
    elapsed_total = maxx - minx
    for frac in [0, 0.25, 0.5, 0.75, 1.0]:
        xv = minx + frac * elapsed_total
        xx = tx(xv)
        svg.append(f'<line x1="{xx:.1f}" y1="{height-pad_b}" x2="{xx:.1f}" y2="{height-pad_b+4}" stroke="#888" stroke-width="1"/>')
        svg.append(f'<text x="{xx:.1f}" y="{height-pad_b+14}" text-anchor="middle" '
                   f'font-family="monospace" font-size="10">{frac*elapsed_total:.0f}s</text>')
    # resource eval bands (top 40 by duration to avoid clutter)
    band_resources = sorted(
        [r for r in io_resources if r.get('t_start') and r.get('t_end')],
        key=lambda r: -r.get('duration_s', 0)
    )[:40]
    for r in band_resources:
        x1 = tx(r['t_start'])
        x2 = tx(r['t_end'])
        bw = max(x2 - x1, 1.5)
        color = status_colors.get(r.get('status','unchanged'), status_colors['unchanged'])
        short = r['title'].split('[')[0] if '[' in r['title'] else r['title']
        svg.append(f'<rect x="{x1:.1f}" y="{pad_t}" width="{bw:.1f}" height="{ph}" '
                   f'fill="{color}" stroke="none">'
                   f'<title>{html.escape(r["title"])} ({r.get("duration_s",0):.3f}s)</title>'
                   f'</rect>')
    # reference lines: min, avg, peak
    for val, label, col, dash in [
        (peak_y, f'peak {peak_y//1024}MB', '#e84040', '4,2'),
        (avg_y,  f'avg {avg_y//1024}MB',   '#888',    '2,2'),
        (min_y,  f'min {min_y//1024}MB',   '#4a90d9', '4,2'),
    ]:
        yy = ty(val)
        svg.append(f'<line x1="{pad_l}" y1="{yy:.1f}" x2="{width-pad_r}" y2="{yy:.1f}" '
                   f'stroke="{col}" stroke-width="1" stroke-dasharray="{dash}" opacity="0.7"/>')
        svg.append(f'<text x="{width-pad_r-2}" y="{yy-3:.1f}" text-anchor="end" '
                   f'font-family="monospace" font-size="9" fill="{col}">{label}</text>')
    # RSS line
    pts = ' '.join(f'{tx(p[0]):.1f},{ty(p[1]):.1f}' for p in mem_points_ts)
    svg.append(f'<polyline points="{pts}" fill="none" stroke="#4a90d9" stroke-width="2.5" stroke-linejoin="round"/>')
    # dots at sample points
    for p in mem_points_ts:
        svg.append(f'<circle cx="{tx(p[0]):.1f}" cy="{ty(p[1]):.1f}" r="2.5" '
                   f'fill="#4a90d9" opacity="0.7"><title>{p[1]//1024}MB @ t={p[0]-minx:.0f}s</title></circle>')
    # y-axis label
    mid_y = (pad_t + height - pad_b) // 2
    svg.append(f'<text x="12" y="{mid_y}" text-anchor="middle" font-family="monospace" '
               f'font-size="10" transform="rotate(-90,12,{mid_y})">RSS</text>')
    svg.append('</svg>')
    legend_items = [
        ('<rect width="12" height="12" fill="rgba(39,174,96,0.4)"/>', 'changed'),
        ('<rect width="12" height="12" fill="rgba(232,64,64,0.4)"/>', 'failed'),
        ('<rect width="12" height="12" fill="rgba(180,180,180,0.3)"/>', 'unchanged'),
    ]
    legend = ' &nbsp; '.join(
        f'<svg width="12" height="12" style="vertical-align:middle">{icon}</svg> {lbl}'
        for icon, lbl in legend_items
    )
    stats_row = (f'<div style="font-family:monospace;font-size:12px;color:#555;margin-top:6px">'
                 f'min: <b>{min_y//1024}MB</b> &nbsp; avg: <b>{int(avg_y)//1024}MB</b> &nbsp; '
                 f'peak: <b style="color:#e84040">{peak_y//1024}MB</b> &nbsp; '
                 f'samples: <b>{len(mem_points_ts)}</b> &nbsp; interval: 1s &nbsp;|&nbsp; '
                 f'bands = resource eval windows (top 40 by duration) &nbsp; {legend}</div>')
    return '\n'.join(svg) + stats_row

def make_bar_chart(step_list, wall_total, width=700):
    if not step_list:
        return '<div class="chart-empty">No timing steps captured.</div>'
    n = len(step_list)
    bar_h = 28
    pad_top = 30; pad_left = 160; pad_right = 80; pad_bottom = 20
    height = pad_top + n * (bar_h + 4) + pad_bottom
    max_dur = max((s['duration'] or 0) for s in step_list) or 1
    pw = width - pad_left - pad_right
    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" style="background:#fff;border:1px solid #e0e0e0;border-radius:4px">']
    svg.append(f'<text x="{width//2}" y="16" text-anchor="middle" font-family="monospace" font-size="12" font-weight="bold">Puppet Steps by Duration</text>')
    slowest_dur = max_dur
    for i, s in enumerate(step_list):
        y = pad_top + i * (bar_h + 4)
        dur = s['duration'] or 0
        bw = int(dur / max_dur * pw)
        color = "#e84040" if dur == slowest_dur else "#4a90d9"
        svg.append(f'<text x="{pad_left-6}" y="{y+18}" text-anchor="end" font-family="monospace" font-size="11">{html.escape(s["label"])}</text>')
        svg.append(f'<rect x="{pad_left}" y="{y+2}" width="{bw}" height="{bar_h-4}" fill="{color}" rx="2"/>')
        svg.append(f'<text x="{pad_left+bw+4}" y="{y+18}" font-family="monospace" font-size="10">{dur:.2f}s</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

import re as _re
import html as _html_mod
def _sanitize_svg(s):
    import re as _re
    # Remove <script> blocks including self-closing/unclosed variants
    s = _re.sub(r'<(?:\w+:)?script\b[^>]*>.*?</(?:\w+:)?script>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    s = _re.sub(r'<(?:\w+:)?script\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    # Remove animate/set elements that can animate href to javascript: URIs
    s = _re.sub(r'<(?:animate|set)\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    s = _re.sub(r'<(?:animate|set)\b.*?</(?:animate|set)>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    # Remove foreignObject — can embed arbitrary HTML+<script> when SVG inlined in HTML
    s = _re.sub(r'<foreignObject\b.*?</foreignObject>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    s = _re.sub(r'<foreignObject\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    # Remove <use> elements — can reference external SVG fragments via href
    s = _re.sub(r'<use\b.*?</use>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    s = _re.sub(r'<use\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    # Allowlist href attributes: only allow #anchors and http(s):// URLs
    # Catches javascript:, vbscript:, data:, entity-encoded schemes, tab-split, etc.
    def _clean_href(m):
        prefix, val = m.group(1), m.group(2).strip('"\'').strip()
        # Decode common HTML entities before checking scheme
        val_decoded = val.replace('&#115;','s').replace('&#106;','j').replace('&#97;','a')
        val_decoded = val_decoded.replace('\t','').replace('\n','').replace('\r','')
        if _re.match(r'^https?://', val_decoded, _re.IGNORECASE) or val_decoded.startswith('#'):
            return m.group(0)
        return prefix + '"#"'
    s = _re.sub(r'((?:xlink:)?href\s*=\s*)("[^"]*"|\'[^\']*\'|[^\s>]+)', _clean_href, s, flags=_re.IGNORECASE)
    # Also neutralize src= — only allow https:// URLs
    s = _re.sub(r'(src\s*=\s*)("[^"]*"|\'[^\']*\'|[^\s>]+)',
                lambda m: m.group(0) if _re.match(r'["\']?https?://', m.group(2), _re.IGNORECASE) else m.group(1) + '"#"',
                s, flags=_re.IGNORECASE)
    # Remove on* event handlers (quoted, single-quoted, and unquoted values)
    s = _re.sub(r'\bon\w+\s*=\s*(?:"[^"]*"|\'[^\']*\'|\S+)', '', s, flags=_re.IGNORECASE)
    # Strip url(non-anchor) from style= attributes to block style="fill:url(javascript:...)"
    def _clean_style_url(m):
        return _re.sub(r'url\s*\(([^)]*)\)',
                       lambda u: u.group(0) if u.group(1).strip().startswith('#') else 'url(#)',
                       m.group(0), flags=_re.IGNORECASE)
    s = _re.sub(r'style\s*=\s*"[^"]*"', _clean_style_url, s, flags=_re.IGNORECASE)
    s = _re.sub(r"style\s*=\s*'[^']*'", _clean_style_url, s, flags=_re.IGNORECASE)
    # Also catch unquoted style= values: style=fill:url(javascript:...)
    s = _re.sub(r'style\s*=\s*([^\s>"\']\S*)', _clean_style_url, s, flags=_re.IGNORECASE)
    # Sanitize url() in <style> blocks — same allowlist as inline style= attributes
    def _clean_style_block(m):
        return _re.sub(r'url\s*\(([^)]*)\)',
                       lambda u: u.group(0) if u.group(1).strip().startswith('#') else 'url(#)',
                       m.group(0), flags=_re.IGNORECASE)
    s = _re.sub(r'<style\b[^>]*>.*?</style>', _clean_style_block, s, flags=_re.DOTALL|_re.IGNORECASE)
    return s

