# ── derive summary numbers ────────────────────────────────────────────────────
total_disk_written = sum(r.get('disk_bytes_written', 0) for r in io_resources)
top_writer = max(io_resources, key=lambda r: r.get('disk_bytes_written', 0)) if io_resources else None

res_changed = sum(1 for r in rr_resources if r.get('changed'))
