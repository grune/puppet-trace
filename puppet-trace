    WALL_SECONDS=$(( RUN_END_TS - RUN_START_TS ))

    pmap -x "$PUPPET_PID" >"$PMAP_END" 2>/dev/null || echo "(pmap unavailable)" >"$PMAP_END"

    [[ -n "${PROC_POLLER_PID:-}" ]] && kill "$PROC_POLLER_PID" 2>/dev/null || true
    [[ -n "${NET_POLLER_PID:-}" ]]  && kill "$NET_POLLER_PID"  2>/dev/null || true
    [[ -n "${IO_POLLER_PID:-}" ]]   && kill "$IO_POLLER_PID"   2>/dev/null || true
    [[ -n "${STRACE_PID:-}" ]]       && kill "$STRACE_PID"       2>/dev/null || true
    [[ -n "${PERF_PID:-}" ]]         && kill "$PERF_PID"         2>/dev/null || true
    wait 2>/dev/null || true

    # Snapshot /proc/meminfo + df after run
    {
        echo "=== /proc/meminfo ==="
        cat /proc/meminfo 2>/dev/null || true
        echo "=== df -h ==="
        df -h 2>/dev/null || true
        echo "=== ss -tnp ==="
        ss -tnp 2>/dev/null || true
    } >"$OUTDIR/sysctx-after.txt" 2>/dev/null || true

    echo "[puppet-trace] puppet exited with code $PUPPET_EXIT after ${WALL_SECONDS}s"
    _restart_puppet_service
}

