def _sanitize_svg(s):
    import re as _re
    # Remove <script> blocks including self-closing/unclosed variants
    s = _re.sub(r'<script\b[^>]*>.*?</script>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    s = _re.sub(r'<script\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    # Remove animate/set elements that can animate href to javascript: URIs
    s = _re.sub(r'<(?:animate|set)\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    s = _re.sub(r'<(?:animate|set)\b.*?</(?:animate|set)>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    # Neutralize javascript: URIs in href attributes (quoted and unquoted)
    s = _re.sub(r'((?:xlink:)?href\s*=\s*["\']?)javascript:', r'\1#', s, flags=_re.IGNORECASE)
    # Neutralize data: URIs in href/src (quoted and unquoted)
    s = _re.sub(r'((?:xlink:)?href\s*=\s*["\']?)data:', r'\1#', s, flags=_re.IGNORECASE)
    s = _re.sub(r'(src\s*=\s*["\']?)data:', r'\1#', s, flags=_re.IGNORECASE)
    # Remove on* event handlers (quoted, single-quoted, and unquoted values)
    s = _re.sub(r'\bon\w+\s*=\s*(?:"[^"]*"|\'[^\']*\'|\S+)', '', s, flags=_re.IGNORECASE)
    return s

