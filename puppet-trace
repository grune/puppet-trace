PMAP_HEADER = "         Address       Kbytes     RSS   Dirty Mode  Mapping"

def pmap_lines(base_rss_kb, extra_libs=None):
    lines = [PMAP_HEADER]
    # fixed mappings
    entries = [
        ("00400000",  4096,   int(base_rss_kb * 0.15), 0,    "r-xp", "/usr/bin/ruby3.2"),
        ("00600000",   512,   int(base_rss_kb * 0.01), 512,  "rw-p", "/usr/bin/ruby3.2"),
        ("7f0000000", 8192,   int(base_rss_kb * 0.05), 2048, "r-xp", "/lib/x86_64-linux-gnu/libc.so.6"),
        ("7f0001000",  512,   int(base_rss_kb * 0.01), 256,  "rw-p", "/lib/x86_64-linux-gnu/libc.so.6"),
        ("7f0002000", 4096,   int(base_rss_kb * 0.04), 1024, "r-xp", "/lib/x86_64-linux-gnu/libssl.so.3"),
        ("7f0003000", 2048,   int(base_rss_kb * 0.03), 512,  "r-xp", "/lib/x86_64-linux-gnu/libpuppet.so"),
        ("7f1000000", 40960, int(base_rss_kb * 0.45), 38000,"rw-p", "[heap]"),
        ("7ffe00000", 8192,  int(base_rss_kb * 0.08), 4096, "rw-p", "[stack]"),
        ("7fff00000",    4,     4,                    0,    "r--p", "[vvar]"),
        ("7fff10000",    8,     8,                    0,    "r-xp", "[vdso]"),
    ]
    if extra_libs:
