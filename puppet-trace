###############################################################################
# IDEMPOTENCY CHECK (once mode — second run with --noop)
###############################################################################
IDEMPOTENCY_PASS=unknown
IDEMPOTENCY_CHANGES=0

run_idempotency_check() {
    local puppet_run_user="${PUPPET_TRACE_PUPPET_USER:-puppet}"
    # Validate puppet user — must not be root or contain special chars
    if [[ "$puppet_run_user" == "root" ]] || ! _validate_puppet_id "$puppet_run_user" "PUPPET_TRACE_PUPPET_USER" 2>/dev/null; then
        echo "[puppet-trace] WARNING: PUPPET_TRACE_PUPPET_USER='$puppet_run_user' is invalid or root — using 'puppet'" >&2
        puppet_run_user="puppet"
    fi
    local run_as_user=()
    if id "$puppet_run_user" &>/dev/null && [[ $EUID -eq 0 ]]; then
        run_as_user=(sudo -u "$puppet_run_user" --)
    fi
    if [[ ${#run_as_user[@]} -gt 0 ]]; then
        if ! "${run_as_user[@]}" true 2>/dev/null; then
            echo "[puppet-trace] WARNING: sudo -u $puppet_run_user failed — falling back to root. Install puppet-trace.sudoers to run puppet as $puppet_run_user." >&2
            run_as_user=()
        fi
    fi

    echo "[puppet-trace] idempotency check (--noop run)..."
    local idem_exit=0
    "${run_as_user[@]}" /opt/puppetlabs/bin/puppet agent --test --noop \
        >"$IDEMPOTENCY_STDOUT" 2>&1 || idem_exit=$?
    IDEMPOTENCY_CHANGES=$(grep -cE \
        'would have triggered|would have changed|Notice.*changed' \
        "$IDEMPOTENCY_STDOUT" 2>/dev/null; true)
    IDEMPOTENCY_CHANGES=${IDEMPOTENCY_CHANGES:-0}
    if [[ "$IDEMPOTENCY_CHANGES" -eq 0 ]]; then
        IDEMPOTENCY_PASS=true
    else
        IDEMPOTENCY_PASS=false
    fi
    echo "[puppet-trace] idempotency: pass=$IDEMPOTENCY_PASS changes=$IDEMPOTENCY_CHANGES"
}

###############################################################################
# LAST_RUN_REPORT PARSER (python3, post-run)
###############################################################################
parse_last_run_report() {
    echo "[puppet-trace] parsing last_run_report.yaml..."
    # Python's yaml.safe_load chokes on !ruby/object tags in last_run_report.yaml.
    # Use puppet's bundled ruby + tag-stripping so Psych treats puppet objects as plain Hashes.
    local ruby_script
    ruby_script=$(mktemp "${OUTDIR}/puppet-trace-tmp.XXXXX.rb")
    cat > "$ruby_script" << 'RUBYEOF'
require 'yaml'; require 'json'
report_yaml = ARGV[0]
out_json    = ARGV[1]

unless File.exist?(report_yaml)
  File.write(out_json, JSON.generate({resources: [], totals: {}, status: 'unknown'}))
  exit 0
end

# Strip Ruby-specific YAML tags so Psych parses unknown objects as plain Hashes.
# !ruby/object:Puppet::... -> !!map  (treat as hash)
# !ruby/sym name           -> :name  (treat as symbol key)
yaml_str   = File.read(report_yaml)
yaml_clean = yaml_str.gsub(/!ruby\/object:[^\s]+/, '!!map').gsub(/!ruby\/sym /, ':')
report = YAML.safe_load(yaml_clean, permitted_classes: [Symbol, Time]) || {}

resources = []
resource_statuses = report['resource_statuses'] || {}
resource_statuses.each do |title, rs|
  next unless rs.is_a?(Hash)
  events = (rs['events'] || []).map do |e|
    next unless e.is_a?(Hash)
    {status: e['status'], message: e['message'].to_s, previous_value: e['previous_value'].to_s, desired_value: e['desired_value'].to_s}
  end.compact
  before_val = events.first&.dig(:previous_value)
  after_val  = events.first&.dig(:desired_value)
  failed  = !!rs['failed']
  skipped = !!rs['skipped']
  changed = !!(rs['changed'] || rs['out_of_sync'])
  status  = failed ? 'failed' : (skipped ? 'skipped' : (changed ? 'changed' : 'unchanged'))
  resources << {
    title: title, type: (rs['resource_type'] || title.split('[').first),
    status: status, evaluation_time: rs['evaluation_time'].to_f,
    changed: changed, failed: failed, skipped: skipped, out_of_sync: !!rs['out_of_sync'],
    before: before_val, after: after_val,
    file: rs['file'].to_s, line: rs['line'].to_s,
  }
end

totals = {}
(report['metrics'] || {}).each do |cat, cat_data|
  next unless cat_data.is_a?(Hash)
  (cat_data['values'] || []).each do |entry|
    totals["#{cat}.#{entry[0]}"] = entry[2] if entry.is_a?(Array) && entry.length >= 3
  end
end

result = {
  resources: resources, totals: totals,
  certname:         report['host'].to_s,
  config_version:   report['configuration_version'].to_s,
  puppet_version:   report['puppet_version'].to_s,
  transaction_uuid: report['transaction_uuid'].to_s,
  status:           report['status'].to_s,
  noop:             !!report['noop'],
  summary:          {},
}

File.write(out_json, JSON.generate(result))
STDERR.puts "[puppet-trace] resource-report.json: #{resources.length} resources"
RUBYEOF
    /opt/puppetlabs/puppet/bin/ruby "$ruby_script" "$LAST_RUN_REPORT" "$OUTDIR/resource-report.json" 2>&1
    rm -f "$ruby_script"
}

###############################################################################
# PUPPETDB ENRICHMENT (ssh to puppet server, via docker exec)
# Puppet 8 omits resource_statuses from last_run_report.yaml; fetch from PDB.
###############################################################################
enrich_from_puppetdb() {
    # Skip PuppetDB when running puppet apply (no server, no PDB submission)
    if [[ "${PUPPET_CMD[*]}" =~ puppet[[:space:]]apply ]]; then
        echo "[puppet-trace] puppet apply detected — skipping PuppetDB enrichment"
        return
    fi

    local rr_json="$OUTDIR/resource-report.json"
    local res_count
    res_count=$(python3 -c "import json; d=json.load(open('$rr_json')); print(len(d.get('resources',[])))" 2>/dev/null || echo 0)
    if [[ "$res_count" -gt 0 ]]; then
        echo "[puppet-trace] resource-report has $res_count resources — skipping PuppetDB enrichment"
        return
    fi

    local transaction_uuid certname puppet_server ssh_user ssh_key _ssh_opts
    transaction_uuid=$(python3 -c "import json; print(json.load(open('$rr_json')).get('transaction_uuid',''))" 2>/dev/null || echo "")
    certname=$(python3 -c "import json; print(json.load(open('$rr_json')).get('certname',''))" 2>/dev/null || echo "")
    # Fallback: read host: from last_run_report.yaml directly (more reliable than hostname -f)
    if [[ -z "$certname" ]]; then
        certname=$(grep -m1 '^host:' "$LAST_RUN_REPORT" 2>/dev/null | awk '{print $2}' | tr -d "'" || true)
    fi
    [[ -z "$certname" ]] && certname=$(puppet config print certname 2>/dev/null | tr -d '\n' || hostname -f 2>/dev/null || hostname)
    puppet_server="${PUPPET_SERVER:-$(puppet config print server 2>/dev/null | tr -d '\n' || true)}"
    [[ -z "$puppet_server" ]] && puppet_server="$(hostname -f 2>/dev/null || hostname)"
    if [[ -n "$puppet_server" ]]; then
        _validate_puppet_id "$puppet_server" "puppet_server" || puppet_server=""
    fi
    [[ -z "$puppet_server" ]] && { echo "[puppet-trace] ERROR: could not determine puppet server for PuppetDB enrichment" >&2; return 1; }
    ssh_user="${PUPPET_TRACE_SSH_USER:-puppet}"
    ssh_key="${PUPPET_TRACE_SSH_KEY:-${HOME}/.ssh/id_ed25519}"
    local _pdb_container="${PUPPET_TRACE_PDB_CONTAINER:-puppetdb}"
    _validate_puppet_id "${_pdb_container}" "PUPPET_TRACE_PDB_CONTAINER" || return
    _validate_puppet_id "${ssh_user}" "PUPPET_TRACE_SSH_USER" || return
    # Validate puppet identifiers before use in SSH commands
    _validate_puppet_id "$certname" "certname" || return
    [[ -n "$transaction_uuid" ]] && _validate_puppet_id "$transaction_uuid" "transaction_uuid" || transaction_uuid=""
    local certname_enc transaction_uuid_enc
    certname_enc=$(python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$certname")
    [[ -n "$transaction_uuid" ]] && transaction_uuid_enc=$(python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$transaction_uuid") || transaction_uuid_enc=""
    mkdir -m 0700 -p /var/log/puppet-trace/
    _ssh_opts=(-o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/var/log/puppet-trace/.ssh_known_hosts)
    [[ -f "$ssh_key" ]] && _ssh_opts+=(-i "$ssh_key")

    echo "[puppet-trace] querying PuppetDB on $puppet_server for $certname..."

    local pdb_json
    pdb_json=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
        "docker exec ${_pdb_container} curl -sf \
         'http://localhost:8080/pdb/query/v4/resources?query=%5B%22%3D%22%2C%22certname%22%2C%22${certname_enc}%22%5D'" \
        2>/dev/null) || { echo "[puppet-trace] PuppetDB SSH query failed — using local data only" >&2; return; }

    local event_json=""
    if [[ -n "$transaction_uuid" ]]; then
        local report_hash
        report_hash=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
            "docker exec ${_pdb_container} curl -sf \
             'http://localhost:8080/pdb/query/v4/reports?query=%5B%22%3D%22%2C%22transaction_uuid%22%2C%22${transaction_uuid_enc}%22%5D'" \
            2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d[0]['hash'] if d else '')" 2>/dev/null || echo "")
        if [[ -n "$report_hash" ]]; then
            _validate_puppet_id "$report_hash" "report_hash" || report_hash=""
        fi
        if [[ -n "$report_hash" ]]; then
            event_json=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
                "docker exec ${_pdb_container} curl -sf \
                 'http://localhost:8080/pdb/query/v4/events?query=%5B%22%3D%22%2C%22report%22%2C%22${report_hash}%22%5D'" \
                2>/dev/null) || event_json="[]"
        fi
    fi

    python3 - "$rr_json" "$pdb_json" "${event_json:-[]}" <<'PYEOF_PDB'
import json, sys

rr_path    = sys.argv[1]
pdb_res    = json.loads(sys.argv[2]) if len(sys.argv) > 2 else []
pdb_events = json.loads(sys.argv[3]) if len(sys.argv) > 3 else []

rr = json.load(open(rr_path))

# Build event lookup by resource title
events_by_title = {}
for ev in (pdb_events if isinstance(pdb_events, list) else []):
    t = f"{ev.get('resource_type','')}/{ev.get('resource_title','')}"
    events_by_title.setdefault(t, []).append(ev)

def res_key(rtype, rtitle): return f"{rtype}/{rtitle}"

resources = []
for r in (pdb_res if isinstance(pdb_res, list) else []):
    rtype  = r.get('type', '')
    rtitle = r.get('title', '')
    key    = res_key(rtype, rtitle)
    evs    = events_by_title.get(key, [])
    status = 'unchanged'
    before = after = None
    if evs:
        statuses = [e.get('status','') for e in evs]
        if any(s == 'failure' for s in statuses): status = 'failed'
        elif any(s == 'success' for s in statuses): status = 'changed'
        elif any(s == 'noop' for s in statuses): status = 'noop'
        before = evs[0].get('old_value')
        after  = evs[0].get('new_value')
    resources.append({
        'title':           f"{rtype}[{rtitle}]",
        'type':            rtype,
        'status':          status,
        'evaluation_time': 0,
        'changed':         status == 'changed',
        'failed':          status == 'failed',
        'skipped':         False,
        'before':          str(before) if before is not None else None,
        'after':           str(after)  if after  is not None else None,
        'file':            r.get('file') or '',
        'line':            str(r.get('line') or ''),
        'parameters':      r.get('parameters') or {},
    })

rr['resources'] = resources
with open(rr_path, 'w') as f:
    json.dump(rr, f, indent=2)
print(f"[puppet-trace] PuppetDB enrichment: {len(resources)} resources", file=sys.stderr)
PYEOF_PDB
}

###############################################################################
# STRACE I/O CORRELATION ENGINE (python3, post-run)
###############################################################################
run_strace_correlation() {
    if [[ ! -f "$STRACE_RAW" ]]; then
        echo "[puppet-trace] no strace.raw — skipping correlation"
        return
    fi
    local resource_report="$OUTDIR/resource-report.json"
    if [[ ! -f "$resource_report" ]]; then
        echo "[puppet-trace] no resource-report.json — skipping correlation"
        return
    fi

    echo "[puppet-trace] running strace I/O correlation engine..."
    python3 - "$STRACE_RAW" "$PUPPET_LOG" "$resource_report" "$IO_CORR_JSON" "$PROC_LOG" <<'PYEOF'
import sys, os, re, json, collections

strace_raw      = sys.argv[1]
puppet_log      = sys.argv[2]
resource_report = sys.argv[3]
out_json        = sys.argv[4]
proc_log        = sys.argv[5] if len(sys.argv) > 5 else ''

# ── 1. Parse strace.raw ────────────────────────────────────────────────────
# Format: PID  TIMESTAMP SYSCALL(ARGS) = RETVAL
# -ttt gives microsecond timestamps
strace_events = []
strace_re = re.compile(
    r'^(\d+)\s+([\d.]+)\s+(\w+)\((.*)$'
)
retval_re = re.compile(r'\)\s*=\s*(-?\d+)')

print(f"[corr] parsing strace: {strace_raw}")
try:
    with open(strace_raw, errors='replace') as f:
        for line in f:
            m = strace_re.match(line)
            if not m:
                continue
            pid       = int(m.group(1))
            ts        = float(m.group(2))
            syscall   = m.group(3)
            rest      = m.group(4)
            retval_m  = retval_re.search(rest)
            retval    = int(retval_m.group(1)) if retval_m else 0

            # extract path from first quoted string
            path_m = re.search(r'"([^"]+)"', rest)
            path   = path_m.group(1) if path_m else ''

            # extract execve args
            args = []
            if syscall == 'execve':
                args_m = re.search(r'\[([^\]]+)\]', rest)
                if args_m:
                    args = re.findall(r'"([^"]*)"', args_m.group(1))

            # extract connect target
            remote = ''
            if syscall == 'connect':
                addr_m = re.search(r'sin_addr=inet_addr\("([^"]+)"\).*sin_port=htons\((\d+)\)', rest)
                if addr_m:
                    remote = f'{addr_m.group(1)}:{addr_m.group(2)}'
                addr6_m = re.search(r'sin6_addr=inet_pton\(AF_INET6, "([^"]+)"\).*sin6_port=htons\((\d+)\)', rest)
                if addr6_m:
                    remote = f'[{addr6_m.group(1)}]:{addr6_m.group(2)}'

            strace_events.append({
                'ts': ts, 'pid': pid, 'syscall': syscall,
                'path': path, 'retval': retval,
                'args': args, 'remote': remote,
            })
except FileNotFoundError:
    print(f"[corr] strace.raw not found")
    strace_events = []

# ── 1b. Load proc-poll.log for RSS/memory correlation ───────────────────────
proc_poll = []  # list of (unix_ts_float, rss_kb)
if proc_log and os.path.isfile(proc_log):
    with open(proc_log) as f:
        for ln in f:
            parts = ln.split()
            if len(parts) >= 3:
                try:
                    proc_poll.append((float(parts[0]), int(parts[2])))
                except (ValueError, IndexError):
                    pass
print(f"[corr] proc-poll samples: {len(proc_poll)}")

def rss_for_window(t0, t1, proc_poll):
    samples = [(ts, rss) for ts, rss in proc_poll if t0 <= ts <= t1]
    if not samples and proc_poll:
        # resource faster than poll interval — find nearest sample
        mid = (t0 + t1) / 2
        nearest = min(proc_poll, key=lambda x: abs(x[0] - mid))
        samples = [nearest]
    if not samples:
        return {}
    rss_vals = [rss for _, rss in samples]
    return {
        'rss_start': samples[0][1],
        'rss_end':   samples[-1][1],
        'rss_peak':  max(rss_vals),
        'rss_min':   min(rss_vals),
        'rss_delta': samples[-1][1] - samples[0][1],
    }

print(f"[corr] parsed {len(strace_events)} strace events")
if not strace_events:
    with open(out_json, 'w') as f:
        json.dump([], f)
    sys.exit(0)

min_ts = min(e['ts'] for e in strace_events)
max_ts = max(e['ts'] for e in strace_events)
total_span = max_ts - min_ts or 1

# ── 2. Parse puppet.log for resource boundary lines ──────────────────────
# --evaltrace emits per-resource Info lines (preferred — covers ALL resources):
#   Info: /Stage[main]/M/File[/etc/foo]: Starting to evaluate the resource (N of T)
#   Info: /Stage[main]/M/File[/etc/foo]: Evaluated in 0.01 seconds
# Fallback: Notice: lines for changed resources only (no --evaltrace).
evaltrace_start_re = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Info:\s+(.*?):\s+Starting to evaluate the resource'
)
evaltrace_end_re = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Info:\s+(.*?):\s+Evaluated in ([\d.]+) seconds'
)
notice_re  = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Notice:\s+(/Stage\[.*?\]/[^:]+)(?::\s+(.*))?$'
)
applied_re = re.compile(r'Applied catalog in ([\d.]+) seconds')
config_re  = re.compile(r"Applying configuration version '(\d+)'")

config_version      = ''
apply_end_ts_offset = None

# evaltrace tracking: title → (start_idx, duration)
evaltrace_resources = []   # list of {title, canonical, duration, order}
_evaltrace_pending  = {}   # title → start_order (awaiting end line)
_evaltrace_order    = 0

# notice-only fallback
notice_resources = []

print(f"[corr] parsing puppet.log: {puppet_log}")
with open(puppet_log, errors='replace') as f:
    for lineno, line in enumerate(f, 1):
        line = line.rstrip()
        # strip ANSI for regex matching
        clean = re.sub(r'\x1b\[[0-9;]*m', '', line)

        m = evaltrace_start_re.match(clean)
        if m:
            raw_title = m.group(1).strip()
            canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])$', r'\1', raw_title)
            if canonical not in _evaltrace_pending:
                _evaltrace_pending[canonical] = _evaltrace_order
                _evaltrace_order += 1
            continue

        m = evaltrace_end_re.match(clean)
        if m:
            raw_title = m.group(1).strip()
            duration  = float(m.group(2))
            canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])$', r'\1', raw_title)
            order = _evaltrace_pending.pop(canonical, _evaltrace_order)
            evaltrace_resources.append({
                'title': canonical, 'raw': raw_title,
                'duration': duration, 'order': order,
            })
            continue

        m = notice_re.match(clean)
        if m:
            notice_resources.append({
                'lineno': lineno, 'resource': m.group(1), 'detail': m.group(2) or '',
            })

        m = applied_re.search(clean)
        if m:
            apply_end_ts_offset = float(m.group(1))
        m = config_re.search(clean)
        if m:
            config_version = m.group(1)

# Prefer evaltrace data; fall back to notice lines
use_evaltrace = len(evaltrace_resources) > 0
print(f"[corr] evaltrace resources: {len(evaltrace_resources)}, notice lines: {len(notice_resources)}")
print(f"[corr] using {'evaltrace' if use_evaltrace else 'notice fallback'} for time windows")

# ── 3. Load resource-report.json ─────────────────────────────────────────
with open(resource_report) as f:
    rr = json.load(f)

rr_by_title = {r['title']: r for r in rr.get('resources', [])}

# ── 4. Build resource time windows ───────────────────────────────────────
# evaltrace path: use reported per-resource durations, anchored to strace span.
# The evaltrace durations sum to the catalog application time. We anchor the
# first resource to min_ts (strace start) and accumulate durations forward.
# This gives accurate per-resource strace windows even for unchanged resources.
#
# Fallback (no evaltrace): assign windows proportionally by log line position.

windows = []

if use_evaltrace:
    evaltrace_resources.sort(key=lambda r: r['order'])
    # Find approximate start of catalog application in strace timeline.
    # Use min_ts + (total_span - sum_of_durations) as offset, clamped to min_ts.
    total_eval_time = sum(r['duration'] for r in evaltrace_resources)
    catalog_start_ts = max(min_ts, max_ts - total_eval_time - 0.5)
    t_cursor = catalog_start_ts
    for res in evaltrace_resources:
        t_start   = t_cursor
        t_end     = t_cursor + max(res['duration'], 0.0005)
        t_cursor  = t_end
        canonical = res['title']
        rr_entry  = rr_by_title.get(canonical, {})
        # merge notice detail if available
        notice_detail = next(
            (n['detail'] for n in notice_resources
             if canonical in n['resource']),
            ''
        )
        windows.append({
            'title':    canonical,
            'raw':      res['raw'],
            'detail':   notice_detail,
            't_start':  t_start,
            't_end':    t_end,
            'duration': res['duration'],
            'rr':       rr_entry,
        })
else:
    # Notice-only fallback (unchanged from original)
    total_lines = len(notice_resources) or 1
    def line_to_ts(lineno):
        frac = lineno / (notice_resources[-1]['lineno'] if notice_resources else 1)
        return min_ts + frac * total_span
    for i, rl in enumerate(notice_resources):
        t_start = min_ts if i == 0 else line_to_ts(notice_resources[i-1]['lineno'])
        t_end   = line_to_ts(rl['lineno'])
        title   = rl['resource']
        canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])(?:/.*)?$', r'\1', title)
        rr_entry  = rr_by_title.get(canonical, rr_by_title.get(title, {}))
        windows.append({
            'title': canonical, 'raw': title, 'detail': rl['detail'],
            't_start': t_start, 't_end': t_end,
            'duration': t_end - t_start, 'rr': rr_entry,
        })

# ── 5. Correlate strace events to resource windows ────────────────────────
# Track pid→exe via execve
pid_exe   = {}   # pid → exe path
pid_args  = {}   # pid → args list

# Pre-pass: collect execve
for ev in strace_events:
    if ev['syscall'] == 'execve' and ev['args']:
        pid_exe[ev['pid']]  = ev['args'][0] if ev['args'] else ev['path']
        pid_args[ev['pid']] = ev['args']

correlated = []
for w in windows:
    t0, t1 = w['t_start'], w['t_end']
    if t1 <= t0:
        t1 = t0 + 0.001  # minimum window

    # collect events in window
    evs_in = [e for e in strace_events if t0 <= e['ts'] < t1]

    # aggregate writes/reads per path
    files_written = collections.defaultdict(lambda: {'bytes': 0, 'ops': 0})
    files_read    = collections.defaultdict(lambda: {'bytes': 0, 'ops': 0})
    net_conns     = {}
    pids_seen     = set()
    bytes_written = 0
    bytes_read    = 0

    for ev in evs_in:
        pids_seen.add(ev['pid'])
        sc  = ev['syscall']
        rv  = ev['retval']
        pth = ev['path']

        if sc in ('write', 'sendto') and rv > 0 and pth:
            files_written[pth]['bytes'] += rv
            files_written[pth]['ops']   += 1
            bytes_written += rv
        elif sc in ('read', 'recvfrom') and rv > 0 and pth:
            files_read[pth]['bytes'] += rv
            files_read[pth]['ops']   += 1
            bytes_read += rv
        elif sc == 'connect' and ev['remote']:
            net_conns[ev['remote']] = {'remote': ev['remote'], 'direction': 'outbound'}

    # build process list
    processes = []
    for pid in pids_seen:
        exe  = pid_exe.get(pid, f'pid:{pid}')
        args = pid_args.get(pid, [])
        # sum bytes for this pid
        pw = sum(e['retval'] for e in evs_in
                 if e['pid'] == pid and e['syscall'] in ('write','sendto') and e['retval'] > 0)
        pr = sum(e['retval'] for e in evs_in
                 if e['pid'] == pid and e['syscall'] in ('read','recvfrom') and e['retval'] > 0)
        processes.append({'pid': pid, 'exe': exe, 'args': args,
                          'bytes_written': pw, 'bytes_read': pr})

    rr_entry = w['rr']
    rss = rss_for_window(t0, t1, proc_poll)
    correlated.append({
        'title':              w['title'],
        'type':               rr_entry.get('type', w['title'].split('[')[0] if '[' in w['title'] else ''),
        'duration_s':         round(w['duration'], 4),
        'status':             rr_entry.get('status', 'unknown'),
        'before':             rr_entry.get('before'),
        'after':              rr_entry.get('after'),
        'evaluation_time':    rr_entry.get('evaluation_time', 0),
        'parameters':         rr_entry.get('parameters') or {},
        'file':               rr_entry.get('file') or '',
        'line':               rr_entry.get('line') or '',
        'processes':          processes,
        'files_written':      [{'path': p, **v} for p, v in
                               sorted(files_written.items(), key=lambda x: -x[1]['bytes'])],
        'files_read':         [{'path': p, **v} for p, v in
                               sorted(files_read.items(), key=lambda x: -x[1]['bytes'])],
        'network_connections': list(net_conns.values()),
        'disk_bytes_written': bytes_written,
        'disk_bytes_read':    bytes_read,
        'strace_events':      len(evs_in),
        't_start':            t0,
        't_end':              t1,
        **rss,
    })

# sort by disk_bytes_written desc for summary
correlated.sort(key=lambda r: -r['disk_bytes_written'])

total_strace_events = len(strace_events)
print(f"[corr] correlated {len(correlated)} resources, {total_strace_events} strace events total")

with open(out_json, 'w') as f:
    json.dump(correlated, f, indent=2, default=str)
print(f"[corr] written: {out_json}")
PYEOF
    echo "[puppet-trace] strace correlation done: $IO_CORR_JSON"
}

###############################################################################
# FLAMEGRAPH (once mode — perf/stack-based)
###############################################################################
generate_flamegraph() {
    if $HAS_PERF && $IS_ROOT && [[ -f "$PERF_DATA" ]]; then
        echo "[puppet-trace] generating flamegraph from perf data..."
        if $HAS_STACKCOLLAPSE && $HAS_FLAMEGRAPH; then
            perf script -i "$PERF_DATA" 2>/dev/null \
                | stackcollapse-perf.pl 2>/dev/null \
                | flamegraph.pl 2>/dev/null \
                >"$FLAMEGRAPH_SVG" || true
            [[ -s "$FLAMEGRAPH_SVG" ]] && { echo "[puppet-trace] flamegraph generated: $FLAMEGRAPH_SVG"; return; }
        fi
    fi

    if [[ -s "$STACK_LOG" ]]; then
        echo "[puppet-trace] generating stack summary from /proc stack samples..."
        python3 - "$STACK_LOG" "$FLAMEGRAPH_SVG" <<'PYEOF'
import sys, re, collections

stack_log = sys.argv[1]
svg_out = sys.argv[2]

stacks = []
current = []
with open(stack_log) as f:
    for line in f:
        line = line.rstrip()
        if line == '---':
            if current:
                stacks.append(list(reversed(current)))
            current = []
        else:
            m = re.match(r'\[\d+\]\s+\[<[0-9a-f]+>\]\s+(\S+)', line)
            if m:
                current.append(m.group(1))
            elif line.strip():
                current.append(line.strip())
if current:
    stacks.append(list(reversed(current)))

counter = collections.Counter()
for s in stacks:
    counter[';'.join(s)] += 1

total = sum(counter.values()) or 1
rows = sorted(counter.items(), key=lambda x: -x[1])[:30]

lines = []
lines.append('<svg xmlns="http://www.w3.org/2000/svg" width="900" height="{}" viewBox="0 0 900 {}">'.format(
    30 + len(rows) * 22, 30 + len(rows) * 22))
lines.append('<rect width="900" height="{}" fill="#f8f8f8"/>'.format(30 + len(rows) * 22))
lines.append('<text x="10" y="18" font-family="monospace" font-size="13" font-weight="bold">Kernel Stack Samples (top {} unique stacks, {} total samples)</text>'.format(len(rows), total))

for i, (stack, count) in enumerate(rows):
    y = 32 + i * 22
    pct = count / total * 100
    bar_w = int(pct / 100 * 600)
    color = "#4a90d9" if i % 2 == 0 else "#357abd"
    frame = stack.split(';')[-1] if stack else '(unknown)'
    lines.append('<rect x="10" y="{}" width="{}" height="18" fill="{}"/>'.format(y, bar_w, color))
    lines.append('<text x="{}" y="{}" font-family="monospace" font-size="11" fill="#222">{:.1f}% ({}) {}</text>'.format(
        bar_w + 16, y + 13, pct, count, frame[:60]))

lines.append('</svg>')

with open(svg_out, 'w') as f:
    f.write('\n'.join(lines))
print("stack summary SVG written:", svg_out)
PYEOF
    fi
}

###############################################################################
# PROFILE FLAMEGRAPH (once mode)
###############################################################################
collect_profile_flamegraph() {
    # puppet apply compiles locally — no puppetserver PROFILE log
    if [[ "${PUPPET_CMD[*]}" =~ puppet[[:space:]]apply ]]; then
        echo "[puppet-trace] puppet apply — skipping puppetserver profile log (compiled locally)"
        return 0
    fi

    local start_iso="${RUN_START_ISO:-}"
    local puppet_server ssh_key _ssh_opts
    puppet_server=$(puppet config print server 2>/dev/null | tr -d '\n' || true)
    [[ -z "$puppet_server" ]] && puppet_server="$(hostname -f 2>/dev/null || hostname)"
    _validate_puppet_id "$puppet_server" "puppet_server" || puppet_server=""
    [[ -z "$puppet_server" ]] && { echo "[puppet-trace] ERROR: could not determine puppet server for profile flamegraph" >&2; return 1; }
    local _ssh_user2="${PUPPET_TRACE_SSH_USER:-puppet}"
    ssh_key="${PUPPET_TRACE_SSH_KEY:-${HOME}/.ssh/id_ed25519}"
    local _server_container2="${PUPPET_TRACE_SERVER_CONTAINER:-puppetserver}"
    _validate_puppet_id "${_server_container2}" "PUPPET_TRACE_SERVER_CONTAINER" || return
    _validate_puppet_id "${_ssh_user2}" "PUPPET_TRACE_SSH_USER" || return
    mkdir -m 0700 -p /var/log/puppet-trace/
    _ssh_opts=(-o ConnectTimeout=10 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/var/log/puppet-trace/.ssh_known_hosts)
    [[ -f "$ssh_key" ]] && _ssh_opts+=(-i "$ssh_key")

    if [[ -n "$start_iso" ]] && [[ ! "$start_iso" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z?$ ]]; then
        echo "[puppet-trace] WARNING: start_iso has unexpected format, ignoring: $start_iso" >&2
        start_iso=""
    fi

    echo "[puppet-trace] fetching PROFILE entries from puppetserver (${puppet_server}) docker logs since ${start_iso}..."

    if [[ -n "$start_iso" ]]; then
        ssh "${_ssh_opts[@]}" "${_ssh_user2}@${puppet_server}" \
            "docker logs ${_server_container2} --since '${start_iso}' 2>&1 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    else
        ssh "${_ssh_opts[@]}" "${_ssh_user2}@${puppet_server}" \
            "docker logs ${_server_container2} 2>&1 | tail -5000 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    fi

    _generate_profile_flamegraph "$PROFILE_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$SCRIPT_DIR" || true
}

