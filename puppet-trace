# Feature 8: HTTP phase waterfall chart
def make_http_phase_waterfall(http_phases, width=900, height=180):
    """Horizontal bar waterfall of HTTP phases in the puppet run."""
    if not http_phases:
        return '<div class="chart-empty">No HTTP phases detected in strace (requires strace + root + puppet agent mode).</div>'
    PHASE_COLORS = {
        'node_classify':   '#4a90d9',
        'facts_upload':    '#27ae60',
        'catalog_request': '#e87b2a',
        'file_resource':   '#9b59b6',
        'report_submit':   '#e84040',
        'other_http':      '#888',
    }
    # Build timeline: group by phase, show each occurrence
    if not http_phases:
        return '<div class="chart-empty">No HTTP phases.</div>'
    ts_min = min(p['ts'] for p in http_phases)
    ts_max = max(p['ts'] for p in http_phases) + 0.5
    if ts_max <= ts_min:
        ts_max = ts_min + 1

    pad_l, pad_r, pad_t, pad_b = 140, 20, 36, 40
    pw = width - pad_l - pad_r
    row_h = 22

    # group phases by name
    import collections as _col
    by_phase = _col.defaultdict(list)
    for p in http_phases:
        by_phase[p['phase']].append(p)

    phase_order = ['node_classify','facts_upload','catalog_request','file_resource','report_submit','other_http']
    rows = [(ph, by_phase[ph]) for ph in phase_order if ph in by_phase]
    n_rows = len(rows)
    svg_h = pad_t + n_rows * row_h + pad_b

    def tx(t):
        return pad_l + (t - ts_min) / (ts_max - ts_min) * pw

    svg = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{svg_h}" '
           f'style="background:#fff;border:1px solid #e0e0e0;border-radius:4px;display:block">']
    svg.append(f'<text x="{(pad_l+width-pad_r)//2}" y="20" text-anchor="middle" '
               f'font-family="monospace" font-size="12" font-weight="bold">HTTP Phase Waterfall</text>')
    svg.append(f'<line x1="{pad_l}" y1="{pad_t}" x2="{pad_l}" y2="{svg_h-pad_b}" stroke="#bbb" stroke-width="1"/>')
    svg.append(f'<line x1="{pad_l}" y1="{svg_h-pad_b}" x2="{width-pad_r}" y2="{svg_h-pad_b}" stroke="#bbb" stroke-width="1"/>')

    for i, (phase, events) in enumerate(rows):
        y = pad_t + i * row_h
        col = PHASE_COLORS.get(phase, '#888')
        svg.append(f'<text x="{pad_l-4}" y="{y+row_h-6}" text-anchor="end" '
                   f'font-family="monospace" font-size="10" fill="#333">{html.escape(phase.replace("_"," "))}</text>')
        for ev in events:
            x = tx(ev['ts'])
            svg.append(f'<rect x="{x:.1f}" y="{y+3}" width="6" height="{row_h-8}" '
                       f'fill="{col}" rx="2" opacity="0.85">'
                       f'<title>{html.escape(phase)}: {ev["verb"]} {html.escape(ev["path"])} @ t={ev["ts"]:.2f}s</title></rect>')

    # x-axis ticks
    elapsed_total = ts_max - ts_min
    for frac in [0, 0.25, 0.5, 0.75, 1.0]:
        xv = ts_min + frac * elapsed_total
        xx = tx(xv)
        svg.append(f'<line x1="{xx:.1f}" y1="{svg_h-pad_b}" x2="{xx:.1f}" y2="{svg_h-pad_b+4}" stroke="#888"/>')
        svg.append(f'<text x="{xx:.1f}" y="{svg_h-pad_b+14}" text-anchor="middle" font-family="monospace" font-size="10">{frac*elapsed_total:.0f}s</text>')
    svg.append('</svg>')
    return '\n'.join(svg)

