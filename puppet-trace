def rss_at(t):
    base = 88576
    if 4  <= t <= 6:  base += int(8000 * (t-4)/2)
    elif t > 6:        base += 8000
    if 9  <= t <= 11: base += int(6000 * (t-9)/2)
    elif t > 11:       base += 6000
    if 12 <= t <= 17: base += int(20000 * (t-12)/5)
    elif t > 17:       base += 20000
    if t > 25:         base -= int(5000 * (t-25)/10)
    return max(base, 85000)

IO_RESOURCES = [
