    var det = document.getElementById(r.onclick.toString().match(/'([^']+)'/)[1]+'-detail');
    if (det) tbody.appendChild(det);
  }});
}}
</script>
</head>
<body>
<header>
  <h1>puppet-trace report
    <span class="status-{puppet_exit_class}">
      {'&#10003; exit 0' if puppet_exit == 0 else f'&#10007; exit {puppet_exit}'}
    </span>
  </h1>
  <div class="meta">
    Host: {html.escape(hostname)} &nbsp;|&nbsp;
    Date: {now} &nbsp;|&nbsp;
    Puppet: {html.escape(rr_pversion or puppet_version)} &nbsp;|&nbsp;
    UUID: {html.escape(rr_trans_uuid) if rr_trans_uuid else 'n/a'} &nbsp;|&nbsp;
    Command: <code>{html.escape(puppet_cmd)}</code> &nbsp;|&nbsp;
    Wall time: {wall_seconds}s
  </div>
</header>

<main>

<section id="summary">
  <h2>Summary</h2>
  <div class="summary-grid">
    <div class="stat-card"><div class="value">{wall_seconds}s</div><div class="label">Wall time</div></div>
    <div class="stat-card"><div class="value">{peak_rss//1024}MB</div><div class="label">Peak RSS</div></div>
    <div class="stat-card"><div class="value">{avg_rss//1024}MB</div><div class="label">Avg RSS</div></div>
    <div class="stat-card"><div class="value">{min_rss//1024}MB</div><div class="label">Min RSS</div></div>
    <div class="stat-card"><div class="value">{avg_cpu}%</div><div class="label">Avg CPU</div></div>
    <div class="stat-card"><div class="value">{res_changed}</div><div class="label">Resources changed</div></div>
    <div class="stat-card"><div class="value">{res_failed}</div><div class="label">Resources failed</div></div>
    <div class="stat-card"><div class="value">{res_skipped}</div><div class="label">Resources skipped</div></div>
    <div class="stat-card"><div class="value">{res_total}</div><div class="label">Resources total</div></div>
    <div class="stat-card"><div class="value">{fmt_bytes(total_disk_written)}</div><div class="label">Total disk written</div></div>
    <div class="stat-card"><div class="value">{strace_total_events:,}</div><div class="label">strace events</div></div>
    <div class="stat-card"><div class="value" style="color:{idem_color}">{idem_label}</div><div class="label">Idempotency</div></div>
    <div class="stat-card"><div class="value">{len(unique_conns)}</div><div class="label">Net connections</div></div>
    <div class="stat-card"><div class="value">{len(step_list)}</div><div class="label">Steps traced</div></div>
  </div>
</section>

<section id="timing">
  <h2>Step Timing</h2>
  {timing_chart}
</section>

<section id="memory">
  <h2>Memory (RSS)</h2>
  {mem_chart}
</section>

<section id="cpu">
  <h2>CPU%</h2>
  {cpu_chart}
</section>

{flamegraph_section}

{profile_flamegraph_section}

<section id="latency">
  <h2>Step Latency</h2>
  <table>
    <tr><th>Step</th><th>Duration</th><th>Delta from prev</th></tr>
    {latency_rows if latency_rows else '<tr><td colspan="3">(no steps captured)</td></tr>'}
  </table>
</section>

<section id="files">
  <h2>File Access (top 20 by count)</h2>
  <table>
    <tr><th>Path</th><th>Count</th><th>Operations</th></tr>
    {file_rows if file_rows else '<tr><td colspan="3">(no file data — strace/inotifywait not available or not root)</td></tr>'}
  </table>
</section>

<section id="network">
  <h2>Network Connections</h2>
  <table>
    <tr><th>State</th><th>Local</th><th>Remote</th></tr>
    {net_rows}
  </table>
</section>

<section id="resources">
  <h2>Per-Resource I/O Attribution</h2>
  {'<p style="color:#888;font-size:0.85em">strace correlation active — click row to expand file/process/network detail. Sorted by disk written.</p>' if io_resources else '<p style="color:#888;font-style:italic">strace correlation not available (requires root + strace). Showing resources from last_run_report.yaml without I/O attribution.</p>'}
  <table id="res-table" data-sort-dir="desc">
    <thead>
      <tr>
        <th onclick="sortTable(0)">Resource</th>
        <th onclick="sortTable(1)">Type</th>
        <th onclick="sortTable(2)">Status</th>
        <th onclick="sortTable(3)">Duration</th>
        <th onclick="sortTable(4)">Disk Written</th>
        <th onclick="sortTable(5)">Disk Read</th>
        <th onclick="sortTable(6)" title="RSS delta during resource eval">Mem Δ</th>
        <th onclick="sortTable(7)" title="Peak RSS during resource eval">Mem Peak</th>
        <th onclick="sortTable(8)">Processes</th>
        <th onclick="sortTable(9)">Top File Written</th>
      </tr>
    </thead>
    <tbody>
      {resource_table_rows if resource_table_rows else '<tr><td colspan="10" style="color:#888;font-style:italic">No resource data available</td></tr>'}
    </tbody>
  </table>
</section>

<section id="idempotency">
  <h2>Idempotency</h2>
  <p><span class="idem-{'pass' if idempotency_pass == 'true' else ('fail' if idempotency_pass == 'false' else 'unk')}">{idem_label}</span>
  {'&nbsp; — ' + str(idempotency_changes) + ' change(s) detected in --noop run' if idempotency_pass == 'false' else ''}</p>
  <details>
    <summary>Expand --noop run output</summary>
    <pre>{idem_log_html}</pre>
  </details>
</section>

<section id="sysctx">
  <h2>System Context</h2>
  <details>
    <summary>Pre-run: /proc/meminfo + df</summary>
    <pre>{html.escape(sysctx_before_text) if sysctx_before_text else '(not captured)'}</pre>
  </details>
  <details>
    <summary>Post-run: /proc/meminfo + df + ss</summary>
    <pre>{html.escape(sysctx_after_text) if sysctx_after_text else '(not captured)'}</pre>
  </details>
</section>

<section id="logs">
  <h2>Raw Logs</h2>
  <details open>
    <summary>Puppet stdout/stderr</summary>
    <pre>{puppet_log_html}</pre>
  </details>
  {'<details><summary>Top 20 files by strace ops</summary><pre>' + html.escape(chr(10).join(f"{c:6d}  {p}" for p,c in file_counter.most_common(20))) + '</pre></details>' if file_counter else ''}
</section>

</main>
</body>
</html>
'''

with open(report_html, 'w') as f:
