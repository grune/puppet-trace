        f'<text x="{width//2}" y="24" text-anchor="middle" font-size="17">{html.escape(title)}</text>',
    ]
    y_base = svg_h - fh - 2
    for label, x_pct, w_pct, level, color in frames:
        x = int(width * x_pct / 100)
        w = max(1, int(width * w_pct / 100) - 1)
        y = y_base - level * fh
        parts.append(
            f'<g><title>{html.escape(label)}</title>'
            f'<rect x="{x}" y="{y}" width="{w}" height="{fh-1}" fill="{color}" rx="1"/>'
            f'<text x="{x+3}" y="{y+fh-3}" font-size="11">{html.escape(label[:max(1,w//7)])}</text>'
            f'</g>'
        )
    parts.append('</svg>')
    with open(path, "w") as f:
        f.write("\n".join(parts) + "\n")

