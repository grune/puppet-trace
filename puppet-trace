def status_badge(status):
    colors = {
        'changed':    ('#1a6b3a','#d4edda'),
        'failed':     ('#7a1a1a','#f8d7da'),
        'skipped':    ('#6b5a1a','#fff3cd'),
        'out_of_sync':('#3a3a7a','#cce5ff'),
        'unknown':    ('#555','#eee'),
        'unchanged':  ('#555','#eee'),
    }
    fg, bg = colors.get(status, ('#555','#eee'))
    return f'<span style="background:{bg};color:{fg};padding:2px 7px;border-radius:3px;font-size:0.8em;font-weight:bold">{html.escape(status)}</span>'

def fmt_rss_delta(delta):
    if delta is None: return '—'
    sign = '+' if delta >= 0 else ''
    return f'{sign}{delta//1024}MB'

