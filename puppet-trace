        except Exception:
            pass
    # Fallback: hand-crafted SVG
    frames = [
        # (label, x_pct, w_pct, level, color)
        ("ruby; main",                               0,  100, 0, "#e85"),
        ("Puppet::Agent#run",                        0,   90, 1, "#e65"),
