import sys, math
f = sys.argv[1]
base_ts = int(sys.argv[2])
# Memory profile: rises during nginx install (2s), jumps at vim (8s),
# spikes at prometheus (12s), peaks at docker install (24s)
def rss_at(t):
    base = 95000
    # nginx install
    if 4 <= t <= 6:   base += int(20000 * (t-4)/2)
    elif t > 6:        base += 20000
    # vim install
    if 9 <= t <= 11:  base += int(15000 * (t-9)/2)
    elif t > 11:       base += 15000
    # prometheus install
    if 14 <= t <= 17: base += int(25000 * (t-14)/3)
    elif t > 17:       base += 25000
    # docker install (biggest spike)
    if 22 <= t <= 27: base += int(40000 * (t-22)/5)
    elif t > 27:       base += 40000
    # gradual cleanup after peak
    if t > 30:         base -= int(10000 * (t-30)/8)
    noise = int(1200 * math.sin(t * 0.7))
    return max(base + noise, 90000)
with open(f, 'w') as out:
