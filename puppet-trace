                ["perl", fg_pl, "--title", title, f"--width={width}", f"--height={height}",
                 "--colors=hot", "--countname=samples"],
                input=folded_stacks, capture_output=True, text=True, timeout=15
            )
            if proc.returncode == 0 and proc.stdout.strip():
                with open(path, "w") as f:
                    f.write(proc.stdout)
