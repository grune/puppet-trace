        PUPPET_PID=$!
    else
        "${run_as_user[@]}" "${PUPPET_CMD[@]}" >"$PUPPET_LOG" 2>&1 &
        PUPPET_PID=$!
    fi

    echo "[puppet-trace] puppet PID=$PUPPET_PID started at $RUN_START_TS"

    sleep 0.3

    pmap -x "$PUPPET_PID" >"$PMAP_START" 2>/dev/null || echo "(pmap unavailable)" >"$PMAP_START"

    proc_poller "$PUPPET_PID" "$PROC_LOG" &
    PROC_POLLER_PID=$!
    _PT_CLEANUP_PIDS+=("$PROC_POLLER_PID")

    net_poller "$PUPPET_PID" "$NET_LOG" &
