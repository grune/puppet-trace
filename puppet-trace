# 4. proc-poll.log  (50 lines, 1/s)
# ---------------------------------------------------------------------------
proc_lines = []
base_rss = 27000
for i in range(50):
    ts = BASE_TS + i
    elapsed = i
    if i < 15:
        rss = base_rss + int((90000 - base_rss) * i / 15)
    else:
        rss = 90000 + random.randint(-500, 500)
    vmpeak = int(rss * 1.10)
    vmswap = 0
