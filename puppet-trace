cmd_diff() {
    local dir1="" dir2="" outfile="" format="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) echo "Usage: puppet-trace diff DIR1 DIR2 [--out FILE] [--html]"; exit 0 ;;
            --out)    outfile="$2"; shift 2 ;;
            --html)   format="html"; shift ;;
            *)
                if [[ -z "$dir1" ]]; then dir1="$1"
                elif [[ -z "$dir2" ]]; then dir2="$1"
                else echo "[puppet-trace diff] unexpected arg: $1" >&2; exit 1
                fi
                shift ;;
        esac
    done
    if [[ -z "$dir1" ]] || [[ -z "$dir2" ]]; then
        echo "Usage: puppet-trace diff DIR1 DIR2 [--out FILE] [--html]" >&2
        exit 1
    fi
    _validate_safe_path "$dir1" "DIR1" || exit 1
    _validate_safe_path "$dir2" "DIR2" || exit 1
    [[ -d "$dir1" ]] || { echo "[puppet-trace diff] DIR1 not found: $dir1" >&2; exit 1; }
    [[ -d "$dir2" ]] || { echo "[puppet-trace diff] DIR2 not found: $dir2" >&2; exit 1; }

    python3 - "$dir1" "$dir2" "$format" "${outfile:-}" <<'DIFF_PYEOF'
