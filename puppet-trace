###############################################################################
# POLLING WORKERS
###############################################################################
proc_poller() {
    trap - EXIT INT TERM
    local pid=$1
    local outfile=$2
    local elapsed=0
    # Use end-time sentinel instead of pure PID liveness to avoid PID-reuse confusion
    local deadline=$(( $(date +%s) + 3600 ))  # max 1 hour
    while kill -0 "$pid" 2>/dev/null && [[ $(date +%s) -lt $deadline ]]; do
        local ts
        ts=$(date +%s)
        local rss=0 vmpeak=0 vmswap=0
        if [[ -r /proc/$pid/status ]]; then
            rss=$(grep '^VmRSS:' /proc/$pid/status 2>/dev/null | awk '{print $2}' || echo 0)
            vmpeak=$(grep '^VmPeak:' /proc/$pid/status 2>/dev/null | awk '{print $2}' || echo 0)
            vmswap=$(grep '^VmSwap:' /proc/$pid/status 2>/dev/null | awk '{print $2}' || echo 0)
        fi
        local cpu=0
        if [[ -r /proc/$pid/stat ]]; then
            local stat
            stat=$(cat /proc/$pid/stat 2>/dev/null || echo "")
            if [[ -n $stat ]]; then
                local utime stime
                utime=$(echo "$stat" | awk '{print $14}')
                stime=$(echo "$stat" | awk '{print $15}')
                cpu=$(( (utime + stime) ))
            fi
        fi
        # Feature 2: smaps_rollup PSS/Private_Dirty
        local pss=0 private_dirty=0 swap_pss=0
        if [[ -r /proc/$pid/smaps_rollup ]]; then
            pss=$(grep '^Pss:' /proc/$pid/smaps_rollup 2>/dev/null | awk '{print $2}' || echo 0)
            private_dirty=$(grep '^Private_Dirty:' /proc/$pid/smaps_rollup 2>/dev/null | awk '{print $2}' || echo 0)
            swap_pss=$(grep '^SwapPss:' /proc/$pid/smaps_rollup 2>/dev/null | awk '{print $2}' || echo 0)
        fi
        echo "$ts $elapsed $rss $vmpeak $vmswap $cpu $pss $private_dirty $swap_pss" >>"$outfile"
        sleep "$POLL_INTERVAL"
        elapsed=$(echo "$elapsed + $POLL_INTERVAL" | bc 2>/dev/null || echo "?")
    done
}

net_poller() {
    trap - EXIT INT TERM
    local pid=$1
    local outfile=$2
    # Use end-time sentinel instead of pure PID liveness to avoid PID-reuse confusion
    local deadline=$(( $(date +%s) + 3600 ))  # max 1 hour
    while kill -0 "$pid" 2>/dev/null && [[ $(date +%s) -lt $deadline ]]; do
        local ts
        ts=$(date +%s)
        echo "# ts=$ts" >>"$outfile"
        # Read only the puppet process's TCP connections via /proc to avoid
        # leaking the full system TCP map into the report (#7471, #7590)
        if [[ -r /proc/$pid/net/tcp ]]; then
            awk 'NR>1 {print $3, $4}' /proc/"$pid"/net/tcp 2>/dev/null >>"$outfile" || true
            [[ -r /proc/$pid/net/tcp6 ]] && awk 'NR>1 {print $3, $4}' /proc/"$pid"/net/tcp6 2>/dev/null >>"$outfile" || true
        elif command -v ss &>/dev/null; then
            ss -tn 2>/dev/null >>"$outfile" || true
        fi
        sleep "$NET_POLL_INTERVAL"
    done
}

stack_sampler() {
    trap - EXIT INT TERM
    local pid=$1
    local outfile=$2
    local deadline=$(( $(date +%s) + 3600 ))  # max 1 hour
    while kill -0 "$pid" 2>/dev/null && [[ $(date +%s) -lt $deadline ]]; do
        if [[ -r /proc/$pid/stack ]]; then
            echo "---" >>"$outfile"
            cat /proc/$pid/stack 2>/dev/null >>"$outfile" || true
        fi
        sleep "$STACK_SAMPLE_INTERVAL"
    done
}

###############################################################################
# RUN PUPPET (once mode) — with strace wrapping for I/O correlation
###############################################################################
STRACE_RAW="$OUTDIR/strace.raw"
IDEMPOTENCY_STDOUT="$OUTDIR/idempotency.stdout"
LAST_RUN_REPORT="/opt/puppetlabs/puppet/cache/state/last_run_report.yaml"
LAST_RUN_SUMMARY="/opt/puppetlabs/puppet/cache/state/last_run_summary.yaml"
IO_CORR_JSON="$OUTDIR/io-correlation.json"

_PUPPET_SVC_STOPPED=false
_stop_puppet_service() {
    local lock="/opt/puppetlabs/puppet/cache/state/agent_catalog_run.lock"
    if [[ -f "$lock" ]]; then
        echo "[puppet-trace] lock file exists — stopping puppet.service to clear it..."
        if systemctl is-active --quiet puppet 2>/dev/null; then
            systemctl stop puppet 2>/dev/null && _PUPPET_SVC_STOPPED=true \
                && echo "[puppet-trace] puppet.service stopped" \
                || echo "[puppet-trace] WARNING: could not stop puppet.service" >&2
            _PT_STOPPED_PUPPET=true
        fi
        rm -f "$lock"
    fi
}

_restart_puppet_service() {
    if $_PUPPET_SVC_STOPPED; then
        echo "[puppet-trace] restarting puppet.service..."
        systemctl start puppet 2>/dev/null \
            && echo "[puppet-trace] puppet.service restarted" \
            || echo "[puppet-trace] WARNING: could not restart puppet.service" >&2
    fi
}

run_puppet() {
    _stop_puppet_service

    RUN_START_TS=$(date +%s)
    RUN_START_ISO=$(date -u -d "@${RUN_START_TS}" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)

    # Snapshot /proc/meminfo + df before run
    {
        echo "=== /proc/meminfo ==="
        cat /proc/meminfo 2>/dev/null || true
        echo "=== df -h ==="
        df -h 2>/dev/null || true
    } >"$OUTDIR/sysctx-before.txt" 2>/dev/null || true

    local puppet_run_user="${PUPPET_TRACE_PUPPET_USER:-puppet}"
    # Validate puppet user — must not be root or contain special chars
    if [[ "$puppet_run_user" == "root" ]] || ! _validate_puppet_id "$puppet_run_user" "PUPPET_TRACE_PUPPET_USER" 2>/dev/null; then
        echo "[puppet-trace] WARNING: PUPPET_TRACE_PUPPET_USER='$puppet_run_user' is invalid or root — using 'puppet'" >&2
        puppet_run_user="puppet"
    fi
    local run_as_user=()
    if id "$puppet_run_user" &>/dev/null && [[ $EUID -eq 0 ]]; then
        run_as_user=(sudo -u "$puppet_run_user" --)
    fi
    if [[ ${#run_as_user[@]} -gt 0 ]]; then
        if ! "${run_as_user[@]}" true 2>/dev/null; then
            echo "[puppet-trace] WARNING: sudo -u $puppet_run_user failed — falling back to root. Install puppet-trace.sudoers to run puppet as $puppet_run_user." >&2
            run_as_user=()
        fi
    fi

    # Feature 1: state.yaml health check (PUP-3647: unbounded growth causes 100-250s overhead)
    local state_yaml="/opt/puppetlabs/puppet/cache/state/state.yaml"
    local _statesize=0
    if [[ -f "$state_yaml" ]]; then
        _statesize=$(stat -c%s "$state_yaml" 2>/dev/null || echo 0)
        echo "[puppet-trace] state.yaml size: $(( _statesize / 1024 / 1024 ))MB ($(( _statesize / 1024 ))KB)"
        if (( _statesize > 10485760 )); then  # > 10MB
            echo "[puppet-trace] WARNING: state.yaml is $(( _statesize / 1024 / 1024 ))MB — PUP-3647 bloat suspected. Large state file adds minutes to run time. Consider: puppet resource file --purge=true ... or truncate after backup." >&2
        fi
    fi
    echo "$_statesize" > "$OUTDIR/state-yaml-size.txt"

    # Feature 6: GC::Profiler injection via RUBYOPT for once-mode
    GC_PROF_LOG="$OUTDIR/gc-profiler.log"
    local _gc_shim=""
    if [[ "${RUBYOPT_GC_PROF:-true}" == "true" ]]; then
        _gc_shim=$(mktemp --suffix=.rb /tmp/pt_gc_enable_XXXXXXXX) || true
        if [[ -n "$_gc_shim" ]]; then
            cat >"$_gc_shim" <<'GCEOF'
GC::Profiler.enable
at_exit do
  $stderr.puts "\n=== PT_GC_PROFILER ==="
  $stderr.puts GC::Profiler.result
  $stderr.puts "=== PT_GC_PROFILER_END ==="
end
GCEOF
            chmod 644 "$_gc_shim"
            export RUBYOPT="-r $_gc_shim${RUBYOPT:+ $RUBYOPT}"
        fi
    fi

    "${run_as_user[@]}" "${PUPPET_CMD[@]}" >"$PUPPET_LOG" 2>&1 &
    PUPPET_PID=$!

    # Feature 3: cgroup v2 accounting — snapshot at run start
    CGROUP_LOG="$OUTDIR/cgroup-accounting.log"
    local _cg_path=""
    if [[ -f /sys/fs/cgroup/cgroup.controllers ]]; then
        # cgroup v2 unified hierarchy
        _cg_path=$(awk -F: '$2=="" {print "/sys/fs/cgroup" $3}' /proc/$PUPPET_PID/cgroup 2>/dev/null | head -1)
        if [[ -z "$_cg_path" ]] && systemctl is-active --quiet puppet 2>/dev/null; then
            _cg_path=$(systemctl show puppet --property=ControlGroup --value 2>/dev/null)
            [[ -n "$_cg_path" ]] && _cg_path="/sys/fs/cgroup${_cg_path}"
        fi
        if [[ -n "$_cg_path" ]] && [[ -d "$_cg_path" ]]; then
            {
                echo "# cgroup_start ts=$(date +%s)"
                echo "# path=$_cg_path"
                [[ -r "$_cg_path/cpu.stat" ]]       && echo "=== cpu.stat ===" && cat "$_cg_path/cpu.stat"
                [[ -r "$_cg_path/memory.current" ]]  && echo "=== memory.current ===" && cat "$_cg_path/memory.current"
                [[ -r "$_cg_path/io.stat" ]]         && echo "=== io.stat ===" && cat "$_cg_path/io.stat"
            } >"$CGROUP_LOG" 2>/dev/null || true
            echo "$_cg_path" >"$OUTDIR/cgroup-path.txt"
        fi
    fi

    STRACE_ATTACH_PID=""
    if $HAS_STRACE && $IS_ROOT; then
        echo "[puppet-trace] running puppet under strace (full I/O correlation mode)"
        # Attach strace to the running puppet PID so we wait on puppet (not strace).
        # strace -f launched as the root process would hang indefinitely if any
        # child it forked daemonizes and never exits (#7597).
        sleep 0.1
        strace -f -ttt -s 0 \
            -e trace=openat,open,read,write,execve,clone,exit_group,connect,sendto,recvfrom \
            -p "$PUPPET_PID" \
            -o "$STRACE_RAW" 2>/dev/null &
        STRACE_ATTACH_PID=$!
        _PT_CLEANUP_PIDS+=("$STRACE_ATTACH_PID")
    fi

    echo "[puppet-trace] puppet PID=$PUPPET_PID started at $RUN_START_TS"

    sleep 0.3

    pmap -x "$PUPPET_PID" >"$PMAP_START" 2>/dev/null || echo "(pmap unavailable)" >"$PMAP_START"

    proc_poller "$PUPPET_PID" "$PROC_LOG" &
    PROC_POLLER_PID=$!
    _PT_CLEANUP_PIDS+=("$PROC_POLLER_PID")

    net_poller "$PUPPET_PID" "$NET_LOG" &
    NET_POLLER_PID=$!
    _PT_CLEANUP_PIDS+=("$NET_POLLER_PID")

    # /proc/PID/io poller for per-resource delta tracking
    IO_POLL_LOG="$OUTDIR/proc-io-poll.log"
    {
        trap - EXIT INT TERM
        local io_deadline=$(( $(date +%s) + 3600 ))
        while kill -0 "$PUPPET_PID" 2>/dev/null && [[ $(date +%s) -lt $io_deadline ]]; do
            local ts rb wb
            ts=$(date +%s%3N)
            rb=$(awk '/^read_bytes/{print $2}' /proc/$PUPPET_PID/io 2>/dev/null || echo 0)
            wb=$(awk '/^write_bytes/{print $2}' /proc/$PUPPET_PID/io 2>/dev/null || echo 0)
            echo "$ts $rb $wb"
            sleep 0.5
        done
    } >>"$IO_POLL_LOG" &
    IO_POLLER_PID=$!
    _PT_CLEANUP_PIDS+=("$IO_POLLER_PID")

    STRACE_PID=""
    if ! $HAS_STRACE || ! $IS_ROOT; then
        if $HAS_INOTIFY; then
            inotifywait -m -r /etc /opt/puppetlabs /var/lib/puppet \
                --format '%T %e %w%f' --timefmt '%s' \
                >"$INOTIFY_LOG" 2>/dev/null &
            STRACE_PID=$!
            _PT_CLEANUP_PIDS+=("$STRACE_PID")
        fi
    fi

    PERF_PID=""
    if $HAS_PERF && $IS_ROOT; then
        perf record -g -p "$PUPPET_PID" -o "$PERF_DATA" 2>/dev/null &
        PERF_PID=$!
        _PT_CLEANUP_PIDS+=("$PERF_PID")
    else
        stack_sampler "$PUPPET_PID" "$STACK_LOG" &
        PERF_PID=$!
        _PT_CLEANUP_PIDS+=("$PERF_PID")
    fi

    # Feature 5: rbspy Ruby-level flamegraph (if available)
    RBSPY_PID=""
    RBSPY_SVG="$OUTDIR/ruby-flamegraph.svg"
    if ${HAS_RBSPY:-false} && $IS_ROOT; then
        rbspy record --pid "$PUPPET_PID" --nonblocking \
            --format flamegraph --file "$RBSPY_SVG" &
        RBSPY_PID=$!
        _PT_CLEANUP_PIDS+=("$RBSPY_PID")
        echo "[puppet-trace] rbspy Ruby-level profiler started (PID=$RBSPY_PID)"
    fi

    # pmap calls: PMAP_START and PMAP_END are synchronous — no cleanup needed.
    # PMAP_MID runs in a background subshell (sleep 10 then snapshot); track its PID (#7515).
    (
        trap - EXIT INT TERM
        sleep 10
        pmap -x "$PUPPET_PID" >"$PMAP_MID" 2>/dev/null || echo "(pmap unavailable)" >"$PMAP_MID"
    ) &
    PMAP_MID_PID=$!
    _PT_CLEANUP_PIDS+=("$PMAP_MID_PID")

    if $FOLLOW; then
        local _last_log_line=0 _last_rb=0 _last_wb=0 _tick=0
        while kill -0 "$PUPPET_PID" 2>/dev/null; do
            local _elapsed=$(( $(date +%s) - RUN_START_TS ))
            local _rb _wb _drb _dwb
            _rb=$(awk '/^read_bytes/{print $2}' /proc/$PUPPET_PID/io 2>/dev/null || echo 0)
            _wb=$(awk '/^write_bytes/{print $2}' /proc/$PUPPET_PID/io 2>/dev/null || echo 0)
            _drb=$(( (_rb - _last_rb) / 1024 ))
            _dwb=$(( (_wb - _last_wb) / 1024 ))
            _last_rb=$_rb; _last_wb=$_wb
            # Print new puppet.log lines (strip ANSI, prefix with ">")
            if [[ -f "$PUPPET_LOG" ]]; then
                local _total_lines
                _total_lines=$(wc -l <"$PUPPET_LOG" 2>/dev/null || echo 0)
                if (( _total_lines > _last_log_line )); then
                    sed -n "$(( _last_log_line + 1 )),${_total_lines}p" "$PUPPET_LOG" \
                        | sed 's/\x1b\[[0-9;]*m//g' \
                        | while IFS= read -r _line; do printf '[puppet] %s\n' "$_line"; done
                    _last_log_line=$_total_lines
                fi
            fi
            printf '[puppet-trace] elapsed=%ds io_read=%dKB/s io_write=%dKB/s\n' \
                "$_elapsed" "$_drb" "$_dwb"
            sleep 5
        done
    fi
    wait "$PUPPET_PID"
    PUPPET_EXIT=$?
    true
    RUN_END_TS=$(date +%s)
    WALL_SECONDS=$(( RUN_END_TS - RUN_START_TS ))

    # Detach strace now that puppet exited; don't let it hang on daemonized children.
    [[ -n "${STRACE_ATTACH_PID:-}" ]] && kill "$STRACE_ATTACH_PID" 2>/dev/null || true

    pmap -x "$PUPPET_PID" >"$PMAP_END" 2>/dev/null || echo "(pmap unavailable)" >"$PMAP_END"

    [[ -n "${PROC_POLLER_PID:-}" ]] && kill "$PROC_POLLER_PID" 2>/dev/null || true
    [[ -n "${NET_POLLER_PID:-}" ]]  && kill "$NET_POLLER_PID"  2>/dev/null || true
    [[ -n "${IO_POLLER_PID:-}" ]]   && kill "$IO_POLLER_PID"   2>/dev/null || true
    [[ -n "${STRACE_PID:-}" ]]       && kill "$STRACE_PID"       2>/dev/null || true
    [[ -n "${PERF_PID:-}" ]]         && kill "$PERF_PID"         2>/dev/null || true
    [[ -n "${RBSPY_PID:-}" ]]        && kill "$RBSPY_PID"        2>/dev/null || true
    wait 2>/dev/null || true

    # Snapshot /proc/meminfo + df after run
    {
        echo "=== /proc/meminfo ==="
        cat /proc/meminfo 2>/dev/null || true
        echo "=== df -h ==="
        df -h 2>/dev/null || true
        echo "=== ss -tn ==="
        ss -tn 2>/dev/null || true
    } >"$OUTDIR/sysctx-after.txt" 2>/dev/null || true

    # Feature 3: cgroup v2 accounting — snapshot at run end
    if [[ -n "${_cg_path:-}" ]] && [[ -d "$_cg_path" ]]; then
        {
            echo "# cgroup_end ts=$(date +%s)"
            [[ -r "$_cg_path/cpu.stat" ]]       && echo "=== cpu.stat ===" && cat "$_cg_path/cpu.stat"
            [[ -r "$_cg_path/memory.current" ]]  && echo "=== memory.current ===" && cat "$_cg_path/memory.current"
            [[ -r "$_cg_path/io.stat" ]]         && echo "=== io.stat ===" && cat "$_cg_path/io.stat"
        } >>"$CGROUP_LOG" 2>/dev/null || true
    fi

    # Feature 4: Facter timing — capture facter --timing output if Facter 4.x
    FACTER_TIMING_LOG="$OUTDIR/facter-timing.log"
    if command -v facter &>/dev/null; then
        facter --timing 2>"$FACTER_TIMING_LOG" >/dev/null || true
        if [[ ! -s "$FACTER_TIMING_LOG" ]]; then
            FACTER_TIMING="(facter --timing produced no output — may be Facter < 4.x or puppetlabs facter)"
            echo "$FACTER_TIMING" >"$FACTER_TIMING_LOG"
        fi
    fi

    # Feature 4: Pre-catalog gap — time from process start to first connect() in strace
    PRECATALOG_SECS=""
    if [[ -f "$STRACE_RAW" ]]; then
        local _first_connect_ts
        _first_connect_ts=$(grep -m1 'connect(' "$STRACE_RAW" 2>/dev/null | awk '{print $2}' | head -1)
        if [[ -n "$_first_connect_ts" ]]; then
            local _first_ts_sec="${_first_connect_ts%%.*}"
            PRECATALOG_SECS=$(( _first_ts_sec - RUN_START_TS ))
            echo "$PRECATALOG_SECS" >"$OUTDIR/facter-gap-secs.txt"
            echo "[puppet-trace] pre-catalog gap (facter+init): ${PRECATALOG_SECS}s"
        fi
    fi

    # Feature 6: Extract GC::Profiler output from puppet.log and clean up shim
    if [[ -n "${_gc_shim:-}" ]]; then
        unset RUBYOPT
        rm -f "$_gc_shim" 2>/dev/null || true
        if grep -q 'PT_GC_PROFILER' "$PUPPET_LOG" 2>/dev/null; then
            sed -n '/=== PT_GC_PROFILER ===/,/=== PT_GC_PROFILER_END ===/p' \
                "$PUPPET_LOG" >"$GC_PROF_LOG" 2>/dev/null || true
            echo "[puppet-trace] GC::Profiler data captured → $GC_PROF_LOG"
        else
            echo "(GC::Profiler output not found — may not be Ruby 2.x+)" >"$GC_PROF_LOG"
        fi
    fi

    echo "[puppet-trace] puppet exited with code $PUPPET_EXIT after ${WALL_SECONDS}s"
    _restart_puppet_service
}

###############################################################################
# SAVE RUN METADATA (once mode — for 'report' subcommand)
###############################################################################
save_run_meta() {
    python3 - "$OUTDIR/run-meta.json" \
        "$WALL_SECONDS" "$PUPPET_EXIT" "${PUPPET_CMD[*]}" \
        "$IDEMPOTENCY_PASS" "$IDEMPOTENCY_CHANGES" "${RUN_START_ISO:-}" \
        "$TIMESTAMP" "$OUTDIR/resource-report.json" <<'PYEOF_META'
import json, sys, os
out  = sys.argv[1]
rr_path = sys.argv[9] if len(sys.argv) > 9 else ''
data = {
    'wall_seconds':        int(sys.argv[2]),
    'puppet_exit':         int(sys.argv[3]),
    'puppet_cmd':          sys.argv[4],
    'idempotency_pass':    sys.argv[5],
    'idempotency_changes': int(sys.argv[6]),
    'run_start_iso':       sys.argv[7],
    'timestamp':           sys.argv[8],
}
if rr_path and os.path.isfile(rr_path):
    try:
        rr = json.load(open(rr_path))
        resources = rr.get('resources', [])
        data['res_total']     = len(resources)
        data['res_changed']   = sum(1 for r in resources if r.get('changed'))
        data['res_failed']    = sum(1 for r in resources if r.get('failed'))
        data['res_skipped']   = sum(1 for r in resources if r.get('skipped'))
        data['pdb_enriched']  = rr.get('pdb_enriched', False)
        data['pdb_node']      = rr.get('pdb_node', '')
    except Exception:
        pass
with open(out, 'w') as f:
    json.dump(data, f, indent=2)
print(f"[puppet-trace] run-meta.json saved: {out}", file=__import__('sys').stderr)
PYEOF_META
}

###############################################################################
# IDEMPOTENCY CHECK (once mode — second run with --noop)
###############################################################################
IDEMPOTENCY_PASS=unknown
IDEMPOTENCY_CHANGES=0

run_idempotency_check() {
    local puppet_run_user="${PUPPET_TRACE_PUPPET_USER:-puppet}"
    # Validate puppet user — must not be root or contain special chars
    if [[ "$puppet_run_user" == "root" ]] || ! _validate_puppet_id "$puppet_run_user" "PUPPET_TRACE_PUPPET_USER" 2>/dev/null; then
        echo "[puppet-trace] WARNING: PUPPET_TRACE_PUPPET_USER='$puppet_run_user' is invalid or root — using 'puppet'" >&2
        puppet_run_user="puppet"
    fi
    local run_as_user=()
    if id "$puppet_run_user" &>/dev/null && [[ $EUID -eq 0 ]]; then
        run_as_user=(sudo -u "$puppet_run_user" --)
    fi
    if [[ ${#run_as_user[@]} -gt 0 ]]; then
        if ! "${run_as_user[@]}" true 2>/dev/null; then
            echo "[puppet-trace] WARNING: sudo -u $puppet_run_user failed — falling back to root. Install puppet-trace.sudoers to run puppet as $puppet_run_user." >&2
            run_as_user=()
        fi
    fi

    echo "[puppet-trace] idempotency check (--noop run)..."
    local idem_exit=0
    "${run_as_user[@]}" /opt/puppetlabs/bin/puppet agent --test --noop \
        >"$IDEMPOTENCY_STDOUT" 2>&1 || idem_exit=$?
    IDEMPOTENCY_CHANGES=$(grep -cE \
        'would have triggered|would have changed|Notice.*changed' \
        "$IDEMPOTENCY_STDOUT" 2>/dev/null; true)
    IDEMPOTENCY_CHANGES=${IDEMPOTENCY_CHANGES:-0}
    if [[ "$IDEMPOTENCY_CHANGES" -eq 0 ]]; then
        IDEMPOTENCY_PASS=true
    else
        IDEMPOTENCY_PASS=false
    fi
    echo "[puppet-trace] idempotency: pass=$IDEMPOTENCY_PASS changes=$IDEMPOTENCY_CHANGES"
}

###############################################################################
# LAST_RUN_REPORT PARSER (python3, post-run)
###############################################################################
parse_last_run_report() {
    echo "[puppet-trace] parsing last_run_report.yaml..."
    # Python's yaml.safe_load chokes on !ruby/object tags in last_run_report.yaml.
    # Use puppet's bundled ruby + tag-stripping so Psych treats puppet objects as plain Hashes.
    local ruby_script
    ruby_script=$(mktemp "${OUTDIR}/puppet-trace-tmp.XXXXX.rb")
    cat > "$ruby_script" << 'RUBYEOF'
require 'yaml'; require 'json'
report_yaml = ARGV[0]
out_json    = ARGV[1]

unless File.exist?(report_yaml)
  File.write(out_json, JSON.generate({resources: [], totals: {}, status: 'unknown'}))
  exit 0
end

# Strip Ruby-specific YAML tags so Psych parses unknown objects as plain Hashes.
# !ruby/object:Puppet::... -> !!map  (treat as hash)
# !ruby/sym name           -> :name  (treat as symbol key)
yaml_str   = File.read(report_yaml)
yaml_clean = yaml_str.gsub(/!ruby\/object:[^\s]+/, '!!map').gsub(/!ruby\/sym /, ':')
report = YAML.safe_load(yaml_clean, permitted_classes: [Symbol, Time]) || {}

resources = []
resource_statuses = report['resource_statuses'] || {}
resource_statuses.each do |title, rs|
  next unless rs.is_a?(Hash)
  events = (rs['events'] || []).map do |e|
    next unless e.is_a?(Hash)
    {status: e['status'], message: e['message'].to_s, previous_value: e['previous_value'].to_s, desired_value: e['desired_value'].to_s}
  end.compact
  before_val = events.first&.dig(:previous_value)
  after_val  = events.first&.dig(:desired_value)
  failed  = !!rs['failed']
  skipped = !!rs['skipped']
  changed = !!(rs['changed'] || rs['out_of_sync'])
  status  = failed ? 'failed' : (skipped ? 'skipped' : (changed ? 'changed' : 'unchanged'))
  resources << {
    title: title, type: (rs['resource_type'] || title.split('[').first),
    status: status, evaluation_time: rs['evaluation_time'].to_f,
    changed: changed, failed: failed, skipped: skipped, out_of_sync: !!rs['out_of_sync'],
    before: before_val, after: after_val,
    file: rs['file'].to_s, line: rs['line'].to_s,
  }
end

totals = {}
(report['metrics'] || {}).each do |cat, cat_data|
  next unless cat_data.is_a?(Hash)
  (cat_data['values'] || []).each do |entry|
    totals["#{cat}.#{entry[0]}"] = entry[2] if entry.is_a?(Array) && entry.length >= 3
  end
end

result = {
  resources: resources, totals: totals,
  certname:         report['host'].to_s,
  config_version:   report['configuration_version'].to_s,
  puppet_version:   report['puppet_version'].to_s,
  transaction_uuid: report['transaction_uuid'].to_s,
  status:           report['status'].to_s,
  noop:             !!report['noop'],
  summary:          {},
}

File.write(out_json, JSON.generate(result))
STDERR.puts "[puppet-trace] resource-report.json: #{resources.length} resources"
RUBYEOF
    /opt/puppetlabs/puppet/bin/ruby "$ruby_script" "$LAST_RUN_REPORT" "$OUTDIR/resource-report.json" 2>&1
    rm -f "$ruby_script"
}

###############################################################################
# PUPPETDB ENRICHMENT (ssh to puppet server, via docker exec)
# Puppet 8 omits resource_statuses from last_run_report.yaml; fetch from PDB.
###############################################################################
enrich_from_puppetdb() {
    # Skip PuppetDB when running puppet apply (no server, no PDB submission)
    if [[ "${PUPPET_CMD[*]}" =~ puppet[[:space:]]apply ]]; then
        echo "[puppet-trace] puppet apply detected — skipping PuppetDB enrichment"
        return
    fi

    local rr_json="$OUTDIR/resource-report.json"
    local res_count
    res_count=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(len(d.get('resources',[])))" "$rr_json" 2>/dev/null || echo 0)
    if [[ "$res_count" -gt 0 ]]; then
        echo "[puppet-trace] resource-report has $res_count resources — skipping PuppetDB enrichment"
        return
    fi

    local transaction_uuid certname puppet_server ssh_user ssh_key _ssh_opts
    transaction_uuid=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('transaction_uuid',''))" "$rr_json" 2>/dev/null || echo "")
    certname=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('certname',''))" "$rr_json" 2>/dev/null || echo "")
    # Fallback: read host: from last_run_report.yaml directly (more reliable than hostname -f)
    if [[ -z "$certname" ]]; then
        certname=$(grep -m1 '^host:' "$LAST_RUN_REPORT" 2>/dev/null | awk '{print $2}' | tr -d "'" || true)
    fi
    [[ -z "$certname" ]] && certname=$(puppet config print certname 2>/dev/null | tr -d '\n' || hostname -f 2>/dev/null || hostname)
    puppet_server="${PUPPET_SERVER:-$(puppet config print server 2>/dev/null | tr -d '\n' || true)}"
    [[ -z "$puppet_server" ]] && puppet_server="$(hostname -f 2>/dev/null || hostname)"
    if [[ -n "$puppet_server" ]]; then
        _validate_puppet_id "$puppet_server" "puppet_server" || puppet_server=""
    fi
    [[ -z "$puppet_server" ]] && { echo "[puppet-trace] ERROR: could not determine puppet server for PuppetDB enrichment" >&2; return 1; }
    ssh_user="${PUPPET_TRACE_SSH_USER:-${SUDO_USER:-puppet}}"
    local _pdb_sudo_key=""
    if [[ -n "${SUDO_USER:-}" ]]; then
        local _pdb_sudo_home
        _pdb_sudo_home=$(getent passwd "$SUDO_USER" 2>/dev/null | cut -d: -f6 || true)
        [[ -n "$_pdb_sudo_home" ]] && _pdb_sudo_key="${_pdb_sudo_home}/.ssh/id_ed25519"
    fi
    local _pdb_default_key="${HOME:-/root}/.ssh/id_ed25519"
    if [[ ! -f "$_pdb_default_key" ]] && [[ -f "${_pdb_sudo_key:-}" ]]; then
        _pdb_default_key="$_pdb_sudo_key"
    fi
    ssh_key="${PUPPET_TRACE_SSH_KEY:-${_pdb_default_key}}"
    if [[ -n "${PUPPET_TRACE_SSH_KEY:-}" ]]; then
        _validate_ssh_key_path "$ssh_key" "$_pdb_default_key" || ssh_key="$_pdb_default_key"
    fi
    local _pdb_container="${PUPPET_TRACE_PDB_CONTAINER:-}"
    if [[ -z "$_pdb_container" ]] && [[ -n "${PUSH_SERVER:-}" ]]; then
        _pdb_container=$(curl -sf --max-time 3 \
            "http://${PUSH_SERVER}/api/profiling/status" \
            2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('pdb_container_name',''))" 2>/dev/null || true)
    fi
    if [[ -z "$_pdb_container" ]]; then
        echo "[puppet-trace] PuppetDB not configured — skipping enrichment" >&2
        return
    fi
    _validate_puppet_id "${_pdb_container}" "PUPPET_TRACE_PDB_CONTAINER" || return
    _validate_puppet_id "${ssh_user}" "PUPPET_TRACE_SSH_USER" || return
    # Validate puppet identifiers before use in SSH commands
    _validate_puppet_id "$certname" "certname" || return
    [[ -n "$transaction_uuid" ]] && _validate_puppet_id "$transaction_uuid" "transaction_uuid" || transaction_uuid=""
    local certname_enc transaction_uuid_enc
    certname_enc=$(python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$certname")
    [[ -n "$transaction_uuid" ]] && transaction_uuid_enc=$(python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.argv[1]))" "$transaction_uuid") || transaction_uuid_enc=""
    mkdir -m 0755 -p /var/log/puppet-trace/
    local _pdb_strict_host="${PUPPET_TRACE_STRICT_HOST_KEY:-accept-new}"
    case "$_pdb_strict_host" in
        yes|accept-new|no) ;;
        *) echo "[puppet-trace] WARNING: invalid PUPPET_TRACE_STRICT_HOST_KEY '$_pdb_strict_host' — using accept-new" >&2
           _pdb_strict_host="accept-new" ;;
    esac
    if [[ "$_pdb_strict_host" == "accept-new" ]]; then
        echo "[puppet-trace] WARNING: StrictHostKeyChecking=accept-new (TOFU). Set PUPPET_TRACE_STRICT_HOST_KEY=yes for production." >&2
    fi
    _ssh_opts=(-o ConnectTimeout=5 -o BatchMode=yes -o "StrictHostKeyChecking=${_pdb_strict_host}" -o UserKnownHostsFile=/var/log/puppet-trace/.ssh_known_hosts)
    [[ -f "$ssh_key" ]] && _ssh_opts+=(-i "$ssh_key")

    echo "[puppet-trace] querying PuppetDB on $puppet_server for $certname..."

    local pdb_json _pdb_stderr
    _pdb_stderr=$(mktemp)
    pdb_json=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
        "docker exec ${_pdb_container} curl -sf \
         'http://localhost:8080/pdb/query/v4/resources?query=%5B%22%3D%22%2C%22certname%22%2C%22${certname_enc}%22%5D'" \
        2>"$_pdb_stderr") || {
        local _pdb_err; _pdb_err=$(cat "$_pdb_stderr" 2>/dev/null | head -1)
        rm -f "$_pdb_stderr"
        echo "[puppet-trace] PuppetDB query failed (container=${_pdb_container}): ${_pdb_err:-ssh error} — skipping" >&2
        return
    }
    rm -f "$_pdb_stderr"

    local event_json=""
    if [[ -n "$transaction_uuid" ]]; then
        local report_hash
        report_hash=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
            "docker exec ${_pdb_container} curl -sf \
             'http://localhost:8080/pdb/query/v4/reports?query=%5B%22%3D%22%2C%22transaction_uuid%22%2C%22${transaction_uuid_enc}%22%5D'" \
            2>/dev/null | python3 -c "import json,sys; d=json.load(sys.stdin); print(d[0]['hash'] if d else '')" 2>/dev/null || echo "")
        if [[ -n "$report_hash" ]]; then
            _validate_puppet_id "$report_hash" "report_hash" || report_hash=""
        fi
        if [[ -n "$report_hash" ]]; then
            event_json=$(ssh "${_ssh_opts[@]}" "${ssh_user}@${puppet_server}" \
                "docker exec ${_pdb_container} curl -sf \
                 'http://localhost:8080/pdb/query/v4/events?query=%5B%22%3D%22%2C%22report%22%2C%22${report_hash}%22%5D'" \
                2>/dev/null) || event_json="[]"
        fi
    fi

    local _pdb_tmp _evt_tmp
    _pdb_tmp=$(mktemp "${OUTDIR}/puppet-trace-tmp.XXXXX.json")
    _evt_tmp=$(mktemp "${OUTDIR}/puppet-trace-tmp.XXXXX.json")
    printf '%s\n' "$pdb_json" > "$_pdb_tmp"
    printf '%s\n' "${event_json:-[]}" > "$_evt_tmp"

    python3 - "$rr_json" "$_pdb_tmp" "$_evt_tmp" <<'PYEOF_PDB'
import json, sys, os

rr_path    = sys.argv[1]
pdb_path   = sys.argv[2] if len(sys.argv) > 2 else ''
evt_path   = sys.argv[3] if len(sys.argv) > 3 else ''

pdb_res    = json.load(open(pdb_path)) if pdb_path and os.path.isfile(pdb_path) else []
pdb_events = json.load(open(evt_path)) if evt_path and os.path.isfile(evt_path) else []

rr = json.load(open(rr_path))

# Build event lookup by resource title
events_by_title = {}
for ev in (pdb_events if isinstance(pdb_events, list) else []):
    t = f"{ev.get('resource_type','')}/{ev.get('resource_title','')}"
    events_by_title.setdefault(t, []).append(ev)

def res_key(rtype, rtitle): return f"{rtype}/{rtitle}"

resources = []
for r in (pdb_res if isinstance(pdb_res, list) else []):
    rtype  = r.get('type', '')
    rtitle = r.get('title', '')
    key    = res_key(rtype, rtitle)
    evs    = events_by_title.get(key, [])
    status = 'unchanged'
    before = after = None
    if evs:
        statuses = [e.get('status','') for e in evs]
        if any(s == 'failure' for s in statuses): status = 'failed'
        elif any(s == 'success' for s in statuses): status = 'changed'
        elif any(s == 'noop' for s in statuses): status = 'noop'
        before = evs[0].get('old_value')
        after  = evs[0].get('new_value')
    resources.append({
        'title':           f"{rtype}[{rtitle}]",
        'type':            rtype,
        'status':          status,
        'evaluation_time': 0,
        'changed':         status == 'changed',
        'failed':          status == 'failed',
        'skipped':         False,
        'before':          str(before) if before is not None else None,
        'after':           str(after)  if after  is not None else None,
        'file':            r.get('file') or '',
        'line':            str(r.get('line') or ''),
        'parameters':      r.get('parameters') or {},
        'pdb_source':      True,
    })

rr['resources'] = resources
rr['pdb_enriched'] = True
rr['pdb_node'] = rr.get('certname', '')
with open(rr_path, 'w') as f:
    json.dump(rr, f, indent=2)
print(f"[puppet-trace] PuppetDB enrichment: {len(resources)} resources", file=sys.stderr)
PYEOF_PDB
    rm -f "$_pdb_tmp" "$_evt_tmp"
}

###############################################################################
# STRACE I/O CORRELATION ENGINE (python3, post-run)
###############################################################################
run_strace_correlation() {
    if [[ ! -f "$STRACE_RAW" ]]; then
        echo "[puppet-trace] no strace.raw — skipping correlation"
        return
    fi
    local resource_report="$OUTDIR/resource-report.json"
    if [[ ! -f "$resource_report" ]]; then
        echo "[puppet-trace] no resource-report.json — skipping correlation"
        return
    fi

    # Size sentinel: skip correlation on very large strace files to prevent OOM
    local strace_size
    strace_size=$(stat -c%s "$STRACE_RAW" 2>/dev/null || echo 0)
    local strace_max_bytes=$(( 512 * 1024 * 1024 ))  # 512MB
    if [[ "$strace_size" -gt "$strace_max_bytes" ]]; then
        echo "[puppet-trace] WARNING: strace.raw is ${strace_size} bytes (>${strace_max_bytes}) — skipping correlation to avoid OOM. Use --no-strace or increase disk space." >&2
        return
    fi

    echo "[puppet-trace] running strace I/O correlation engine..."
    python3 - "$STRACE_RAW" "$PUPPET_LOG" "$resource_report" "$IO_CORR_JSON" "$PROC_LOG" <<'PYEOF'
import sys, os, re, json, collections

strace_raw      = sys.argv[1]
puppet_log      = sys.argv[2]
resource_report = sys.argv[3]
out_json        = sys.argv[4]
proc_log        = sys.argv[5] if len(sys.argv) > 5 else ''

# ── 1. Parse strace.raw ────────────────────────────────────────────────────
# Format: PID  TIMESTAMP SYSCALL(ARGS) = RETVAL
# -ttt gives microsecond timestamps
strace_events = []
strace_re = re.compile(
    r'^(\d+)\s+([\d.]+)\s+(\w+)\((.*)$'
)
retval_re = re.compile(r'\)\s*=\s*(-?\d+)')

print(f"[corr] parsing strace: {strace_raw}")
try:
    with open(strace_raw, errors='replace') as f:
        for line in f:
            m = strace_re.match(line)
            if not m:
                continue
            pid       = int(m.group(1))
            ts        = float(m.group(2))
            syscall   = m.group(3)
            rest      = m.group(4)
            retval_m  = retval_re.search(rest)
            retval    = int(retval_m.group(1)) if retval_m else 0

            # extract path from first quoted string
            path_m = re.search(r'"([^"]+)"', rest)
            path   = path_m.group(1) if path_m else ''

            # extract execve args
            args = []
            if syscall == 'execve':
                args_m = re.search(r'\[([^\]]+)\]', rest)
                if args_m:
                    args = re.findall(r'"([^"]*)"', args_m.group(1))

            # extract connect target
            remote = ''
            if syscall == 'connect':
                addr_m = re.search(r'sin_addr=inet_addr\("([^"]+)"\).*sin_port=htons\((\d+)\)', rest)
                if addr_m:
                    remote = f'{addr_m.group(1)}:{addr_m.group(2)}'
                addr6_m = re.search(r'sin6_addr=inet_pton\(AF_INET6, "([^"]+)"\).*sin6_port=htons\((\d+)\)', rest)
                if addr6_m:
                    remote = f'[{addr6_m.group(1)}]:{addr6_m.group(2)}'

            strace_events.append({
                'ts': ts, 'pid': pid, 'syscall': syscall,
                'path': path, 'retval': retval,
                'args': args, 'remote': remote,
            })
except FileNotFoundError:
    print(f"[corr] strace.raw not found")
    strace_events = []

# ── 1b. Load proc-poll.log for RSS/memory correlation ───────────────────────
proc_poll = []  # list of (unix_ts_float, rss_kb)
if proc_log and os.path.isfile(proc_log):
    with open(proc_log) as f:
        for ln in f:
            parts = ln.split()
            if len(parts) >= 3:
                try:
                    proc_poll.append((float(parts[0]), int(parts[2])))
                except (ValueError, IndexError):
                    pass
print(f"[corr] proc-poll samples: {len(proc_poll)}")

def rss_for_window(t0, t1, proc_poll):
    samples = [(ts, rss) for ts, rss in proc_poll if t0 <= ts <= t1]
    if not samples and proc_poll:
        # resource faster than poll interval — find nearest sample
        mid = (t0 + t1) / 2
        nearest = min(proc_poll, key=lambda x: abs(x[0] - mid))
        samples = [nearest]
    if not samples:
        return {}
    rss_vals = [rss for _, rss in samples]
    return {
        'rss_start': samples[0][1],
        'rss_end':   samples[-1][1],
        'rss_peak':  max(rss_vals),
        'rss_min':   min(rss_vals),
        'rss_delta': samples[-1][1] - samples[0][1],
    }

print(f"[corr] parsed {len(strace_events)} strace events")
if not strace_events:
    with open(out_json, 'w') as f:
        json.dump([], f)
    sys.exit(0)

min_ts = min(e['ts'] for e in strace_events)
max_ts = max(e['ts'] for e in strace_events)
total_span = max_ts - min_ts or 1

# ── 2. Parse puppet.log for resource boundary lines ──────────────────────
# --evaltrace emits per-resource Info lines (preferred — covers ALL resources):
#   Info: /Stage[main]/M/File[/etc/foo]: Starting to evaluate the resource (N of T)
#   Info: /Stage[main]/M/File[/etc/foo]: Evaluated in 0.01 seconds
# Fallback: Notice: lines for changed resources only (no --evaltrace).
evaltrace_start_re = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Info:\s+(.*?):\s+Starting to evaluate the resource'
)
evaltrace_end_re = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Info:\s+(.*?):\s+Evaluated in ([\d.]+) seconds'
)
notice_re  = re.compile(
    r'^(?:\x1b\[[0-9;]*m)?Notice:\s+(/Stage\[.*?\]/[^:]+)(?::\s+(.*))?$'
)
applied_re = re.compile(r'Applied catalog in ([\d.]+) seconds')
config_re  = re.compile(r"Applying configuration version '(\d+)'")

config_version      = ''
apply_end_ts_offset = None

# evaltrace tracking: title → (start_idx, duration)
evaltrace_resources = []   # list of {title, canonical, duration, order}
_evaltrace_pending  = {}   # title → start_order (awaiting end line)
_evaltrace_order    = 0

# notice-only fallback
notice_resources = []

print(f"[corr] parsing puppet.log: {puppet_log}")
with open(puppet_log, errors='replace') as f:
    for lineno, line in enumerate(f, 1):
        line = line.rstrip()
        # strip ANSI for regex matching
        clean = re.sub(r'\x1b\[[0-9;]*m', '', line)

        m = evaltrace_start_re.match(clean)
        if m:
            raw_title = m.group(1).strip()
            canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])$', r'\1', raw_title)
            if canonical not in _evaltrace_pending:
                _evaltrace_pending[canonical] = _evaltrace_order
                _evaltrace_order += 1
            continue

        m = evaltrace_end_re.match(clean)
        if m:
            raw_title = m.group(1).strip()
            duration  = float(m.group(2))
            canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])$', r'\1', raw_title)
            order = _evaltrace_pending.pop(canonical, _evaltrace_order)
            evaltrace_resources.append({
                'title': canonical, 'raw': raw_title,
                'duration': duration, 'order': order,
            })
            continue

        m = notice_re.match(clean)
        if m:
            notice_resources.append({
                'lineno': lineno, 'resource': m.group(1), 'detail': m.group(2) or '',
            })

        m = applied_re.search(clean)
        if m:
            apply_end_ts_offset = float(m.group(1))
        m = config_re.search(clean)
        if m:
            config_version = m.group(1)

# Prefer evaltrace data; fall back to notice lines
use_evaltrace = len(evaltrace_resources) > 0
print(f"[corr] evaltrace resources: {len(evaltrace_resources)}, notice lines: {len(notice_resources)}")
print(f"[corr] using {'evaltrace' if use_evaltrace else 'notice fallback'} for time windows")

# ── 3. Load resource-report.json ─────────────────────────────────────────
with open(resource_report) as f:
    rr = json.load(f)

rr_by_title = {r['title']: r for r in rr.get('resources', [])}

# ── 4. Build resource time windows ───────────────────────────────────────
# evaltrace path: use reported per-resource durations, anchored to strace span.
# The evaltrace durations sum to the catalog application time. We anchor the
# first resource to min_ts (strace start) and accumulate durations forward.
# This gives accurate per-resource strace windows even for unchanged resources.
#
# Fallback (no evaltrace): assign windows proportionally by log line position.

windows = []

if use_evaltrace:
    evaltrace_resources.sort(key=lambda r: r['order'])
    # Find approximate start of catalog application in strace timeline.
    # Use min_ts + (total_span - sum_of_durations) as offset, clamped to min_ts.
    total_eval_time = sum(r['duration'] for r in evaltrace_resources)
    catalog_start_ts = max(min_ts, max_ts - total_eval_time - 0.5)
    t_cursor = catalog_start_ts
    for res in evaltrace_resources:
        t_start   = t_cursor
        t_end     = t_cursor + max(res['duration'], 0.0005)
        t_cursor  = t_end
        canonical = res['title']
        rr_entry  = rr_by_title.get(canonical, {})
        # merge notice detail if available
        notice_detail = next(
            (n['detail'] for n in notice_resources
             if canonical in n['resource']),
            ''
        )
        windows.append({
            'title':    canonical,
            'raw':      res['raw'],
            'detail':   notice_detail,
            't_start':  t_start,
            't_end':    t_end,
            'duration': res['duration'],
            'rr':       rr_entry,
        })
else:
    # Notice-only fallback (unchanged from original)
    total_lines = len(notice_resources) or 1
    def line_to_ts(lineno):
        frac = lineno / (notice_resources[-1]['lineno'] if notice_resources else 1)
        return min_ts + frac * total_span
    for i, rl in enumerate(notice_resources):
        t_start = min_ts if i == 0 else line_to_ts(notice_resources[i-1]['lineno'])
        t_end   = line_to_ts(rl['lineno'])
        title   = rl['resource']
        canonical = re.sub(r'^.*/([A-Z][^/]+\[[^\]]+\])(?:/.*)?$', r'\1', title)
        rr_entry  = rr_by_title.get(canonical, rr_by_title.get(title, {}))
        windows.append({
            'title': canonical, 'raw': title, 'detail': rl['detail'],
            't_start': t_start, 't_end': t_end,
            'duration': t_end - t_start, 'rr': rr_entry,
        })

# ── 5. Correlate strace events to resource windows ────────────────────────
# Track pid→exe via execve
pid_exe   = {}   # pid → exe path
pid_args  = {}   # pid → args list

# Pre-pass: collect execve
for ev in strace_events:
    if ev['syscall'] == 'execve' and ev['args']:
        pid_exe[ev['pid']]  = ev['args'][0] if ev['args'] else ev['path']
        pid_args[ev['pid']] = ev['args']

correlated = []
for w in windows:
    t0, t1 = w['t_start'], w['t_end']
    if t1 <= t0:
        t1 = t0 + 0.001  # minimum window

    # collect events in window
    evs_in = [e for e in strace_events if t0 <= e['ts'] < t1]

    # aggregate writes/reads per path
    files_written = collections.defaultdict(lambda: {'bytes': 0, 'ops': 0})
    files_read    = collections.defaultdict(lambda: {'bytes': 0, 'ops': 0})
    net_conns     = {}
    pids_seen     = set()
    bytes_written = 0
    bytes_read    = 0

    for ev in evs_in:
        pids_seen.add(ev['pid'])
        sc  = ev['syscall']
        rv  = ev['retval']
        pth = ev['path']

        if sc in ('write', 'sendto') and rv > 0 and pth:
            files_written[pth]['bytes'] += rv
            files_written[pth]['ops']   += 1
            bytes_written += rv
        elif sc in ('read', 'recvfrom') and rv > 0 and pth:
            files_read[pth]['bytes'] += rv
            files_read[pth]['ops']   += 1
            bytes_read += rv
        elif sc == 'connect' and ev['remote']:
            net_conns[ev['remote']] = {'remote': ev['remote'], 'direction': 'outbound'}

    # build process list
    processes = []
    for pid in pids_seen:
        exe  = pid_exe.get(pid, f'pid:{pid}')
        args = pid_args.get(pid, [])
        # sum bytes for this pid
        pw = sum(e['retval'] for e in evs_in
                 if e['pid'] == pid and e['syscall'] in ('write','sendto') and e['retval'] > 0)
        pr = sum(e['retval'] for e in evs_in
                 if e['pid'] == pid and e['syscall'] in ('read','recvfrom') and e['retval'] > 0)
        processes.append({'pid': pid, 'exe': exe, 'args': args,
                          'bytes_written': pw, 'bytes_read': pr})

    rr_entry = w['rr']
    rss = rss_for_window(t0, t1, proc_poll)
    correlated.append({
        'title':              w['title'],
        'type':               rr_entry.get('type', w['title'].split('[')[0] if '[' in w['title'] else ''),
        'duration_s':         round(w['duration'], 4),
        'status':             rr_entry.get('status', 'unknown'),
        'before':             rr_entry.get('before'),
        'after':              rr_entry.get('after'),
        'evaluation_time':    rr_entry.get('evaluation_time', 0),
        'parameters':         rr_entry.get('parameters') or {},
        'file':               rr_entry.get('file') or '',
        'line':               rr_entry.get('line') or '',
        'processes':          processes,
        'files_written':      [{'path': p, **v} for p, v in
                               sorted(files_written.items(), key=lambda x: -x[1]['bytes'])],
        'files_read':         [{'path': p, **v} for p, v in
                               sorted(files_read.items(), key=lambda x: -x[1]['bytes'])],
        'network_connections': list(net_conns.values()),
        'disk_bytes_written': bytes_written,
        'disk_bytes_read':    bytes_read,
        'strace_events':      len(evs_in),
        't_start':            t0,
        't_end':              t1,
        **rss,
    })

# ── Feature 9: Augeas lens detection per resource ────────────────────────────
def count_augeas_lenses(events_for_window):
    """Count augeas lens file opens — indicates no incl: guard."""
    return sum(1 for e in events_for_window
               if '/augeas/lenses/' in e.get('path', '') or '/usr/share/augeas/' in e.get('path', ''))

# ── Feature 7: HTTP phase decomposition from strace sendto/write buffers ──────
def parse_http_phases(strace_events_list, run_start_ts):
    """Extract HTTP phase timing from strace sendto/write buffers."""
    phases = []
    http_verb_re = re.compile(r'(GET|POST|PUT|DELETE)\s+(/puppet/v3/\S+)\s+HTTP')
    ts_re = re.compile(r'^(\d+\.\d+)')

    for ev in strace_events_list:
        if ev['syscall'] not in ('sendto', 'write'):
            continue
        path = ev.get('path', '')
        # strace with -s 0 captures full payload in path field for sendto
        hm = http_verb_re.search(path)
        if not hm:
            continue
        verb = hm.group(1)
        url_path = hm.group(2)
        ts = ev['ts']
        if '/node' in url_path:
            phase = 'node_classify'
        elif '/catalog' in url_path and verb == 'POST':
            phase = 'catalog_request'
        elif '/file_metadata' in url_path or '/file_content' in url_path:
            phase = 'file_resource'
        elif '/report' in url_path and verb == 'PUT':
            phase = 'report_submit'
        elif '/facts' in url_path:
            phase = 'facts_upload'
        else:
            phase = 'other_http'
        phases.append({'ts': ts - run_start_ts, 'phase': phase, 'verb': verb, 'path': url_path})
    return phases

http_phases = parse_http_phases(strace_events, min_ts)
print(f"[corr] HTTP phases detected: {len(http_phases)}")

# Augeas + re-correlate to add augeas_lens_count per resource
# Build per-window event lists for augeas counting
for i, w in enumerate(windows):
    t0, t1 = w['t_start'], w['t_end']
    if t1 <= t0:
        t1 = t0 + 0.001
    evs_in = [e for e in strace_events if t0 <= e['ts'] < t1]
    correlated[i]['augeas_lens_count'] = count_augeas_lenses(evs_in)

# sort by disk_bytes_written desc for summary
correlated.sort(key=lambda r: -r['disk_bytes_written'])

total_strace_events = len(strace_events)
print(f"[corr] correlated {len(correlated)} resources, {total_strace_events} strace events total")

output_data = {
    'resources': correlated,
    'http_phases': http_phases,
}

with open(out_json, 'w') as f:
    json.dump(correlated, f, indent=2, default=str)
# Also save http_phases separately for the report
import os as _os
http_phases_path = _os.path.join(_os.path.dirname(out_json), 'http-phases.json')
with open(http_phases_path, 'w') as f:
    json.dump(http_phases, f, indent=2)
print(f"[corr] written: {out_json}")
print(f"[corr] http-phases: {http_phases_path}")
PYEOF
    echo "[puppet-trace] strace correlation done: $IO_CORR_JSON"
}

###############################################################################
# FLAMEGRAPH (once mode — perf/stack-based)
###############################################################################
generate_flamegraph() {
    if $HAS_PERF && $IS_ROOT && [[ -f "$PERF_DATA" ]]; then
        echo "[puppet-trace] generating flamegraph from perf data..."
        if $HAS_STACKCOLLAPSE && $HAS_FLAMEGRAPH; then
            perf script -i "$PERF_DATA" 2>/dev/null \
                | stackcollapse-perf.pl 2>/dev/null \
                | flamegraph.pl 2>/dev/null \
                >"$FLAMEGRAPH_SVG" || true
            [[ -s "$FLAMEGRAPH_SVG" ]] && { echo "[puppet-trace] flamegraph generated: $FLAMEGRAPH_SVG"; return; }
        fi
    fi

    if [[ -s "$STACK_LOG" ]]; then
        echo "[puppet-trace] generating stack summary from /proc stack samples..."
        python3 - "$STACK_LOG" "$FLAMEGRAPH_SVG" <<'PYEOF'
import sys, re, collections, html

stack_log = sys.argv[1]
svg_out = sys.argv[2]

stacks = []
current = []
with open(stack_log) as f:
    for line in f:
        line = line.rstrip()
        if line == '---':
            if current:
                stacks.append(list(reversed(current)))
            current = []
        else:
            m = re.match(r'\[\d+\]\s+\[<[0-9a-f]+>\]\s+(\S+)', line)
            if m:
                current.append(m.group(1))
            elif line.strip():
                current.append(line.strip())
if current:
    stacks.append(list(reversed(current)))

counter = collections.Counter()
for s in stacks:
    counter[';'.join(s)] += 1

total = sum(counter.values()) or 1
rows = sorted(counter.items(), key=lambda x: -x[1])[:30]

lines = []
lines.append('<svg xmlns="http://www.w3.org/2000/svg" width="900" height="{}" viewBox="0 0 900 {}">'.format(
    30 + len(rows) * 22, 30 + len(rows) * 22))
lines.append('<rect width="900" height="{}" fill="#f8f8f8"/>'.format(30 + len(rows) * 22))
lines.append('<text x="10" y="18" font-family="monospace" font-size="13" font-weight="bold">Kernel Stack Samples (top {} unique stacks, {} total samples)</text>'.format(len(rows), total))

for i, (stack, count) in enumerate(rows):
    y = 32 + i * 22
    pct = count / total * 100
    bar_w = int(pct / 100 * 600)
    color = "#4a90d9" if i % 2 == 0 else "#357abd"
    frame = html.escape(stack.split(';')[-1][:60] if stack else '(unknown)')
    lines.append('<rect x="10" y="{}" width="{}" height="18" fill="{}"/>'.format(y, bar_w, color))
    lines.append('<text x="{}" y="{}" font-family="monospace" font-size="11" fill="#222">{:.1f}% ({}) {}</text>'.format(
        bar_w + 16, y + 13, pct, count, frame))

lines.append('</svg>')

with open(svg_out, 'w') as f:
    f.write('\n'.join(lines))
print("stack summary SVG written:", svg_out)
PYEOF
    fi
}

###############################################################################
# PROFILE FLAMEGRAPH (once mode)
###############################################################################
collect_profile_flamegraph() {
    # puppet apply compiles locally — no puppetserver PROFILE log
    if [[ "${PUPPET_CMD[*]}" =~ puppet[[:space:]]apply ]]; then
        echo "[puppet-trace] puppet apply — skipping puppetserver profile log (compiled locally)"
        return 0
    fi

    local start_iso="${RUN_START_ISO:-}"
    local puppet_server ssh_key _ssh_opts
    puppet_server=$(puppet config print server 2>/dev/null | tr -d '\n' || true)
    [[ -z "$puppet_server" ]] && puppet_server="$(hostname -f 2>/dev/null || hostname)"
    _validate_puppet_id "$puppet_server" "puppet_server" || puppet_server=""
    [[ -z "$puppet_server" ]] && { echo "[puppet-trace] ERROR: could not determine puppet server for profile flamegraph" >&2; return 1; }
    local _ssh_user2="${PUPPET_TRACE_SSH_USER:-${SUDO_USER:-puppet}}"
    # When running via sudo, $HOME is /root but the invoking user's key
    # is the one authorised on the puppet server. Fall through:
    # 1. PUPPET_TRACE_SSH_KEY env var (explicit override)
    # 2. $HOME/.ssh/id_ed25519 (works for direct root or explicit sudo -E)
    # 3. SUDO_USER's home key (sudo without -E; most common case)
    local _sudo_user_key=""
    if [[ -n "${SUDO_USER:-}" ]]; then
        local _sudo_home
        _sudo_home=$(getent passwd "$SUDO_USER" 2>/dev/null | cut -d: -f6 || true)
        [[ -n "$_sudo_home" ]] && _sudo_user_key="${_sudo_home}/.ssh/id_ed25519"
    fi
    local _fg_default_key="${HOME:-/root}/.ssh/id_ed25519"
    if [[ ! -f "$_fg_default_key" ]] && [[ -f "${_sudo_user_key:-}" ]]; then
        _fg_default_key="$_sudo_user_key"
    fi
    ssh_key="${PUPPET_TRACE_SSH_KEY:-${_fg_default_key}}"
    if [[ -n "${PUPPET_TRACE_SSH_KEY:-}" ]]; then
        _validate_ssh_key_path "$ssh_key" "$_fg_default_key" || ssh_key="$_fg_default_key"
    fi
    # If PUPPET_TRACE_SERVER_CONTAINER not set explicitly, query puppet-trace-server
    # for the container name it knows about (avoids hardcoding runecorps-puppetserver).
    local _server_container2="${PUPPET_TRACE_SERVER_CONTAINER:-}"
    if [[ -z "$_server_container2" ]] && [[ -n "${PUSH_SERVER:-}" ]]; then
        _server_container2=$(curl -sf --max-time 3 \
            "http://${PUSH_SERVER}/api/profiling/status" \
            2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('container_name',''))" 2>/dev/null || true)
    fi
    [[ -z "$_server_container2" ]] && _server_container2="${PUPPET_TRACE_SERVER_CONTAINER:-puppetserver}"
    _validate_puppet_id "${_server_container2}" "PUPPET_TRACE_SERVER_CONTAINER" || return
    _validate_puppet_id "${_ssh_user2}" "PUPPET_TRACE_SSH_USER" || return
    mkdir -m 0755 -p /var/log/puppet-trace/
    local _fg_strict_host="${PUPPET_TRACE_STRICT_HOST_KEY:-accept-new}"
    case "$_fg_strict_host" in
        yes|accept-new|no) ;;
        *) echo "[puppet-trace] WARNING: invalid PUPPET_TRACE_STRICT_HOST_KEY '$_fg_strict_host' — using accept-new" >&2
           _fg_strict_host="accept-new" ;;
    esac
    if [[ "$_fg_strict_host" == "accept-new" ]]; then
        echo "[puppet-trace] WARNING: StrictHostKeyChecking=accept-new (TOFU). Set PUPPET_TRACE_STRICT_HOST_KEY=yes for production." >&2
    fi
    _ssh_opts=(-o ConnectTimeout=10 -o BatchMode=yes -o "StrictHostKeyChecking=${_fg_strict_host}" -o UserKnownHostsFile=/var/log/puppet-trace/.ssh_known_hosts)
    [[ -f "$ssh_key" ]] && _ssh_opts+=(-i "$ssh_key")

    if [[ -n "$start_iso" ]] && [[ ! "$start_iso" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z?$ ]]; then
        echo "[puppet-trace] WARNING: start_iso has unexpected format, ignoring: $start_iso" >&2
        start_iso=""
    fi

    echo "[puppet-trace] fetching PROFILE entries from puppetserver (${puppet_server}) docker logs since ${start_iso}..."

    if [[ -n "$start_iso" ]]; then
        ssh "${_ssh_opts[@]}" "${_ssh_user2}@${puppet_server}" \
            "docker logs ${_server_container2} --since '${start_iso}' 2>&1 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    else
        ssh "${_ssh_opts[@]}" "${_ssh_user2}@${puppet_server}" \
            "docker logs ${_server_container2} 2>&1 | tail -5000 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    fi

    _generate_profile_flamegraph "$PROFILE_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$SCRIPT_DIR" || true
