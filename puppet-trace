###############################################################################
# SUBCOMMAND: report — regenerate HTML from existing outdir
# (defined here so generate_report / run_strace_correlation / etc. are in scope)
###############################################################################
cmd_report() {
    local outdir="${1:-}"
    if [[ -z "$outdir" ]]; then
        outdir=$(ls -dt /var/log/puppet-trace/*/ 2>/dev/null | head -1)
        [[ -n "$outdir" ]] || { echo "report: no outdir found under /var/log/puppet-trace/" >&2; exit 1; }
        echo "[puppet-trace report] using latest outdir: $outdir"
    fi
    [[ -d "$outdir" ]] || { echo "report: not a directory: $outdir" >&2; exit 1; }
    outdir="${outdir%/}"
    _validate_safe_path "$outdir" "outdir" || exit 1

    local meta="$outdir/run-meta.json"
    WALL_SECONDS=0; PUPPET_EXIT=0; PUPPET_CMD_META="puppet agent --test"
    IDEMPOTENCY_PASS=unknown; IDEMPOTENCY_CHANGES=0; RUN_START_ISO=""
    if [[ -f "$meta" ]]; then
        WALL_SECONDS=$(python3 -c "import json; d=json.load(open('$meta')); print(int(d.get('wall_seconds',0)))" 2>/dev/null || echo 0)
        PUPPET_EXIT=$(python3 -c "import json; d=json.load(open('$meta')); print(int(d.get('puppet_exit',0)))" 2>/dev/null || echo 0)
        PUPPET_CMD_META=$(python3 -c "import json; d=json.load(open('$meta')); print(d.get('puppet_cmd','puppet agent --test'))" 2>/dev/null || echo "puppet agent --test")
        IDEMPOTENCY_PASS=$(python3 -c "import json; d=json.load(open('$meta')); print(d.get('idempotency_pass','unknown'))" 2>/dev/null || echo "unknown")
        IDEMPOTENCY_CHANGES=$(python3 -c "import json; d=json.load(open('$meta')); print(int(d.get('idempotency_changes',0)))" 2>/dev/null || echo 0)
        RUN_START_ISO=$(python3 -c "import json; d=json.load(open('$meta')); print(d.get('run_start_iso',''))" 2>/dev/null || echo "")
    else
        echo "[puppet-trace report] WARNING: run-meta.json not found in $outdir — using defaults" >&2
    fi

    # Validate ISO date format before use in SSH --since arg
    if [[ -n "$RUN_START_ISO" ]] && [[ ! "$RUN_START_ISO" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z?$ ]]; then
        echo "[puppet-trace] WARNING: run_start_iso has unexpected format, ignoring: $RUN_START_ISO" >&2
        RUN_START_ISO=""
    fi

    OUTDIR="$outdir"
    PUPPET_LOG="$outdir/puppet.log"
    PROC_LOG="$outdir/proc-poll.log"
    NET_LOG="$outdir/net-poll.log"
    STRACE_LOG="$outdir/strace.log"
    INOTIFY_LOG="$outdir/inotify.log"
    FLAMEGRAPH_SVG="$outdir/flamegraph.svg"
    PROFILE_FLAMEGRAPH_SVG="$outdir/flamegraph-profile.svg"
    PROFILE_LOG="$outdir/puppetserver-profile.log"
    STRACE_RAW="$outdir/strace.raw"
    IO_CORR_JSON="$outdir/io-correlation.json"
    IDEMPOTENCY_STDOUT="$outdir/idempotency.stdout"
    REPORT_HTML="$outdir/report.html"
    read -r -a PUPPET_CMD <<< "$PUPPET_CMD_META"

    if [[ ! -s "$PROFILE_FLAMEGRAPH_SVG" ]] && [[ -s "$PROFILE_LOG" ]]; then
        echo "[puppet-trace report] profile.log present but flamegraph SVG missing — regenerating..."
        _generate_profile_flamegraph "$PROFILE_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$SCRIPT_DIR" || true
    fi
    if [[ ! -f "$IO_CORR_JSON" ]] && [[ -f "$STRACE_RAW" ]]; then
        echo "[puppet-trace report] strace.raw present but io-correlation.json missing — re-correlating..."
        run_strace_correlation || true
    fi
    if [[ ! -s "$FLAMEGRAPH_SVG" ]]; then
        generate_flamegraph || true
    fi

    echo "[puppet-trace report] generating HTML from $outdir..."
    generate_report
    echo "[puppet-trace report] done"
    echo "Report: $REPORT_HTML"
}

###############################################################################
# SUBCOMMAND: ship — rsync outdir to remote + regenerate report there
###############################################################################
cmd_ship() {
    local outdir="${1:-}"
    local remote="${2:-}"
    if [[ -z "$outdir" ]] || [[ -z "$remote" ]]; then
        echo "Usage: puppet-trace ship <outdir> <[user@]host:path> [--include-strace]" >&2
        echo "  Ships artifacts (excl. strace.raw/perf.data) then runs: puppet-trace report <path>" >&2
        exit 1
    fi
    shift 2
    [[ -d "$outdir" ]] || { echo "ship: not a directory: $outdir" >&2; exit 1; }
    outdir="${outdir%/}"
    _validate_safe_path "$outdir" "outdir" || exit 1

    local include_strace=false rsync_extra=()
    for arg in "$@"; do
        if [[ "$arg" == "--include-strace" ]]; then
            include_strace=true
        else
            # Whitelist safe rsync args; reject dangerous flags
            case "$arg" in
                --checksum|--compress|-z|-c|--progress|--verbose|-v|--dry-run|-n)
                    rsync_extra+=("$arg") ;;
                --bwlimit=*|--timeout=*)
                    rsync_extra+=("$arg") ;;
                *)
                    echo "[puppet-trace] ship: ignoring unrecognized/unsafe arg: $arg" >&2 ;;
            esac
        fi
    done

    local remote_host="${remote%%:*}"
    local remote_path="${remote#*:}"
    [[ "$remote_path" == "$remote_host" ]] && { echo "ship: remote must be [user@]host:path" >&2; exit 1; }
    _validate_safe_path "$remote_path" "remote path" || exit 1

    local exclude_args=(--exclude='strace.raw' --exclude='perf.data')
    $include_strace && exclude_args=()

    echo "[puppet-trace ship] $outdir → $remote (${exclude_args[*]:-no exclusions})"
    rsync -av --progress "${exclude_args[@]}" "${rsync_extra[@]}" "$outdir/" "${remote}/"
    echo "[puppet-trace ship] synced — running report on $remote_host..."
    ssh "$remote_host" puppet-trace report -- "$remote_path"
    echo "[puppet-trace ship] done — report at $remote_host:${remote_path}/report.html"
}

###############################################################################
# LATE DISPATCH — report/ship need functions defined above; handled here
###############################################################################
if [[ -n "${_LATE_SUBCMD:-}" ]]; then
    "cmd_${_LATE_SUBCMD}" "${_LATE_ARGS[@]}"
    exit $?
fi

###############################################################################
