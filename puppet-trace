    proc_lines.append(f"{ts} {elapsed} {rss} {vmpeak} {vmswap} {cpu_ticks}")
with open(os.path.join(outdir, "proc-poll.log"), "w") as f:
    f.write("\n".join(proc_lines) + "\n")

# ---------------------------------------------------------------------------
# 5. proc-io-poll.log  (100 lines, every 0.5s)
# ---------------------------------------------------------------------------
def sigmoidal(x, center, width, total):
    return total / (1 + math.exp(-(x - center) / width))

io_lines = []
for i in range(100):
    ts_ms = int((BASE_TS + i * 0.5) * 1000)
    t = i * 0.5
    # Two write spikes: around t=14s and t=22s
    w1 = sigmoidal(t, 14.0, 1.5, 120 * 1024 * 1024)
