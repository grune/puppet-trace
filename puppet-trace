#!/usr/bin/env bash
# puppet-trace — unified puppet process monitor/tracer with postrun_command support
#
# Subcommands:
#   puppet-trace enable          touch /etc/puppet-trace.enabled; install postrun in puppet.conf
#   puppet-trace disable         rm /etc/puppet-trace.enabled; remove postrun from puppet.conf
#   puppet-trace once            one-shot trace run (old behaviour), ignores flag file
#   puppet-trace status          show enabled/disabled, last report path
#   puppet-trace collect <args>  internal: called by puppet as postrun_command
#
# Legacy (no subcommand) behaves like 'once'.
#
# Requires: bash 4+, python3, /proc filesystem
# Optional: strace, perf, inotifywait, flamegraph.pl, stackcollapse-perf.pl,
#           puppet-profile-parser.rb, ruby

set -euo pipefail

_validate_puppet_id() {
    local val="$1" name="$2"
    if [[ ! "$val" =~ ^[a-zA-Z0-9._:-]+$ ]]; then
        echo "[puppet-trace] ERROR: $name contains invalid characters: '$val'" >&2
        return 1
    fi
}

_validate_safe_path() {
    local val="$1" name="${2:-path}"
    if [[ "$val" == *"'"* ]] || [[ "$val" == *'"'* ]] || [[ "$val" == *$'\n'* ]] || [[ "$val" == *$'\r'* ]]; then
        echo "[puppet-trace] ERROR: $name contains unsafe characters (quotes/newlines): '$val'" >&2
        return 1
    fi
    # Block path traversal
    if [[ "$val" == *"/../"* ]] || [[ "$val" == *"/.."  ]] || [[ "$val" == "../"* ]]; then
        echo "[puppet-trace] ERROR: $name contains path traversal: '$val'" >&2
        return 1
    fi
}

# Cleanup trap — kill background processes on exit/interrupt
_PT_CLEANUP_PIDS=()
_pt_cleanup() {
    local sig="${1:-EXIT}"
    for pid in "${_PT_CLEANUP_PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
    done
    # Restart puppet service if we stopped it
    if [[ "${_PT_STOPPED_PUPPET:-false}" == "true" ]]; then
        systemctl start puppet 2>/dev/null || true
    fi
}
trap '_pt_cleanup INT'  INT
trap '_pt_cleanup TERM' TERM
trap '_pt_cleanup EXIT' EXIT

export PATH="/opt/puppetlabs/bin:/opt/puppetlabs/puppet/bin:$PATH"

###############################################################################
# CONSTANTS
###############################################################################
FLAG_FILE="/etc/puppet-trace.enabled"
PUPPET_CONF="/etc/puppetlabs/puppet/puppet.conf"
POSTRUN_CMD="/usr/local/bin/puppet-trace collect"
TRACE_LOG="/var/log/puppet-trace.log"
SCRIPT_PATH="$(readlink -f "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

###############################################################################
# SUBCOMMAND: enable
###############################################################################
cmd_enable() {
    if [[ $EUID -ne 0 ]]; then
        echo "puppet-trace enable: must run as root" >&2
        exit 1
    fi

    touch "$FLAG_FILE"
    echo "[puppet-trace] flag file: $FLAG_FILE created"

    # Idempotently insert postrun_command under [agent] in puppet.conf
    if [[ ! -f "$PUPPET_CONF" ]]; then
        echo "[puppet-trace] WARNING: $PUPPET_CONF not found — cannot install postrun_command" >&2
    else
        # Remove any existing puppet-trace postrun line first (idempotent)
        sed -i "/postrun_command\s*=\s*\/usr\/local\/bin\/puppet-trace collect/d" "$PUPPET_CONF"

        # Check if [agent] section exists
        if grep -q '^\[agent\]' "$PUPPET_CONF"; then
            # Insert postrun_command after [agent]
            sed -i '/^\[agent\]/a\    postrun_command = /usr/local/bin/puppet-trace collect' "$PUPPET_CONF"
            echo "[puppet-trace] postrun_command inserted under [agent] in $PUPPET_CONF"
        else
            # Append [agent] section
            printf '\n[agent]\n    postrun_command = /usr/local/bin/puppet-trace collect\n' >> "$PUPPET_CONF"
            echo "[puppet-trace] [agent] section added to $PUPPET_CONF with postrun_command"
        fi
    fi

    echo "[puppet-trace] enabled — next daemon puppet run will call: $POSTRUN_CMD"
    cmd_status
}

###############################################################################
# SUBCOMMAND: disable
###############################################################################
cmd_disable() {
    if [[ $EUID -ne 0 ]]; then
        echo "puppet-trace disable: must run as root" >&2
        exit 1
    fi

    rm -f "$FLAG_FILE"
    echo "[puppet-trace] flag file removed"

    if [[ -f "$PUPPET_CONF" ]]; then
        sed -i "/postrun_command\s*=\s*\/usr\/local\/bin\/puppet-trace collect/d" "$PUPPET_CONF"
        echo "[puppet-trace] postrun_command removed from $PUPPET_CONF"
    fi

    echo "[puppet-trace] disabled"
}

###############################################################################
# SUBCOMMAND: status
###############################################################################
cmd_status() {
    if [[ -f "$FLAG_FILE" ]]; then
        echo "puppet-trace: ENABLED (flag: $FLAG_FILE)"
    else
        echo "puppet-trace: DISABLED (flag not present: $FLAG_FILE)"
    fi

    # Show postrun_command state in puppet.conf
    if [[ -f "$PUPPET_CONF" ]]; then
        if grep -q "postrun_command.*puppet-trace" "$PUPPET_CONF"; then
            echo "puppet.conf: postrun_command = /usr/local/bin/puppet-trace collect [present]"
        else
            echo "puppet.conf: postrun_command [absent]"
        fi
    else
        echo "puppet.conf: $PUPPET_CONF not found"
    fi

    # Last report
    if [[ -f "$TRACE_LOG" ]]; then
        local last
        last=$(tail -1 "$TRACE_LOG" 2>/dev/null || true)
        if [[ -n "$last" ]]; then
            echo "Last report: $last"
        fi
    else
        echo "No reports yet (log: $TRACE_LOG)"
    fi
}

###############################################################################
# SUBCOMMAND: collect
# Called by puppet daemon as postrun_command after each run.
# Puppet sets $PUPPET_TRANSACTION_UUID in environment.
###############################################################################
cmd_collect() {
    # Safety net
    if [[ ! -f "$FLAG_FILE" ]]; then
        echo "[puppet-trace collect] flag file not present — bailing" >&2
        exit 0
    fi

    local transaction_uuid="${PUPPET_TRANSACTION_UUID:-}"
    # Validate UUID format (allow empty)
    if [[ -n "$transaction_uuid" ]] && [[ ! "$transaction_uuid" =~ ^[a-fA-F0-9-]+$ ]]; then
        echo "[puppet-trace] WARNING: PUPPET_TRANSACTION_UUID has unexpected format, ignoring" >&2
        transaction_uuid=""
    fi
    local TIMESTAMP
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    local OUTDIR="/var/log/puppet-trace/${TIMESTAMP}"
    mkdir -m 0700 -p "$OUTDIR"

    local PUPPET_LOG="$OUTDIR/puppet.log"
    local PROFILE_LOG="$OUTDIR/puppetserver-profile.log"
    local PROFILE_FLAMEGRAPH_SVG="$OUTDIR/flamegraph-profile.svg"
    local PROC_LOG="$OUTDIR/proc-poll.log"
    local REPORT_HTML="$OUTDIR/report.html"

    echo "[puppet-trace collect] transaction_uuid=$transaction_uuid outdir=$OUTDIR"

    # ── Fetch puppet output from journald ─────────────────────────
    # puppet daemon logs to syslog/journald; try journalctl first, then skip
    if command -v journalctl &>/dev/null; then
        journalctl -u puppet --since "10 minutes ago" --no-pager -q 2>/dev/null \
            > "$PUPPET_LOG" || true
    fi

    # ── Fetch PROFILE entries from puppetserver logs ────────────────
    local since_arg=""
    local window_min=10
    local start_iso
    start_iso=$(date -d "${window_min} minutes ago" +%Y-%m-%dT%H:%M:%S 2>/dev/null \
        || date -u -d "@$(($(date +%s) - window_min * 60))" +%Y-%m-%dT%H:%M:%S 2>/dev/null \
        || "")

    if [[ -n "$start_iso" ]] && [[ ! "$start_iso" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z?$ ]]; then
        echo "[puppet-trace] WARNING: start_iso has unexpected format, ignoring: $start_iso" >&2
        start_iso=""
    fi

    if [[ -n "$start_iso" ]]; then
        since_arg="$start_iso"
    fi

    local puppet_server
    puppet_server=$(puppet config print server 2>/dev/null | tr -d '\n' || true)
    [[ -z "$puppet_server" ]] && puppet_server="$(hostname -f 2>/dev/null || hostname)"
    _validate_puppet_id "$puppet_server" "puppet_server" || puppet_server=""
    [[ -z "$puppet_server" ]] && { echo "[puppet-trace] ERROR: could not determine puppet server" >&2; return 1; }

    local _ssh_user="${PUPPET_TRACE_SSH_USER:-puppet}"
    local _ssh_key="${PUPPET_TRACE_SSH_KEY:-${HOME}/.ssh/id_ed25519}"
    local _server_container="${PUPPET_TRACE_SERVER_CONTAINER:-puppetserver}"
    _validate_puppet_id "${_server_container}" "PUPPET_TRACE_SERVER_CONTAINER" || return
    _validate_puppet_id "${_ssh_user}" "PUPPET_TRACE_SSH_USER" || return
    mkdir -m 0700 -p /var/log/puppet-trace/
    local _ssh_c_opts=(-o ConnectTimeout=10 -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/var/log/puppet-trace/.ssh_known_hosts)
    [[ -f "$_ssh_key" ]] && _ssh_c_opts+=(-i "$_ssh_key")

    echo "[puppet-trace collect] fetching PROFILE entries from $puppet_server since ${since_arg:-last 5000 lines}..."

    if [[ -n "$since_arg" ]]; then
        ssh "${_ssh_c_opts[@]}" "${_ssh_user}@${puppet_server}" \
            "docker logs ${_server_container} --since '${since_arg}' 2>&1 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    else
        ssh "${_ssh_c_opts[@]}" "${_ssh_user}@${puppet_server}" \
            "docker logs ${_server_container} 2>&1 | tail -5000 | grep PROFILE" \
            > "$PROFILE_LOG" 2>/dev/null || true
    fi

    local profile_line_count=0
    profile_line_count=$(wc -l < "$PROFILE_LOG" 2>/dev/null || echo 0)
    echo "[puppet-trace collect] PROFILE entries: $profile_line_count"

    # ── /proc snapshot of puppet PID (best-effort) ─────────────────
    local puppet_pid=""
    puppet_pid=$(pgrep -f "puppet agent" 2>/dev/null | head -1 || true)
    if [[ -n "$puppet_pid" ]] && [[ -r "/proc/$puppet_pid/status" ]]; then
        {
            echo "# puppet pid=$puppet_pid snapshot at $(date)"
            grep -E '^(VmRSS|VmPeak|VmSwap):' "/proc/$puppet_pid/status" 2>/dev/null || true
        } > "$PROC_LOG"
    else
        # fallback: ps snapshot
        ps aux 2>/dev/null | grep -E '[p]uppet' > "$PROC_LOG" || true
    fi

    # ── system context snapshot ────────────────────────────────────
    local SYSCTX="$OUTDIR/sysctx.txt"
    {
        echo "=== /proc/meminfo ==="
        cat /proc/meminfo 2>/dev/null || true
        echo "=== df -h ==="
        df -h 2>/dev/null || true
        echo "=== ss -tnp ==="
        ss -tnp 2>/dev/null || true
    } > "$SYSCTX" 2>/dev/null || true

    # ── parse last_run_report.yaml ─────────────────────────────────
    local LAST_RUN_REPORT_YAML="/opt/puppetlabs/puppet/cache/state/last_run_report.yaml"
    local LAST_RUN_SUMMARY_YAML="/opt/puppetlabs/puppet/cache/state/last_run_summary.yaml"
    local RESOURCE_REPORT_JSON="$OUTDIR/resource-report.json"
    if [[ -f "$LAST_RUN_REPORT_YAML" ]]; then
        local _rb_collect
        _rb_collect=$(mktemp "${OUTDIR}/puppet-trace-tmp.XXXXX.rb")
        cat > "$_rb_collect" << 'RUBYEOF_COLLECT'
require 'yaml'; require 'json'
report_path  = ARGV[0]
summary_path = ARGV[1]
out_path     = ARGV[2]

def load_yaml(path)
  return {} unless File.exist?(path.to_s)
  raw = File.read(path)
  clean = raw.gsub(/!ruby\/object:[^\s]+/, '!!map').gsub(/!ruby\/sym /, ':')
  YAML.safe_load(clean, permitted_classes: [Symbol, Time]) || {}
rescue => e
  STDERR.puts "[puppet-trace collect] YAML parse error #{path}: #{e}"
  {}
end

report  = load_yaml(report_path)
summary = load_yaml(summary_path)

resource_statuses = report['resource_statuses'] || {}
resources = []
resource_statuses.each do |res_title, info|
  next unless info.is_a?(Hash)
  status = 'unchanged'
  status = 'failed'      if info['failed']
  status = 'changed'     if info['changed']
  status = 'skipped'     if info['skipped']
  status = 'out_of_sync' if info['out_of_sync']
  events = Array(info['events'])
  before_val = after_val = nil
  events.each do |ev|
    next unless ev.is_a?(Hash)
    before_val = ev['previous_value'] if ev.key?('previous_value')
    after_val  = ev['desired_value']  if ev.key?('desired_value')
  end
  type = info['resource_type'] || (res_title.include?('[') ? res_title.split('[').first : '')
  resources << {
    'title'           => res_title,
    'type'            => type.to_s,
    'status'          => status,
    'evaluation_time' => (info['evaluation_time'] || 0).to_f,
    'changed'         => !!info['changed'],
    'failed'          => !!info['failed'],
    'skipped'         => !!info['skipped'],
    'before'          => before_val&.to_s,
    'after'           => after_val&.to_s,
  }
end

totals = {}
(report['metrics'] || {}).each do |cat, cat_data|
  next unless cat_data.is_a?(Hash)
  Array(cat_data['values']).each do |entry|
    next unless entry.is_a?(Array) && entry.size >= 3
    totals["#{cat}.#{entry[0]}"] = entry[2]
  end
end

result = {
  'resources'        => resources,
  'totals'           => totals,
  'certname'         => report['host'].to_s,
  'config_version'   => report['configuration_version'].to_s,
  'puppet_version'   => report['puppet_version'].to_s,
  'transaction_uuid' => report['transaction_uuid'].to_s,
  'status'           => report['status'].to_s,
  'noop'             => !!report['noop'],
  'summary'          => summary,
}
File.write(out_path, JSON.pretty_generate(result))
STDERR.puts "[puppet-trace collect] resource-report.json: #{resources.size} resources"
RUBYEOF_COLLECT
        /opt/puppetlabs/puppet/bin/ruby "$_rb_collect" \
            "$LAST_RUN_REPORT_YAML" "$LAST_RUN_SUMMARY_YAML" "$RESOURCE_REPORT_JSON" 2>&1
        rm -f "$_rb_collect"
    else
        echo "[puppet-trace collect] last_run_report.yaml not found at $LAST_RUN_REPORT_YAML" >&2
        echo '{"resources":[],"totals":{}}' > "$RESOURCE_REPORT_JSON"
    fi

    # ── Generate profile flamegraph ─────────────────────────────────
    local flamegraph_generated=false
    _generate_profile_flamegraph "$PROFILE_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$SCRIPT_DIR" \
        && flamegraph_generated=true || true

    # ── Generate report ─────────────────────────────────────────────
    local puppet_version="unknown"
    puppet_version=$(puppet --version 2>/dev/null | tr -d '\n' || echo "unknown")

    _generate_collect_report \
        "$OUTDIR" "$PUPPET_LOG" "$PROC_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$REPORT_HTML" \
        "$transaction_uuid" "$puppet_version" "$puppet_server" "$profile_line_count" \
        "$RESOURCE_REPORT_JSON" "$SYSCTX"

    # ── Log report path ─────────────────────────────────────────────
    echo "$REPORT_HTML" >> "$TRACE_LOG" 2>/dev/null || true

    echo "[puppet-trace collect] done"
    echo "Report: $REPORT_HTML"
    echo "PROFILE entries: $profile_line_count"
    if $flamegraph_generated; then
        echo "Flamegraph: yes ($PROFILE_FLAMEGRAPH_SVG)"
    else
        echo "Flamegraph: no"
    fi
}

###############################################################################
# SHARED: profile flamegraph generation
###############################################################################
_generate_profile_flamegraph() {
    local profile_log="$1"
    local svg_out="$2"
    local script_dir="$3"

    local parser="${script_dir}/vendor/flamegraph/puppet-profile-parser.rb"
    local flamegraph_pl="${script_dir}/vendor/flamegraph/flamegraph.pl"

    # Fallback to PATH
    command -v puppet-profile-parser.rb &>/dev/null \
        && parser=$(command -v puppet-profile-parser.rb)
    command -v flamegraph.pl &>/dev/null \
        && flamegraph_pl=$(command -v flamegraph.pl)

    if [[ ! -x "$parser" ]] || [[ ! -x "$flamegraph_pl" ]]; then
        echo "[puppet-trace] puppet-profile-parser or flamegraph.pl not found — skipping" >&2
        return 1
    fi
    if ! command -v ruby &>/dev/null; then
        echo "[puppet-trace] ruby not found — skipping profile flamegraph" >&2
        return 1
    fi

    local line_count=0
    line_count=$(wc -l < "$profile_log" 2>/dev/null || echo 0)
    if [[ "$line_count" -lt 2 ]]; then
        echo "[puppet-trace] not enough PROFILE entries ($line_count) for flamegraph" >&2
        return 1
    fi

    # puppet-profile-parser.rb expects logback format:
    #   <ts> <level> [<thread>] [<javaclass>] Puppet PROFILE ...
    # Our puppetserver container omits [javaclass], so inject a placeholder.
    local normalized_log
    normalized_log=$(mktemp "$(dirname "$svg_out")/puppet-trace-tmp.XXXXX.log")
    sed 's/ Puppet PROFILE/ [puppet.server] Puppet PROFILE/' \
        "$profile_log" > "$normalized_log"
    ruby "$parser" -f flamegraph "$normalized_log" \
        | "$flamegraph_pl" --countname ms --title "Puppet Catalog Compilation" \
        > "$svg_out" 2>/dev/null
    rm -f "$normalized_log"
    [[ -s "$svg_out" ]] || return 1

    if [[ -s "$svg_out" ]]; then
        local sz
        sz=$(wc -c < "$svg_out")
        echo "[puppet-trace] profile flamegraph: $svg_out (${sz} bytes, ${line_count} PROFILE entries)"
        return 0
    else
        rm -f "$svg_out"
        return 1
    fi
}

###############################################################################
# SHARED: collect-mode HTML report (lighter than once-mode)
###############################################################################
_generate_collect_report() {
    local outdir="$1"
    local puppet_log="$2"
    local proc_log="$3"
    local profile_flamegraph_svg="$4"
    local report_html="$5"
    local transaction_uuid="$6"
    local puppet_version="$7"
    local puppet_server="$8"
    local profile_line_count="$9"
    local resource_report_json="${10:-}"
    local sysctx_file="${11:-}"

    python3 - \
        "$outdir" \
        "$puppet_log" \
        "$proc_log" \
        "$profile_flamegraph_svg" \
        "$report_html" \
        "$transaction_uuid" \
        "$puppet_version" \
        "$puppet_server" \
        "$profile_line_count" \
        "$resource_report_json" \
        "$sysctx_file" \
        <<'PYEOF'
import sys, os, re, json, html, datetime

outdir                 = sys.argv[1]
puppet_log             = sys.argv[2]
proc_log               = sys.argv[3]
profile_flamegraph_svg = sys.argv[4]
report_html            = sys.argv[5]
transaction_uuid       = sys.argv[6]
puppet_version         = sys.argv[7]
puppet_server          = sys.argv[8]
profile_line_count     = int(sys.argv[9])
resource_report_json   = sys.argv[10] if len(sys.argv) > 10 else ''
sysctx_file            = sys.argv[11] if len(sys.argv) > 11 else ''

hostname = os.uname().nodename
now      = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')

def fmt_bytes_c(n):
    n = float(n)
    for unit in ('B','KB','MB','GB','TB'):
        if abs(n) < 1024:
            return f'{n:.1f} {unit}'
        n /= 1024
    return f'{n:.1f} PB'

# ── puppet log ────────────────────────────────────────────────────────────────
puppet_lines = []
if os.path.isfile(puppet_log):
    with open(puppet_log) as f:
        puppet_lines = f.readlines()

# ── proc snapshot ─────────────────────────────────────────────────────────────
proc_text = ''
if os.path.isfile(proc_log):
    with open(proc_log) as f:
        proc_text = f.read()

# ── resource report ───────────────────────────────────────────────────────────
rr_resources  = []
rr_trans_uuid = transaction_uuid
rr_pversion   = puppet_version
rr_status     = ''
res_changed = res_failed = res_skipped = res_total = 0
resource_table_rows = ''

if resource_report_json and os.path.isfile(resource_report_json):
    try:
        with open(resource_report_json) as f:
            rrd = json.load(f)
        rr_resources  = rrd.get('resources', [])
        rr_trans_uuid = rrd.get('transaction_uuid', transaction_uuid) or transaction_uuid
        rr_pversion   = rrd.get('puppet_version', puppet_version) or puppet_version
        rr_status     = rrd.get('status', '')
        res_changed = sum(1 for r in rr_resources if r.get('changed'))
        res_failed  = sum(1 for r in rr_resources if r.get('failed'))
        res_skipped = sum(1 for r in rr_resources if r.get('skipped'))
        res_total   = len(rr_resources)

        def status_badge_c(status):
            colors = {'changed':('#1a6b3a','#d4edda'),'failed':('#7a1a1a','#f8d7da'),
                      'skipped':('#6b5a1a','#fff3cd'),'out_of_sync':('#3a3a7a','#cce5ff'),
                      'unknown':('#555','#eee'),'unchanged':('#555','#eee')}
            fg, bg = colors.get(status, ('#555','#eee'))
            return f'<span style="background:{bg};color:{fg};padding:2px 7px;border-radius:3px;font-size:0.8em;font-weight:bold">{html.escape(status)}</span>'

        for r in rr_resources:
            before = html.escape(str(r.get('before') or '—'))
            after  = html.escape(str(r.get('after')  or '—'))
            resource_table_rows += (
                f'<tr><td>{html.escape(r["title"])}</td>'
                f'<td>{html.escape(r.get("type",""))}</td>'
                f'<td>{status_badge_c(r.get("status","unknown"))}</td>'
                f'<td>{r.get("evaluation_time",0):.3f}s</td>'
                f'<td>{before}</td><td>{after}</td></tr>\n'
            )
    except Exception as e:
        resource_table_rows = f'<tr><td colspan="6" style="color:red">Error loading resource-report.json: {html.escape(str(e))}</td></tr>'

# ── system context ────────────────────────────────────────────────────────────
sysctx_text = ''
if sysctx_file and os.path.isfile(sysctx_file):
    with open(sysctx_file) as f:
        sysctx_text = f.read()

# ── extract compile/apply times from puppet log ───────────────────────────────
compile_time = None
apply_time   = None
for line in puppet_lines:
    m = re.search(r'Compiled catalog.*in.*?(\d+\.\d+) seconds', line)
    if m:
        compile_time = float(m.group(1))
    m = re.search(r'Applied catalog in.*?(\d+\.\d+) seconds', line)
    if m:
        apply_time = float(m.group(1))

resource_count = sum(1 for l in puppet_lines if re.search(r'^Notice: /Stage', l))

# ── profile flamegraph ────────────────────────────────────────────────────────
import re as _re
def _sanitize_svg(s):
    import re as _re
    # Remove <script> blocks including self-closing/unclosed variants
    s = _re.sub(r'<script\b[^>]*>.*?</script>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    s = _re.sub(r'<script\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    # Remove animate/set elements that can animate href to javascript: URIs
    s = _re.sub(r'<(?:animate|set)\b[^>]*/?\s*>', '', s, flags=_re.IGNORECASE)
    s = _re.sub(r'<(?:animate|set)\b.*?</(?:animate|set)>', '', s, flags=_re.DOTALL|_re.IGNORECASE)
    # Neutralize javascript: URIs in href attributes (quoted and unquoted)
    s = _re.sub(r'((?:xlink:)?href\s*=\s*["\']?)javascript:', r'\1#', s, flags=_re.IGNORECASE)
