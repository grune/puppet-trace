    p = os.path.join(d, 'resource-report.json')
    if not os.path.exists(p):
        return {}
    try:
        data = json.load(open(p))
        return {r['title']: r for r in data.get('resources', data if isinstance(data, list) else [])}
    except Exception as e:
        print(f'Warning: could not load {p}: {e}', file=sys.stderr)
