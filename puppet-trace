# C000020A = 192.0.2.10 big-endian hex
# 7F000001 = 127.0.0.1
# Ports: 0035=53, 01BB=443, 21BC=8636, 1FC4=8132 (puppetserver=8140=1FCC, puppetdb=8081=1F91)
net_blocks = []
for blk in range(10):
    ts = BASE_TS + blk * 5
    lines = [f"# ts={ts}"]
    # DNS always present
    lines.append("0100007F:0035 0A")
    # Puppet server
    lines.append("C000020A:1FCC 06")
    if 3 <= blk <= 6:
        # Package install phase: apt mirrors
        lines.append("C000020A:01BB 06")
        lines.append("C000020A:0050 06")
        if blk == 4 or blk == 5:
            lines.append("0A000201:01BB 06")
            lines.append("0A000201:0050 06")
    else:
        # PuppetDB
        lines.append("C000020A:1F91 06")
    net_blocks.append("\n".join(lines))
with open(os.path.join(outdir, "net-poll.log"), "w") as f:
