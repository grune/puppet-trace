def rss_at(t):
    base = 95000
    # nginx install
    if 4 <= t <= 6:   base += int(20000 * (t-4)/2)
    elif t > 6:        base += 20000
    # vim install
    if 9 <= t <= 11:  base += int(15000 * (t-9)/2)
