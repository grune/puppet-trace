###############################################################################
SUBCOMMAND="${1:-once}"
case "$SUBCOMMAND" in
    enable)   cmd_enable;  exit $? ;;
    disable)  cmd_disable; exit $? ;;
    status)   cmd_status;  exit $? ;;
    collect)  shift; cmd_collect "$@"; exit $? ;;
    report)   shift; _LATE_SUBCMD=report; _LATE_ARGS=("$@"); set -- ;;
    ship)     shift; _LATE_SUBCMD=ship;   _LATE_ARGS=("$@"); set -- ;;
    once)     shift ;;  # fall through to legacy/once logic below
    --help|-h) usage ;;
    --dry-run|--outdir|--)
        # legacy invocation without subcommand — treat as 'once'
        ;;
