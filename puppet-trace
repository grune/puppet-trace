    WALL_SECONDS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('wall_seconds',0)))" "$meta" 2>/dev/null || echo 47)
    PUPPET_EXIT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('puppet_exit',0)))" "$meta" 2>/dev/null || echo 0)
    PUPPET_CMD_META=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('puppet_cmd','puppet agent --test'))" "$meta" 2>/dev/null || echo "puppet agent --test")
    IDEMPOTENCY_PASS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('idempotency_pass','true'))" "$meta" 2>/dev/null || echo "true")
    IDEMPOTENCY_CHANGES=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('idempotency_changes',0)))" "$meta" 2>/dev/null || echo 0)
    RUN_START_ISO=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('run_start_iso',''))" "$meta" 2>/dev/null || echo "")
    read -r -a PUPPET_CMD <<< "$PUPPET_CMD_META"

    echo "[puppet-trace demo] generating HTML report..."
    generate_report

    echo ""
    echo "[puppet-trace demo] report: $DEMO_OUTDIR/report.html"
    echo "[puppet-trace demo] outdir: $DEMO_OUTDIR"
}

###############################################################################
# LATE DISPATCH — report/ship need functions defined above; handled here
###############################################################################
if [[ -n "${_LATE_SUBCMD:-}" ]]; then
    "cmd_${_LATE_SUBCMD}" "${_LATE_ARGS[@]}"
    exit $?
fi

###############################################################################
# ONCE MODE MAIN
###############################################################################
probe_capabilities

echo "[puppet-trace] mode: once"
echo "[puppet-trace] output dir: $OUTDIR"
echo "[puppet-trace] capabilities: root=$IS_ROOT strace=$HAS_STRACE perf=$HAS_PERF inotify=$HAS_INOTIFY flamegraph=$HAS_FLAMEGRAPH"
echo "[puppet-trace] command: ${PUPPET_CMD[*]}"

if $DRY_RUN; then
    generate_fixture_data
else
    toggle_server_profiling enable "$PROFILING_SERVER"
    run_puppet
    toggle_server_profiling disable "$PROFILING_SERVER"
fi

generate_flamegraph
collect_profile_flamegraph

WALL_SECONDS=${WALL_SECONDS:-0}
PUPPET_EXIT=${PUPPET_EXIT:-0}
RUN_START_ISO=${RUN_START_ISO:-}

# Post-run analysis (only for real runs)
if ! $DRY_RUN; then
    parse_last_run_report || true
    enrich_from_puppetdb  || true
    run_strace_correlation || true
    if [[ $EUID -eq 0 ]]; then
        run_idempotency_check || true
    else
        echo "[puppet-trace] skipping idempotency check (not root)"
    fi
fi

save_run_meta || true
emit_prometheus_textfile || true
generate_report
push_report_to_server "$PUSH_SERVER" || true

# Summary stats from correlation
STRACE_EVENTS=0
RESOURCES_IN_TABLE=0
TOP_WRITER=""
if [[ -f "$IO_CORR_JSON" ]]; then
    STRACE_EVENTS=$(python3 -c "
import json,sys
data=json.load(open(sys.argv[1]))
print(sum(r.get('strace_events',0) for r in data))
" "$IO_CORR_JSON" 2>/dev/null || echo 0)
    RESOURCES_IN_TABLE=$(python3 -c "
import json,sys
data=json.load(open(sys.argv[1]))
print(len(data))
" "$IO_CORR_JSON" 2>/dev/null || echo 0)
    TOP_WRITER=$(python3 -c "
import json,sys
data=json.load(open(sys.argv[1]))
if data:
    top=data[0]
    b=top.get('disk_bytes_written',0)
    mb=b/1048576
    print(f\"{top['title']} wrote {mb:.1f}MB\")
" "$IO_CORR_JSON" 2>/dev/null || echo "n/a")
elif [[ -f "$OUTDIR/resource-report.json" ]]; then
    RESOURCES_IN_TABLE=$(python3 -c "
import json,sys
data=json.load(open(sys.argv[1]))
print(len(data.get('resources',[])))
" "$OUTDIR/resource-report.json" 2>/dev/null || echo 0)
fi

PROFILE_AVAILABLE=no
[[ -s "$PROFILE_FLAMEGRAPH_SVG" ]] && PROFILE_AVAILABLE=yes

echo ""
echo "Report: $REPORT_HTML"
echo "Output dir: $OUTDIR"
echo "Wall time: ${WALL_SECONDS}s | Puppet exit: $PUPPET_EXIT"
echo "Resources in table: ${RESOURCES_IN_TABLE}"
echo "Idempotency: ${IDEMPOTENCY_PASS}"
echo "Profile flamegraph: ${PROFILE_AVAILABLE}"
echo "strace events correlated: ${STRACE_EVENTS}"
if [[ -n "$TOP_WRITER" ]]; then
    echo "Top disk writer: ${TOP_WRITER}"
fi
