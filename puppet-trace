###############################################################################
# Prometheus textfile emitter (once mode)
###############################################################################
emit_prometheus_textfile() {
    [[ -z "${PROMETHEUS_TEXTFILE:-}" ]] && return 0
    _validate_safe_path "$PROMETHEUS_TEXTFILE" "--prometheus-textfile" || return 1

    python3 - "$IO_CORR_JSON" "$OUTDIR/run-meta.json" "$PROMETHEUS_TEXTFILE" \
        "${OUTDIR##*/}" <<'PROM_PYEOF'
import json, os, sys, time, re

io_corr_path, meta_path, outpath, run_id = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

resources = []
if os.path.exists(io_corr_path):
    try:
        resources = json.load(open(io_corr_path))
    except Exception:
        pass

meta = {}
if os.path.exists(meta_path):
    try:
        meta = json.load(open(meta_path))
    except Exception:
        pass

lines = []
ts_ms = int(time.time() * 1000)
run_label = f'run="{run_id}"'

# Run-level metrics
lines.append(f'# HELP puppet_trace_run_wall_seconds Total wall clock seconds for puppet run')
lines.append(f'# TYPE puppet_trace_run_wall_seconds gauge')
lines.append(f'puppet_trace_run_wall_seconds{{{run_label}}} {meta.get("wall_seconds", 0)} {ts_ms}')

lines.append(f'# HELP puppet_trace_run_exit_code Puppet agent exit code (0=success)')
lines.append(f'# TYPE puppet_trace_run_exit_code gauge')
lines.append(f'puppet_trace_run_exit_code{{{run_label}}} {meta.get("puppet_exit", -1)} {ts_ms}')

# Resource-level metrics
lines.append(f'# HELP puppet_trace_resource_duration_seconds Per-resource wall time in seconds')
lines.append(f'# TYPE puppet_trace_resource_duration_seconds gauge')
lines.append(f'# HELP puppet_trace_resource_disk_bytes_written Per-resource disk bytes written')
lines.append(f'# TYPE puppet_trace_resource_disk_bytes_written gauge')
lines.append(f'# HELP puppet_trace_resource_disk_bytes_read Per-resource disk bytes read')
lines.append(f'# TYPE puppet_trace_resource_disk_bytes_read gauge')
lines.append(f'# HELP puppet_trace_resource_strace_events Per-resource strace event count')
lines.append(f'# TYPE puppet_trace_resource_strace_events gauge')

for r in resources[:200]:  # cap at 200 resources to bound metric count
    title = r.get('resource', r.get('title', 'unknown'))
    safe_title = re.sub(r'[^a-zA-Z0-9_]', '_', str(title))[:128]
    label = f'{run_label},resource="{safe_title}"'
    dur = float(r.get('t_end', 0) - r.get('t_start', 0)) if r.get('t_end') and r.get('t_start') else float(r.get('duration_s', 0))
    dbw = int(r.get('disk_bytes_written', 0) or 0)
    dbr = int(r.get('disk_bytes_read', 0) or 0)
    sevt = int(r.get('strace_events', 0) or 0)
    lines.append(f'puppet_trace_resource_duration_seconds{{{label}}} {dur:.4f} {ts_ms}')
    lines.append(f'puppet_trace_resource_disk_bytes_written{{{label}}} {dbw} {ts_ms}')
    lines.append(f'puppet_trace_resource_disk_bytes_read{{{label}}} {dbr} {ts_ms}')
    lines.append(f'puppet_trace_resource_strace_events{{{label}}} {sevt} {ts_ms}')

# Write atomically
tmp = outpath + '.tmp'
try:
    with open(tmp, 'w') as f:
        f.write('\n'.join(lines) + '\n')
    os.replace(tmp, outpath)
    print(f'[puppet-trace] Prometheus textfile written: {outpath} ({len(lines)} lines)')
except Exception as e:
    print(f'[puppet-trace] WARNING: could not write Prometheus textfile: {e}', file=sys.stderr)
PROM_PYEOF
}

###############################################################################
# puppet-trace-server integration
###############################################################################
toggle_server_profiling() {
    local action="$1"   # enable or disable
    local server="$2"   # host:port
    [[ -z "$server" ]] && return 0
    local url="http://${server}/api/profiling/${action}"
    local result
    result=$(curl -sf -X POST "$url" --max-time 5 2>/dev/null) || {
        echo "[puppet-trace] WARNING: could not ${action} profiling on $server" >&2
        return 0
    }
    echo "[puppet-trace] profiling ${action}d on $server: $result"
}

push_report_to_server() {
    local server="$1"
    [[ -z "$server" ]] && return 0
    local certname
    certname=$(puppet config print certname 2>/dev/null || hostname -f)
    local runid
    runid=$(basename "$OUTDIR")
    local base_url="http://${server}/reports/${certname}/${runid}"
    local token="${PT_UPLOAD_TOKEN:-}"
    local headers=()
    [[ -n "$token" ]] && headers+=(-H "X-PT-Token: $token")

    local pushed=0
    for f in "$OUTDIR/report.html" "$OUTDIR/run-meta.json" "$OUTDIR/io-correlation.json" \
              "$OUTDIR/resource-report.json" \
              "$OUTDIR/flamegraph.svg" "$OUTDIR/flamegraph-profile.svg"; do
        [[ -f "$f" ]] || continue
        local fname
        fname=$(basename "$f")
        if curl -sf -X PUT "${headers[@]}" \
            --data-binary "@$f" \
            --max-time 30 \
            "${base_url}/${fname}" >/dev/null 2>&1; then
            echo "[puppet-trace] pushed $fname → $base_url/$fname"
            (( pushed++ )) || true
        else
            echo "[puppet-trace] WARNING: failed to push $fname to $server" >&2
        fi
    done
    [[ $pushed -gt 0 ]] && echo "[puppet-trace] report available at http://${server}/reports/${certname}/${runid}/report.html"
}

###############################################################################
# SUBCOMMAND: report — regenerate HTML from existing outdir
# (defined here so generate_report / run_strace_correlation / etc. are in scope)
###############################################################################
cmd_report() {
    local outdir="${1:-}"
    if [[ -z "$outdir" ]]; then
        outdir=$(ls -dt /var/log/puppet-trace/*/ 2>/dev/null | head -1)
        [[ -n "$outdir" ]] || { echo "report: no outdir found under /var/log/puppet-trace/" >&2; exit 1; }
        echo "[puppet-trace report] using latest outdir: $outdir"
    fi
    [[ -d "$outdir" ]] || { echo "report: not a directory: $outdir" >&2; exit 1; }
    outdir="${outdir%/}"
    _validate_safe_path "$outdir" "outdir" || exit 1

    local meta="$outdir/run-meta.json"
    WALL_SECONDS=0; PUPPET_EXIT=0; PUPPET_CMD_META="puppet agent --test"
    IDEMPOTENCY_PASS=unknown; IDEMPOTENCY_CHANGES=0; RUN_START_ISO=""
    if [[ -f "$meta" ]]; then
        WALL_SECONDS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('wall_seconds',0)))" "$meta" 2>/dev/null || echo 0)
        PUPPET_EXIT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('puppet_exit',0)))" "$meta" 2>/dev/null || echo 0)
        PUPPET_CMD_META=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('puppet_cmd','puppet agent --test'))" "$meta" 2>/dev/null || echo "puppet agent --test")
        IDEMPOTENCY_PASS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('idempotency_pass','unknown'))" "$meta" 2>/dev/null || echo "unknown")
        IDEMPOTENCY_CHANGES=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(int(d.get('idempotency_changes',0)))" "$meta" 2>/dev/null || echo 0)
        RUN_START_ISO=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('run_start_iso',''))" "$meta" 2>/dev/null || echo "")
    else
        echo "[puppet-trace report] WARNING: run-meta.json not found in $outdir — using defaults" >&2
    fi

    # Validate ISO date format before use in SSH --since arg
    if [[ -n "$RUN_START_ISO" ]] && [[ ! "$RUN_START_ISO" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z?$ ]]; then
        echo "[puppet-trace] WARNING: run_start_iso has unexpected format, ignoring: $RUN_START_ISO" >&2
        RUN_START_ISO=""
    fi

    OUTDIR="$outdir"
    PUPPET_LOG="$outdir/puppet.log"
    PROC_LOG="$outdir/proc-poll.log"
    NET_LOG="$outdir/net-poll.log"
    STRACE_LOG="$outdir/strace.log"
    INOTIFY_LOG="$outdir/inotify.log"
    FLAMEGRAPH_SVG="$outdir/flamegraph.svg"
    PROFILE_FLAMEGRAPH_SVG="$outdir/flamegraph-profile.svg"
    PROFILE_LOG="$outdir/puppetserver-profile.log"
    STRACE_RAW="$outdir/strace.raw"
    IO_CORR_JSON="$outdir/io-correlation.json"
    IDEMPOTENCY_STDOUT="$outdir/idempotency.stdout"
    REPORT_HTML="$outdir/report.html"
    read -r -a PUPPET_CMD <<< "$PUPPET_CMD_META"

    if [[ ! -s "$PROFILE_FLAMEGRAPH_SVG" ]] && [[ -s "$PROFILE_LOG" ]]; then
        echo "[puppet-trace report] profile.log present but flamegraph SVG missing — regenerating..."
        _generate_profile_flamegraph "$PROFILE_LOG" "$PROFILE_FLAMEGRAPH_SVG" "$SCRIPT_DIR" || true
    fi
    if [[ ! -f "$IO_CORR_JSON" ]] && [[ -f "$STRACE_RAW" ]]; then
        echo "[puppet-trace report] strace.raw present but io-correlation.json missing — re-correlating..."
        run_strace_correlation || true
    fi
    if [[ ! -s "$FLAMEGRAPH_SVG" ]]; then
        generate_flamegraph || true
    fi

    echo "[puppet-trace report] generating HTML from $outdir..."
    generate_report
    echo "[puppet-trace report] done"
    echo "Report: $REPORT_HTML"
}

###############################################################################
# SUBCOMMAND: ship — rsync outdir to remote + regenerate report there
###############################################################################
cmd_ship() {
    local outdir="${1:-}"
    local remote="${2:-}"
    if [[ -z "$outdir" ]] || [[ -z "$remote" ]]; then
        echo "Usage: puppet-trace ship <outdir> <[user@]host:path> [--include-strace]" >&2
        echo "  Ships artifacts (excl. strace.raw/perf.data) then runs: puppet-trace report <path>" >&2
        exit 1
    fi
    shift 2
    [[ -d "$outdir" ]] || { echo "ship: not a directory: $outdir" >&2; exit 1; }
    outdir="${outdir%/}"
    _validate_safe_path "$outdir" "outdir" || exit 1

    local include_strace=false rsync_extra=()
    for arg in "$@"; do
        if [[ "$arg" == "--include-strace" ]]; then
            include_strace=true
        else
            # Whitelist safe rsync args; reject dangerous flags
            case "$arg" in
                --checksum|--compress|-z|-c|--progress|--verbose|-v|--dry-run|-n)
                    rsync_extra+=("$arg") ;;
                --bwlimit=*|--timeout=*)
                    rsync_extra+=("$arg") ;;
                *)
                    echo "[puppet-trace] ship: ignoring unrecognized/unsafe arg: $arg" >&2 ;;
            esac
        fi
    done

    local remote_host="${remote%%:*}"
    local remote_path="${remote#*:}"
    [[ "$remote_path" == "$remote_host" ]] && { echo "ship: remote must be [user@]host:path" >&2; exit 1; }
    # Allow user@host format: validate each component separately
    local ssh_user="" ssh_host="$remote_host"
    if [[ "$remote_host" == *@* ]]; then
        ssh_user="${remote_host%%@*}"
        ssh_host="${remote_host#*@}"
        _validate_puppet_id "$ssh_user" "remote_user" || exit 1
    fi
    _validate_puppet_id "$ssh_host" "remote_host" || exit 1
    _validate_safe_path "$remote_path" "remote path" || exit 1

    local exclude_args=(--exclude='strace.raw' --exclude='perf.data')
    $include_strace && exclude_args=()

    echo "[puppet-trace ship] $outdir → $remote (${exclude_args[*]:-no exclusions})"
    rsync -av --progress --chmod=D0755,F0644 "${exclude_args[@]}" "${rsync_extra[@]}" "$outdir/" "${remote}/"
    echo "[puppet-trace ship] synced — running report on $remote_host..."
    # shellcheck disable=SC2029  # printf %q is intentional — quotes path for remote shell
    ssh -o BatchMode=yes -o ConnectTimeout=30 -o StrictHostKeyChecking=yes "$remote_host" \
        "puppet-trace report -- $(printf '%q' "$remote_path")"
    echo "[puppet-trace ship] done — report at $remote_host:${remote_path}/report.html"
}

