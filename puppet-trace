probe_capabilities() {
    [[ $EUID -eq 0 ]] && IS_ROOT=true
    command -v strace      &>/dev/null && HAS_STRACE=true
    command -v perf        &>/dev/null && HAS_PERF=true
    command -v inotifywait &>/dev/null && HAS_INOTIFY=true
    command -v flamegraph.pl         &>/dev/null && HAS_FLAMEGRAPH=true
    command -v stackcollapse-perf.pl &>/dev/null && HAS_STACKCOLLAPSE=true

    if $HAS_PERF && ! $IS_ROOT; then
        local paranoid
        paranoid=$(cat /proc/sys/kernel/perf_event_paranoid 2>/dev/null || echo 3)
        [[ $paranoid -le 1 ]] || HAS_PERF=false
    fi
    $IS_ROOT || HAS_STRACE=false
}

